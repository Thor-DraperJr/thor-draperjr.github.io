---
import Layout from '../layouts/Layout.astro';
import { getResumePage } from '../lib/content';

const page = getResumePage();
---

<Layout pageTitle={page.title} pageDescription={page.excerpt} currentPath="/resume/">
  <section class="post-layout">
    <header class="page-hero">
      <span class="eyebrow">Resume</span>
      <h1 class="page-title">{page.title}</h1>
      <p class="section-copy">Professional experience, platform focus, and leadership work in one place.</p>
    </header>

    <article class="prose panel" set:html={page.html}></article>
  </section>
</Layout>