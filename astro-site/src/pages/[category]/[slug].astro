---
import Layout from '../../layouts/Layout.astro';
import RuntimeControlChart from '../../components/RuntimeControlChart.astro';
import CareerDevelopmentPlan from '../../components/CareerDevelopmentPlan.astro';
import CharlotteArtsMap from '../../components/CharlotteArtsMap.astro';
import WalkingDeck from '../../components/WalkingDeck.astro';
import Agent365Deck from '../../components/Agent365Deck.astro';
import AllAboardSlide from '../../components/AllAboardSlide.astro';
import LifecycleLanes from '../../components/LifecycleLanes.astro';
import E7Stack from '../../components/E7Stack.astro';
import AgentModes from '../../components/AgentModes.astro';
import FourPositions from '../../components/FourPositions.astro';
import ThreeNewYears from '../../components/ThreeNewYears.astro';
import PerformanceNarrative from '../../components/PerformanceNarrative.astro';
import { getPosts } from '../../lib/content';

export function getStaticPaths() {
  const posts = getPosts();

  return posts.map((post, index) => ({
    params: {
      category: post.category,
      slug: post.slug,
    },
    props: {
      post,
      previous: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null,
    },
  }));
}

const { post, previous, next } = Astro.props;

const runtimeChartMarker = '[[RUNTIME_CONTROL_CHART]]';
const careerDevPlanMarker = '[[CAREER_DEV_PLAN]]';
const charlotteArtsMapMarker = '[[CHARLOTTE_ARTS_MAP]]';
const walkingDeckMarker = '[[WALKING_DECK]]';
const agent365DeckMarker = '[[AGENT365_DECK]]';
const allAboardMarker = '[[ALL_ABOARD]]';
const lifecycleLanesMarker = '[[LIFECYCLE_LANES]]';
const e7StackMarker = '[[E7_STACK]]';
const agentModesMarker = '[[AGENT_MODES]]';
const fourPositionsMarker = '[[FOUR_POSITIONS]]';
const allAboardSlideMarkers = ['01', '02', '03', '04', '05', '06', '07', '08', '09', '10'].map(
  (n) => `[[SLIDE_${n}]]`,
);
const threeNewYearsMarker = '[[THREE_NEW_YEARS]]';
const performanceNarrativeMarker = '[[PERFORMANCE_NARRATIVE]]';

let processedHtml = post.html;
processedHtml = processedHtml.replace(`<p>${runtimeChartMarker}</p>`, runtimeChartMarker);
processedHtml = processedHtml.replace(`<p>${careerDevPlanMarker}</p>`, careerDevPlanMarker);
processedHtml = processedHtml.replace(`<p>${charlotteArtsMapMarker}</p>`, charlotteArtsMapMarker);
processedHtml = processedHtml.replace(`<p>${walkingDeckMarker}</p>`, walkingDeckMarker);
processedHtml = processedHtml.replace(`<p>${agent365DeckMarker}</p>`, agent365DeckMarker);
processedHtml = processedHtml.replace(`<p>${allAboardMarker}</p>`, allAboardMarker);
processedHtml = processedHtml.replace(`<p>${lifecycleLanesMarker}</p>`, lifecycleLanesMarker);
processedHtml = processedHtml.replace(`<p>${e7StackMarker}</p>`, e7StackMarker);
processedHtml = processedHtml.replace(`<p>${agentModesMarker}</p>`, agentModesMarker);
processedHtml = processedHtml.replace(`<p>${fourPositionsMarker}</p>`, fourPositionsMarker);
for (const slideMarker of allAboardSlideMarkers) {
  processedHtml = processedHtml.replace(`<p>${slideMarker}</p>`, slideMarker);
}
processedHtml = processedHtml.replace(`<p>${threeNewYearsMarker}</p>`, threeNewYearsMarker);
processedHtml = processedHtml.replace(`<p>${performanceNarrativeMarker}</p>`, performanceNarrativeMarker);

const hasRuntimeChart = processedHtml.includes(runtimeChartMarker);
const hasCareerDevPlan = processedHtml.includes(careerDevPlanMarker);
const hasCharlotteArtsMap = processedHtml.includes(charlotteArtsMapMarker);
const hasWalkingDeck = processedHtml.includes(walkingDeckMarker);
const hasAgent365Deck = processedHtml.includes(agent365DeckMarker);
const hasAllAboard = processedHtml.includes(allAboardMarker);
const hasThreeNewYears = processedHtml.includes(threeNewYearsMarker);
const hasPerformanceNarrative = processedHtml.includes(performanceNarrativeMarker);

const runtimeParts = hasRuntimeChart ? processedHtml.split(runtimeChartMarker) : [];
const careerParts = hasCareerDevPlan ? processedHtml.split(careerDevPlanMarker) : [];
const charlotteArtsMapParts = hasCharlotteArtsMap ? processedHtml.split(charlotteArtsMapMarker) : [];
const walkingDeckParts = hasWalkingDeck ? processedHtml.split(walkingDeckMarker) : [];
const agent365DeckParts = hasAgent365Deck ? processedHtml.split(agent365DeckMarker) : [];
const allAboardParts = hasAllAboard ? processedHtml.split(allAboardMarker) : [];
// Everything after the [[ALL_ABOARD]] gate is prose with embedded figure
// markers (SLIDE_xx, LIFECYCLE_LANES, E7_STACK, AGENT_MODES). Walk it once and
// build an ordered list of prose/figure segments so the talk reads top to
// bottom: speak, show the slide, keep speaking.
const allAboardBody = hasAllAboard ? allAboardParts.slice(1).join(allAboardMarker) : '';
const allAboardMarkerRegex = /\[\[(?:SLIDE_\d{2}|LIFECYCLE_LANES|E7_STACK|AGENT_MODES|FOUR_POSITIONS)\]\]/g;
const allAboardSegments: Array<{ kind: 'html' | 'marker'; value: string }> = [];
if (hasAllAboard) {
  let lastIndex = 0;
  let match: RegExpExecArray | null;
  while ((match = allAboardMarkerRegex.exec(allAboardBody)) !== null) {
    if (match.index > lastIndex) {
      allAboardSegments.push({ kind: 'html', value: allAboardBody.slice(lastIndex, match.index) });
    }
    allAboardSegments.push({ kind: 'marker', value: match[0] });
    lastIndex = match.index + match[0].length;
  }
  if (lastIndex < allAboardBody.length) {
    allAboardSegments.push({ kind: 'html', value: allAboardBody.slice(lastIndex) });
  }
}
const threeNewYearsParts = hasThreeNewYears ? processedHtml.split(threeNewYearsMarker) : [];
const performanceNarrativeParts = hasPerformanceNarrative ? processedHtml.split(performanceNarrativeMarker) : [];
---

<Layout pageTitle={post.title} pageDescription={post.excerpt}>
  {hasPerformanceNarrative ? (
    <>
      <article class="shell-container">
        <header class="post-hero">
          <span class="eyebrow">{post.category}</span>
          <h1 class="post-heading">{post.title}</h1>
          <div class="post-meta-row">
            <span>{post.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span>{post.readingTime} min read</span>
          </div>
          {post.tags.length > 0 && (
            <div class="post-tags" style="margin-top: 1rem;">
              {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
            </div>
          )}
        </header>

        {performanceNarrativeParts.length > 0 && performanceNarrativeParts[0].trim() && (
          <section class="prose panel">
            <Fragment set:html={performanceNarrativeParts[0]} />
          </section>
        )}
      </article>

      <div class="cdp-breakout">
        <PerformanceNarrative />
      </div>

      <article class="shell-container">
        {performanceNarrativeParts.length > 1 && (
          <section class="prose panel">
            <Fragment set:html={performanceNarrativeParts.slice(1).join(performanceNarrativeMarker)} />
          </section>
        )}

        <nav class="post-pagination">
          {previous ? (
            <a href={previous.permalink}>
              <span>Older</span>
              {previous.title}
            </a>
          ) : <div></div>}

          {next ? (
            <a href={next.permalink} style="text-align: right;">
              <span>Newer</span>
              {next.title}
            </a>
          ) : <div></div>}
        </nav>
      </article>
    </>
  ) : hasCareerDevPlan ? (
    <>
      <article class="shell-container">
        <header class="post-hero">
          <span class="eyebrow">{post.category}</span>
          <h1 class="post-heading">{post.title}</h1>
          <div class="post-meta-row">
            <span>{post.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span>{post.readingTime} min read</span>
          </div>
          {post.tags.length > 0 && (
            <div class="post-tags" style="margin-top: 1rem;">
              {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
            </div>
          )}
        </header>
      </article>

      <div class="cdp-breakout">
        <CareerDevelopmentPlan />
      </div>

      <article class="shell-container">
        {careerParts.length > 1 && (
          <section class="prose panel">
            <Fragment set:html={careerParts.slice(1).join(careerDevPlanMarker)} />
          </section>
        )}

        <nav class="post-pagination">
          {previous ? (
            <a href={previous.permalink}>
              <span>Older</span>
              {previous.title}
            </a>
          ) : <div></div>}

          {next ? (
            <a href={next.permalink} style="text-align: right;">
              <span>Newer</span>
              {next.title}
            </a>
          ) : <div></div>}
        </nav>
      </article>
    </>
  ) : hasAgent365Deck ? (
    <>
      <article class="shell-container">
        <header class="post-hero">
          <span class="eyebrow">{post.category}</span>
          <h1 class="post-heading">{post.title}</h1>
          <div class="post-meta-row">
            <span>{post.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span>{post.readingTime} min read</span>
          </div>
          {post.tags.length > 0 && (
            <div class="post-tags" style="margin-top: 1rem;">
              {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
            </div>
          )}
        </header>
      </article>

      <div class="walking-deck-breakout">
        <Agent365Deck />
      </div>

      <article class="shell-container">
        <section class="prose panel">
          <Fragment set:html={agent365DeckParts.join('')} />
        </section>

        <nav class="post-pagination">
          {previous ? (
            <a href={previous.permalink}>
              <span>Older</span>
              {previous.title}
            </a>
          ) : <div></div>}

          {next ? (
            <a href={next.permalink} style="text-align: right;">
              <span>Newer</span>
              {next.title}
            </a>
          ) : <div></div>}
        </nav>
      </article>
    </>
  ) : hasAllAboard ? (
    <>
      <article class="shell-container">
        <header class="post-hero">
          <span class="eyebrow">{post.category}</span>
          <h1 class="post-heading">{post.title}</h1>
          <div class="post-meta-row">
            <span>{post.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span>{post.readingTime} min read</span>
          </div>
          {post.tags.length > 0 && (
            <div class="post-tags" style="margin-top: 1rem;">
              {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
            </div>
          )}
        </header>

        {allAboardParts.length > 0 && allAboardParts[0].trim() && (
          <section class="prose panel">
            <Fragment set:html={allAboardParts[0]} />
          </section>
        )}
      </article>

      {allAboardSegments.map((seg) => (
        seg.kind === 'html' ? (
          seg.value.trim() && (
            <article class="shell-container">
              <section class="prose panel">
                <Fragment set:html={seg.value} />
              </section>
            </article>
          )
        ) : seg.value.startsWith('[[SLIDE_') ? (
          <div class="walking-deck-breakout">
            <AllAboardSlide n={seg.value.slice(8, 10)} />
          </div>
        ) : seg.value === lifecycleLanesMarker ? (
          <article class="shell-container">
            <LifecycleLanes />
          </article>
        ) : seg.value === e7StackMarker ? (
          <article class="shell-container">
            <E7Stack />
          </article>
        ) : seg.value === fourPositionsMarker ? (
          <article class="shell-container">
            <FourPositions />
          </article>
        ) : (
          <article class="shell-container">
            <AgentModes />
          </article>
        )
      ))}

      <article class="shell-container">
        <nav class="post-pagination">
          {previous ? (
            <a href={previous.permalink}>
              <span>Older</span>
              {previous.title}
            </a>
          ) : <div></div>}

          {next ? (
            <a href={next.permalink} style="text-align: right;">
              <span>Newer</span>
              {next.title}
            </a>
          ) : <div></div>}
        </nav>
      </article>
    </>
  ) : hasWalkingDeck ? (
    <>
      <article class="shell-container">
        <header class="post-hero">
          <span class="eyebrow">{post.category}</span>
          <h1 class="post-heading">{post.title}</h1>
          <div class="post-meta-row">
            <span>{post.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span>{post.readingTime} min read</span>
          </div>
          {post.tags.length > 0 && (
            <div class="post-tags" style="margin-top: 1rem;">
              {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
            </div>
          )}
        </header>
      </article>

      <div class="walking-deck-breakout">
        <WalkingDeck />
      </div>

      <article class="shell-container">
        <section class="prose panel">
          <Fragment set:html={walkingDeckParts.join('')} />
        </section>

        <nav class="post-pagination">
          {previous ? (
            <a href={previous.permalink}>
              <span>Older</span>
              {previous.title}
            </a>
          ) : <div></div>}

          {next ? (
            <a href={next.permalink} style="text-align: right;">
              <span>Newer</span>
              {next.title}
            </a>
          ) : <div></div>}
        </nav>
      </article>
    </>
  ) : (
    <article class="shell-container">
      <header class="post-hero">
        <span class="eyebrow">{post.category}</span>
        <h1 class="post-heading">{post.title}</h1>
        <div class="post-meta-row">
          <span>{post.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          <span>{post.readingTime} min read</span>
        </div>
        {post.tags.length > 0 && (
          <div class="post-tags" style="margin-top: 1rem;">
            {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
          </div>
        )}
      </header>

      <section class="prose panel">
        {hasRuntimeChart ? (
          <>
            <Fragment set:html={runtimeParts[0]} />
            <RuntimeControlChart />
            <Fragment set:html={runtimeParts.slice(1).join(runtimeChartMarker)} />
          </>
        ) : hasCharlotteArtsMap ? (
          <>
            <Fragment set:html={charlotteArtsMapParts[0]} />
            <CharlotteArtsMap />
            <Fragment set:html={charlotteArtsMapParts.slice(1).join(charlotteArtsMapMarker)} />
          </>
        ) : hasThreeNewYears ? (
          <>
            <Fragment set:html={threeNewYearsParts[0]} />
            <ThreeNewYears />
            <Fragment set:html={threeNewYearsParts.slice(1).join(threeNewYearsMarker)} />
          </>
        ) : hasWalkingDeck ? (
          <>
            <Fragment set:html={walkingDeckParts[0]} />
            <WalkingDeck />
            <Fragment set:html={walkingDeckParts.slice(1).join(walkingDeckMarker)} />
          </>
        ) : (
          <Fragment set:html={processedHtml} />
        )}
      </section>

      <nav class="post-pagination">
        {previous ? (
          <a href={previous.permalink}>
            <span>Older</span>
            {previous.title}
          </a>
        ) : <div></div>}

        {next ? (
          <a href={next.permalink} style="text-align: right;">
            <span>Newer</span>
            {next.title}
          </a>
        ) : <div></div>}
      </nav>
    </article>
  )}
</Layout>