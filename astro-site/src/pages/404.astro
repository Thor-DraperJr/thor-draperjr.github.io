---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="Not Found">
  <section class="shell-container">
    <article class="panel empty-state">
      <span class="eyebrow">404</span>
      <h1 class="page-title">Page not found</h1>
      <p class="section-copy">The page you requested is not part of the current site map.</p>
      <div class="button-row" style="justify-content: center; margin-top: 1rem;">
        <a class="button" href="/">Return home</a>
        <a class="button-ghost" href="/archive/">Browse posts</a>
      </div>
    </article>
  </section>
</Layout>