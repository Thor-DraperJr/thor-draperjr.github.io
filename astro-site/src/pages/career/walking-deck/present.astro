---
import '../../../styles/global.css';
import WalkingDeck from '../../../components/WalkingDeck.astro';
import { getSiteConfig } from '../../../lib/content';

const site = getSiteConfig();
const documentTitle = `Walking Deck | ${site.title}`;
const description = `Walking deck for ${site.title} - 8 sections, 3 minutes.`;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <script is:inline>document.documentElement.classList.add('js', 'walking-presenting');</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1d2e" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600&family=Lora:wght@600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet" />
    <title>{documentTitle}</title>
  </head>
  <body class="walking-presenting walking-present-page">
    <main id="main-content">
      <WalkingDeck />
    </main>

    <script>
      // Dedicated present route: open directly into the slideshow with no article chrome.
      const enterDeck = () => {
        const deck = document.querySelector('[data-walking-signal]');
        if (!deck) return false;
        if (deck.dataset.present === 'true') return true;
        const toggle = deck.querySelector('[data-present-toggle]');
        if (toggle && typeof toggle.click === 'function') {
          toggle.click();
          return true;
        }
        return false;
      };

      // Try a series of trigger points so this works regardless of how the page is loaded
      // (cold load, bfcache, low-power Safari, link previewers).
      const tries = [0, 60, 200, 500, 1200];
      tries.forEach((ms) => window.setTimeout(enterDeck, ms));
      window.addEventListener('pageshow', () => window.setTimeout(enterDeck, 60));
    </script>

    <style is:global>
      /* Chrome-free fullscreen present page */
      html.walking-presenting,
      body.walking-present-page {
        margin: 0;
        padding: 0;
        background: #0c1d2e;
        color: white;
        min-height: 100vh;
        min-height: 100dvh;
      }

      body.walking-present-page #main-content {
        margin: 0;
        padding: 0;
      }
    </style>
  </body>
</html>
