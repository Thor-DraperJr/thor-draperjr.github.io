---
import agent365Svg from './logos/microsoft/agent-365.svg?raw';
import conditionalAccessSvg from './logos/microsoft/conditional-access.svg?raw';
import copilotStudioSvg from './logos/microsoft/copilot-studio.svg?raw';
import defenderSvg from './logos/microsoft/defender.svg?raw';
import entraGovernanceSvg from './logos/microsoft/entra-governance.svg?raw';
import entraSvg from './logos/microsoft/entra.svg?raw';
import foundrySvg from './logos/microsoft/foundry.svg?raw';
import purviewSvg from './logos/microsoft/purview.svg?raw';
import openaiSvg from './logos/openai.svg?raw';
import anthropicSvg from './logos/anthropic.svg?raw';
import awsSvg from './logos/amazonwebservices.svg?raw';
import gcpSvg from './logos/googlecloud.svg?raw';
import oktaSvg from './logos/okta.svg?raw';
import auth0Svg from './logos/auth0.svg?raw';
import salesforceSvg from './logos/salesforce.svg?raw';
import datadogSvg from './logos/datadog.svg?raw';
import langchainSvg from './logos/langchain.svg?raw';
import splunkSvg from './logos/splunk.svg?raw';
import servicenowSvg from './logos/servicenow.svg?raw';

interface Props { n: string; }
const { n } = Astro.props;

const msLogos = {
  agent365: agent365Svg,
  conditionalAccess: conditionalAccessSvg,
  copilotStudio: copilotStudioSvg,
  defender: defenderSvg,
  entraGovernance: entraGovernanceSvg,
  entra: entraSvg,
  foundry: foundrySvg,
  purview: purviewSvg,
};

const vendorLogos = {
  openai: openaiSvg,
  anthropic: anthropicSvg,
  aws: awsSvg,
  gcp: gcpSvg,
  okta: oktaSvg,
  auth0: auth0Svg,
  salesforce: salesforceSvg,
  datadog: datadogSvg,
  langchain: langchainSvg,
  splunk: splunkSvg,
  servicenow: servicenowSvg,
};

const lifecycle = [
  { num: '01', label: 'Build', ms: ['Microsoft Foundry', 'Copilot Studio'], logos: ['foundry', 'copilotStudio'], accent: '#5c6b7d' },
  { num: '02', label: 'Identify', ms: ['Entra Agent ID'], logos: ['entra'], accent: '#1f5fb8' },
  { num: '03', label: 'Entitle', ms: ['Entra ID Governance', 'Conditional Access'], logos: ['entraGovernance', 'conditionalAccess'], accent: '#1f7a47' },
  { num: '04', label: 'Run', ms: ['Agent 365'], logos: ['agent365'], accent: '#6a3ba0' },
  { num: '05', label: 'Observe', ms: ['Agent 365 Observability'], logos: ['agent365'], accent: '#a87a1a' },
  { num: '06', label: 'Govern', ms: ['Defender', 'Purview'], logos: ['defender', 'purview'], accent: '#a13b3b' },
];

const lifecycleDetails = [
  {
    num: '01', label: 'Build', products: ['Microsoft Foundry', 'Copilot Studio'], logos: ['foundry', 'copilotStudio'],
    accent: '#5c6b7d',
    body: 'Someone in the business decides they want an agent. They pick a model, drop it into a workflow, and ship it. Usually before security or IT hears about it.',
    good: 'The agent shows up in a registry on day one, not after the incident.',
  },
  {
    num: '02', label: 'Identify', products: ['Entra Agent ID'], logos: ['entra'],
    accent: '#1f5fb8',
    body: 'The agent needs a name and a credential. It has to prove it is the agent your IT bought, not a script someone wrote on a Saturday.',
    good: 'Every agent has its own identity. The same directory humans live in.',
  },
  {
    num: '03', label: 'Entitle', products: ['Entra ID Governance', 'Conditional Access'], logos: ['entraGovernance', 'conditionalAccess'],
    accent: '#1f7a47',
    body: 'It gets the keys to do its job. Read this mailbox. Write to that ticket queue. Stay out of these folders.',
    good: 'Least privilege, scoped to the task. Reviewed on a cadence like any other account.',
  },
  {
    num: '04', label: 'Run', products: ['Agent 365'], logos: ['agent365'],
    accent: '#6a3ba0',
    body: 'It does the work. Calls APIs. Hands off to other agents. Maybe runs for days. Maybe spawns helpers you did not plan for.',
    good: 'Every action is traceable back to one agent, one prompt, one decision.',
  },
  {
    num: '05', label: 'Observe', products: ['Agent 365 Observability'], logos: ['agent365'],
    accent: '#a87a1a',
    body: 'Someone has to know what it did, what it tried to do, what it cost, and when it started behaving differently.',
    good: 'One signal graph. Drift, cost, and risk on the same screen.',
  },
  {
    num: '06', label: 'Govern', products: ['Defender', 'Purview'], logos: ['defender', 'purview'],
    accent: '#a13b3b',
    body: 'When the project ends, the team rotates, or the model gets retired, the agent has to be turned off and evidenced.',
    good: 'Leaver process for agents looks like the leaver process for humans. Auditable.',
  },
];

const localStops = [
  { label: 'Build', accent: '#5c6b7d', tools: [{ name: 'OpenAI', logo: 'openai' }, { name: 'Anthropic', logo: 'anthropic' }, { name: 'Vertex AI', logo: 'gcp' }, { name: 'Bedrock', logo: 'aws' }, { name: 'LangChain', logo: 'langchain' }] },
  { label: 'Identify', accent: '#1f5fb8', tools: [{ name: 'Okta', logo: 'okta' }, { name: 'Auth0', logo: 'auth0' }, { name: 'Ping' }, { name: 'CyberArk' }] },
  { label: 'Entitle', accent: '#1f7a47', tools: [{ name: 'SailPoint' }, { name: 'Saviynt' }, { name: 'ServiceNow', logo: 'servicenow' }] },
  { label: 'Run', accent: '#6a3ba0', tools: [{ name: 'ServiceNow AICT', logo: 'servicenow' }, { name: 'Agentforce', logo: 'salesforce' }, { name: 'Custom orchestrators' }] },
  { label: 'Observe', accent: '#a87a1a', tools: [{ name: 'Datadog', logo: 'datadog' }, { name: 'Splunk', logo: 'splunk' }, { name: 'Arize' }, { name: 'LangSmith' }] },
  { label: 'Govern', accent: '#a13b3b', tools: [{ name: 'OneTrust' }, { name: 'BigID' }, { name: 'Credo AI' }, { name: 'Zenity' }] },
];

const gartnerCards = [
  { title: 'Access Management', image: '/assets/images/posts/all-aboard/gartner/mq-01.png' },
  { title: 'Endpoint Protection Platforms', image: '/assets/images/posts/all-aboard/gartner/mq-02.png' },
  { title: 'Security Information and Event Management', image: '/assets/images/posts/all-aboard/gartner/mq-03.png' },
  { title: 'Email Security', image: '/assets/images/posts/all-aboard/gartner/mq-04.png' },
  { title: 'Endpoint Management Tools', image: '/assets/images/posts/all-aboard/gartner/mq-05.png' },
];

const productIcons = {
  m365Copilot: '/assets/images/posts/all-aboard/native-assets/m365-copilot.png',
  dragonCopilot: '/assets/images/posts/all-aboard/native-assets/dragon-copilot.png',
  copilotStudio: '/assets/images/posts/all-aboard/native-assets/copilot-studio.png',
  githubCopilot: '/assets/images/posts/all-aboard/native-assets/github-copilot.png',
  fabric: '/assets/images/posts/all-aboard/native-assets/microsoft-fabric.png',
  foundry: '/assets/images/posts/all-aboard/native-assets/microsoft-foundry.png',
  azure: '/assets/images/posts/all-aboard/native-assets/microsoft-azure.png',
  agent365: '/assets/images/posts/all-aboard/native-assets/agent-365.png',
  securityCopilot: '/assets/images/posts/all-aboard/native-assets/security-copilot.png',
};

const iqTiles = [
  { name: 'Microsoft 365\nCopilot', icon: productIcons.m365Copilot, area: 'm365' },
  { name: 'Copilot Studio', icon: productIcons.copilotStudio, area: 'studio' },
  { name: 'GitHub Copilot', icon: productIcons.githubCopilot, area: 'github' },
  { name: 'Dragon Copilot', icon: productIcons.dragonCopilot, area: 'dragon' },
  { name: 'Microsoft Fabric', icon: productIcons.fabric, area: 'fabric' },
  { name: 'Microsoft Foundry', icon: productIcons.foundry, area: 'foundry' },
  { name: 'Agent 365', icon: productIcons.agent365, area: 'agent' },
  { name: 'Microsoft Azure', icon: productIcons.azure, area: 'azure' },
];

const agentPanels = [
  { persona: 'IT Admin', quote: 'Control, govern & monitor agents across the org', product: 'Microsoft 365 Admin Center', image: '/assets/images/posts/all-aboard/native-assets/agent365-it-admin.png' },
  { persona: 'Business Leaders', quote: 'Deliver measurable outcomes and ROI', product: 'Agent Dashboard', image: '/assets/images/posts/all-aboard/native-assets/agent365-business.png' },
  { persona: 'SecOps Analyst', quote: 'Detect threats & secure agent activity in real time', product: 'Microsoft Defender', image: '/assets/images/posts/all-aboard/native-assets/agent365-secops.png' },
  { persona: 'Data Security Admin', quote: 'Protect data & enforce compliance policies', product: 'Microsoft Purview', image: '/assets/images/posts/all-aboard/native-assets/agent365-purview.png' },
  { persona: 'Identity & Access Admin', quote: 'Manage identities & access for agents and users', product: 'Microsoft Entra', image: '/assets/images/posts/all-aboard/native-assets/agent365-entra.png' },
];

const foundations = [
  { label: 'Identities', icon: 'lock' },
  { label: 'Endpoints', icon: 'laptop' },
  { label: 'Cloud', icon: 'cloud' },
  { label: 'Data', icon: 'data' },
  { label: 'Apps', icon: 'gear' },
];

const foundationProducts = [
  { label: 'Microsoft Entra', image: '/assets/images/posts/all-aboard/native-assets/ms-entra.png' },
  { label: 'Microsoft Intune', image: '/assets/images/posts/all-aboard/native-assets/ms-intune.png' },
  { label: 'Microsoft Defender', image: '/assets/images/posts/all-aboard/native-assets/ms-defender.png' },
  { label: 'Microsoft Purview', image: '/assets/images/posts/all-aboard/native-assets/ms-purview.png' },
  { label: 'Microsoft Sentinel', image: '/assets/images/posts/all-aboard/native-assets/ms-sentinel.png' },
];

const securityNodes = [
  { type: 'lock', x: 9, y: 26 }, { type: 'lock', x: 15, y: 44 }, { type: 'lock', x: 23, y: 26 }, { type: 'lock', x: 31, y: 46 },
  { type: 'cloud', x: 39, y: 59 }, { type: 'data', x: 52, y: 14 }, { type: 'cloud', x: 52, y: 55 }, { type: 'data', x: 61, y: 27 },
  { type: 'data', x: 68, y: 14 }, { type: 'gear', x: 73, y: 34 }, { type: 'gear', x: 78, y: 62 }, { type: 'gear', x: 82, y: 49 },
  { type: 'laptop', x: 93, y: 28 }, { type: 'laptop', x: 93, y: 55 }, { type: 'laptop', x: 99, y: 42 },
];

const securityEdges = [
  [0, 5], [0, 4], [1, 3], [2, 5], [2, 9], [3, 4], [4, 5], [5, 6], [6, 10], [7, 9], [8, 12], [9, 12], [10, 11], [11, 12], [12, 14], [13, 14],
];

function slideLabel(id: string) {
  return `PowerPoint slide ${id}`;
}
---

<section class={`aas aas-${n}`} data-deck-slide={n} aria-label={slideLabel(n)}>
  {n === '03' && (
    <>
      <header class="aas-title center">
        <h3>Microsoft 365 E7</h3>
        <p>The Frontier Suite</p>
      </header>
      <div class="ga-pill">Generally Available</div>
      <div class="suite-frame">
        <div class="suite-card">
          <span class="brand-text microsoft-mark">Microsoft 365</span>
          <strong>Microsoft 365 E5<br /><small>+<br />Entra Suite</small></strong>
          <hr />
          <span>Secure productive work</span>
        </div>
        <span class="suite-plus">+</span>
        <div class="suite-card">
          <img class="product-image" src={productIcons.m365Copilot} alt="Microsoft 365 Copilot" loading="eager" />
          <strong>Microsoft 365<br />Copilot</strong>
          <hr />
          <span>AI built for work</span>
        </div>
        <span class="suite-plus">+</span>
        <div class="suite-card">
          <span class="product-logo" set:html={msLogos.agent365}></span>
          <strong>Microsoft<br />Agent 365</strong>
          <hr />
          <span>Control plane for agents</span>
        </div>
        <div class="workiq-bar">Work IQ</div>
      </div>
      <p class="slide-foot">Available with or without Teams</p>
    </>
  )}

  {n === '04' && (
    <>
      <header class="aas-title left">
        <h3>AI adoption is accelerating and<br />agents are at the forefront</h3>
      </header>
      <div class="stats-row">
        <article class="stat-card hero-stat"><strong>1.3B</strong><span>AI agents</span><em>by 2028</em><b>IDC</b></article>
        <article class="stat-card"><strong>82%</strong><span>of organizations intend to integrate them within 1-3 years</span><b>Capgemini</b></article>
        <article class="stat-card"><strong>40%</strong><span>of enterprise apps will be integrated with task-specific AI agents by 2026</span><b>Gartner</b></article>
      </div>
    </>
  )}

  {n === '05' && (
    <>
      <header class="aas-title center iq-heading"><h3>Microsoft IQ Platform</h3></header>
      <div class="iq-trust-line"><span></span><strong>Intelligence + Trust</strong><span></span></div>
      <div class="iq-frame">
        {iqTiles.map((tile) => (
          <article class={`iq-tile iq-${tile.area}`}>
            <img src={tile.icon} alt="" loading="eager" />
            <strong set:html={tile.name.replace('\n', '<br />')}></strong>
          </article>
        ))}
        <div class="iq-orb"><strong>Microsoft IQ</strong><span>Work IQ<br />Fabric IQ<br />Foundry IQ</span></div>
      </div>
      <div class="iq-foundation-products">
        {foundationProducts.map((item) => <span><img src={item.image} alt="" loading="eager" />{item.label}</span>)}
      </div>
    </>
  )}

  {n === '06' && (
    <>
      <header class="aas-title left"><h3>Same lifecycle, two populations</h3></header>
      <div class="lane-label">Humans, since 1992</div>
      <div class="life-lane muted">{['Sponsor', 'Provision', 'Review', 'Reassign', 'Retire', 'Audit'].map((label) => <span>{label}</span>)}</div>
      <div class="life-lane agent">{['Sponsor', 'Provision', 'Review', 'Reassign', 'Retire', 'Audit'].map((label) => <span>{label}</span>)}</div>
      <div class="lane-label bottom">Agents, starting now</div>
    </>
  )}

  {n === '07' && (
    <div class="trust-slide">
      <h3>To unlock the potential of agentic AI, we need to start with trust.</h3>
      <p>And trust starts with <span>security</span></p>
    </div>
  )}

  {n === '08' && (
    <>
      <header class="aas-title center"><h3>Recognized as a leader across the threat surface</h3></header>
      <div class="mq-grid">
        {gartnerCards.map((mq) => (
          <article><img src={mq.image} alt={`Gartner Magic Quadrant for ${mq.title}`} loading="eager" /><span>Gartner® Magic Quadrant™ for</span><strong>{mq.title}</strong></article>
        ))}
      </div>
      <p class="gartner-note">Gartner and Magic Quadrant are trademarks of Gartner, Inc. and/or its affiliates. Gartner does not endorse any company, vendor, product or service depicted in its publications.</p>
    </>
  )}

  {n === '09' && (
    <>
      <header class="aas-title center"><h3>Microsoft Agent 365</h3><p>The control plane for agents</p></header>
      <div class="agent-dashboard-strip">
        {agentPanels.map((panel) => (
          <article>
            <img src={panel.image} alt="" loading="eager" />
            <div><strong>{panel.persona}</strong><small>“{panel.quote}“</small></div>
            <b>{panel.product}</b>
          </article>
        ))}
      </div>
      <div class="shared-foundation">
        {['Registry & Identity', 'Access Control & Policies', 'Observability', 'Tools Gateway', 'Run-time Protection', 'Security'].map((item) => <span>{item}</span>)}
      </div>
    </>
  )}

  {n === '10' && (
    <>
      <header class="aas-title center"><h3>All Aboard</h3><p>Six Pillars - One Control Plane</p></header>
      <div class="ticket-layout">
        <div class="ticket-copy">
          <p>Every agent you bring into the enterprise makes the same six-step trip - Build, Identify, Entitle, Run, Observe, Govern.</p>
          <ul>
            <li><strong>Trust before control.</strong> There is nothing to secure if the customer does not trust you in the room.</li>
            <li><strong>Control plane, not IDP.</strong> The control plane can bridge.</li>
            <li><strong>Agents are users.</strong> Measure twice, cut once.</li>
          </ul>
        </div>
        <div class="ticket-stops">
          <strong>One Ticket - Six Stops</strong>
          {['Build', 'Identify', 'Entitle', 'Run', 'Observe', 'Govern'].map((stop, index) => <span><b>{String(index + 1).padStart(2, '0')}</b>{stop}</span>)}
        </div>
      </div>
    </>
  )}

  {n === '11' && (
    <>
      <header class="aas-title left"><h3>Six steps. Every agent. From the whiteboard to the day it gets turned off.</h3></header>
      <div class="step-grid detailed">
        {lifecycleDetails.map((step) => (
          <article class="step-card" style={`--accent:${step.accent}`}>
            <header><span>{step.num}</span><strong>{step.label}</strong></header>
            <div class="mini-products">{step.products.map((name, i) => <span><i set:html={msLogos[step.logos[i]]}></i>{name}</span>)}</div>
            <p>{step.body}</p>
            <b>What good looks like</b>
            <small>{step.good}</small>
          </article>
        ))}
      </div>
      <div class="step-explainer"><strong>Same six steps every time.</strong><span>The differences between vendors and platforms only become visible once you draw the trip end to end.</span><strong>Why this matters.</strong><span>Most agent conversations skip straight to a tool in one of these steps. Executives need to see the whole trip before they can pick where to spend.</span></div>
    </>
  )}

  {n === '12' && (
    <>
      <header class="aas-title left"><h3>The Agentic Enterprise Today</h3></header>
      <div class="step-grid local-grid">
        {localStops.map((stop, index) => (
          <article class="step-card local-card" style={`--accent:${stop.accent}`}>
            <header><span>{String(index + 1).padStart(2, '0')}</span><strong>{stop.label}</strong></header>
            <div class="mini-products">{stop.tools.map((tool) => <span>{tool.logo && <i set:html={vendorLogos[tool.logo]}></i>}{tool.name}</span>)}</div>
          </article>
        ))}
      </div>
      <div class="route-band local-route">
        <strong>LOCAL · stops 1 of 6</strong>
        <div class="local-car" aria-hidden="true"><i></i><i></i><i></i><i></i><b></b><b></b><b></b></div>
        <div class="rail-line" aria-hidden="true">{Array.from({ length: 24 }).map(() => <span></span>)}</div>
        <p>Six stops. Six budget owners. Six different operators on one trip.</p>
      </div>
    </>
  )}

  {n === '13' && (
    <>
      <header class="aas-title left"><h3>Six steps. Every agent. From the whiteboard to the day it gets turned off.</h3></header>
      <div class="step-grid express-grid">
        {lifecycle.map((step) => (
          <article class="step-card express-card" style="--accent:#0784d8">
            <header><span>{step.num}</span><strong>{step.label}</strong></header>
            <div class="mini-products">{step.ms.map((name, i) => <span><i set:html={msLogos[step.logos[i]]}></i>{name}</span>)}</div>
          </article>
        ))}
      </div>
      <div class="route-band express-route">
        <strong>ALL-ABOARD EXPRESS · one route · one operator</strong>
        <div class="speed-lines" aria-hidden="true"><span></span><span></span><span></span></div>
        <div class="bullet-train" aria-hidden="true">{Array.from({ length: 8 }).map(() => <i></i>)}<b></b></div>
        <div class="glow-rail" aria-hidden="true"></div>
        <p>Same six pillars. One platform underneath. One ticket end to end.</p>
      </div>
    </>
  )}

  {n === '14' && (
    <>
      <header class="aas-title center"><h3>Secure foundations</h3></header>
      <div class="security-frame">
        <div class="security-copilot"><img src={productIcons.securityCopilot} alt="" loading="eager" /><strong>Microsoft<br />Security Copilot</strong></div>
        <div class="network-map">
          <svg class="security-lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            {securityEdges.map(([from, to]) => {
              const start = securityNodes[from];
              const end = securityNodes[to];
              return <line x1={start.x} y1={start.y} x2={end.x} y2={end.y} />;
            })}
          </svg>
          {securityNodes.map((node) => <span class={`network-node node-${node.type}`} style={`--x:${node.x};--y:${node.y}`}></span>)}
        </div>
        <div class="foundation-nodes">{foundations.map((item) => <div><span class={`domain-icon icon-${item.icon}`}></span><strong>{item.label}</strong></div>)}</div>
        <div class="foundation-product-row">{foundationProducts.map((item) => <span><img src={item.image} alt="" loading="eager" />{item.label}</span>)}</div>
      </div>
      <div class="shared-foundation bottom-foundation">{['Registry & Identity', 'Access Control & Policies', 'Observability', 'Tools Gateway', 'Run-time Protection', 'Security'].map((item) => <span>{item}</span>)}</div>
    </>
  )}
</section>

<style>
  .aas {
    aspect-ratio: 16 / 9;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    padding: clamp(1.5em, 1em + 2.1cqw, 3.6em);
    background:
      radial-gradient(130% 95% at 12% -10%, rgba(89,159,253,0.32), transparent 54%),
      radial-gradient(120% 95% at 92% 115%, rgba(250,220,20,0.16), transparent 58%),
      linear-gradient(150deg, #0e2a52 0%, #0b2344 55%, #081a36 100%);
    color: #fff;
    font-family: inherit;
    font-size: clamp(6px, 1.2cqw, 15px);
    container-type: inline-size;
  }

  .aas-title h3 { margin: 0; font-size: clamp(1.8em, 1.1em + 3cqw, 3em); line-height: 1.12; font-weight: 800; }
  .aas-title p { margin: 0.25em 0 0; color: #b9d9f7; font-size: clamp(1em, 0.7em + 1.35cqw, 1.75em); font-weight: 700; }
  .center { text-align: center; }
  .left { text-align: left; }

  .ga-pill { position: absolute; top: 26.2%; left: 50%; transform: translateX(-50%); z-index: 3; padding: 0.45em 4.8em; border-radius: 11px; background: #d9edf8; color: #000; font-size: clamp(0.9em, 0.7em + 0.8cqw, 1.25em); font-weight: 800; }
  .suite-frame { position: absolute; left: 4.7%; right: 4.7%; top: 29%; bottom: 13%; display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 1.1em; align-items: start; padding: 2.6em 1.8em 4.8em; border: 2px solid #0088e8; border-radius: 38px; }
  .suite-card { height: calc(100% - 3.6em); min-height: 0; border-radius: 27px; background: #f7f7f7; color: #000; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; gap: 0.62em; padding: 0.9em 1em; box-sizing: border-box; }
  .suite-card strong { font-size: clamp(1.2em, 0.9em + 1.25cqw, 1.8em); line-height: 1.2; }
  .suite-card small { font-size: 0.78em; line-height: 0.95; }
  .suite-card hr { width: 45%; border: 0; border-top: 1px solid #ddd; }
  .microsoft-mark { color: #777; font-size: clamp(0.9em, 0.7em + 0.75cqw, 1.25em); font-weight: 800; }
  .suite-plus { color: #fff; font-size: 2.2em; font-weight: 900; }
  .workiq-bar { position: absolute; left: 2.4%; right: 2.4%; bottom: 1.45em; padding: 0.3em; border-radius: 999px; background: #f7f7f7; color: #000; text-align: center; font-size: clamp(1.15em, 0.85em + 1.2cqw, 1.75em); font-weight: 800; box-shadow: 0 0 0 1px rgba(0,0,0,0.04); }
