---
// In-article figure for the All Aboard written deep-dive.
// The four starting positions a provider lands in, set by what they already
// bought for identity and governance. Same destination; the first ninety days
// differ. Rendered as a 2x2 card grid in the deck palette.
interface Position {
  n: string;
  title: string;
  start: string;
  move: string;
  watch: string;
}

const positions: Position[] = [
  {
    n: 'One',
    title: 'Unified identity + governance stack',
    start: 'Identity and governance already run on one platform.',
    move: 'Extend the human lifecycle to cover agents \u2014 same sponsor, same review, same engine.',
    watch: 'Trap: using agents as cover to re-platform what already works.',
  },
  {
    n: 'Two',
    title: 'One IDP, a separate governance tool',
    start: 'Identity in one place, governance in a tool the audit team trusts.',
    move: 'Co-existence: the control plane sits next to the governance tool. Both feed one view.',
    watch: 'Keep the governance tool. Add the plane that sees the population it never could.',
  },
  {
    n: 'Three',
    title: 'A different identity provider entirely',
    start: 'The directory is someone else\u2019s, and it is staying put.',
    move: 'Federate, and move on. Your IDP vendor need not be your control-plane vendor.',
    watch: 'No re-platform required. See every agent in front of the directory you have.',
  },
  {
    n: 'Four',
    title: 'Agents built on a third-party AI platform',
    start: 'Agents are already live on a platform you don\u2019t fully see.',
    move: 'Visibility before standardization. Auto-registration first.',
    watch: 'You can\u2019t have the standardization talk until you can answer the inventory question.',
  },
];
---

<figure
  class="fp-fig"
  role="img"
  aria-label="The four starting positions for governing agents, set by what an organization already bought for identity and governance. Position one: a unified identity and governance stack; extend the human lifecycle to agents. Position two: one identity provider with a separate governance tool; run co-existence with the control plane beside the governance tool. Position three: a different identity provider entirely; federate and move on. Position four: agents built on a third-party AI platform; visibility before standardization, auto-registration first. The destination is the same in every case; the first ninety days differ."
>
  <div class="fp-head">
    <span class="fp-eyebrow">Where you start</span>
    <h3 class="fp-title">Four starting positions</h3>
  </div>

  <div class="fp-grid">
    {positions.map((p) => (
      <div class="fp-card">
        <span class="fp-card-n">Position {p.n}</span>
        <span class="fp-card-title">{p.title}</span>
        <span class="fp-card-start">{p.start}</span>
        <span class="fp-card-move">{p.move}</span>
        <span class="fp-card-watch">{p.watch}</span>
      </div>
    ))}
  </div>

  <figcaption class="fp-caption">Same destination in every case. The first ninety days are what differ.</figcaption>
</figure>

<style>
  .fp-fig {
    container-type: inline-size;
    margin: 0;
    box-sizing: border-box;
    width: 100%;
    padding: clamp(1.2rem, 0.7rem + 2.4cqw, 2.4rem);
    border-radius: 18px;
    background:
      radial-gradient(130% 95% at 12% -10%, rgba(89, 159, 253, 0.3), transparent 58%),
      radial-gradient(120% 95% at 92% 115%, rgba(250, 220, 20, 0.16), transparent 55%),
      linear-gradient(150deg, #0e2a52 0%, #0b2344 55%, #081a36 100%);
    color: #eaf1fb;
    box-shadow: 0 24px 60px rgba(8, 20, 40, 0.32);
  }

  .fp-head { margin-bottom: clamp(1rem, 0.6rem + 1.6cqw, 1.8rem); }

  .fp-eyebrow {
    display: block;
    font-size: clamp(0.62rem, 0.55rem + 0.3cqw, 0.74rem);
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #599ffd;
  }

  .fp-title {
    margin: 0.3rem 0 0;
    font-size: clamp(1.1rem, 0.85rem + 1.4cqw, 1.7rem);
    font-weight: 800;
    line-height: 1.12;
    color: #fff;
  }

  .fp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.6rem, 0.4rem + 0.9cqw, 1rem);
  }

  @container (min-width: 540px) {
    .fp-grid { grid-template-columns: 1fr 1fr; }
  }

  .fp-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: clamp(0.3rem, 0.2rem + 0.4cqw, 0.5rem);
    padding: clamp(0.9rem, 0.6rem + 1.1cqw, 1.4rem);
    border-radius: 13px;
    background: rgba(89, 159, 253, 0.1);
    border: 1px solid rgba(89, 159, 253, 0.42);
  }

  .fp-card-n {
    font-size: clamp(0.6rem, 0.54rem + 0.28cqw, 0.72rem);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fadc14;
  }

  .fp-card-title {
    font-size: clamp(0.92rem, 0.78rem + 0.7cqw, 1.18rem);
    font-weight: 800;
    line-height: 1.15;
    color: #fff;
  }

  .fp-card-start {
    font-size: clamp(0.72rem, 0.64rem + 0.34cqw, 0.9rem);
    font-weight: 600;
    line-height: 1.3;
    color: #a5b8ee;
  }

  .fp-card-move {
    margin-top: 0.1rem;
    padding-top: clamp(0.35rem, 0.25rem + 0.4cqw, 0.55rem);
    border-top: 1px solid rgba(165, 184, 238, 0.28);
    font-size: clamp(0.76rem, 0.66rem + 0.42cqw, 0.96rem);
    font-weight: 700;
    line-height: 1.28;
    color: #eaf1fb;
  }

  .fp-card-watch {
    font-size: clamp(0.68rem, 0.6rem + 0.3cqw, 0.82rem);
    font-weight: 600;
    font-style: italic;
    line-height: 1.3;
    color: #8ea6d8;
  }

  .fp-caption {
    margin: clamp(0.9rem, 0.6rem + 1.2cqw, 1.5rem) 0 0;
    font-size: clamp(0.78rem, 0.7rem + 0.3cqw, 0.95rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #e2f9d9;
  }
</style>
