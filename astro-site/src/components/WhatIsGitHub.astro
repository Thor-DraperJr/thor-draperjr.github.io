---
// In-article opener for "GitHub Without the Tour".
// The "what GitHub actually is" slide: a team changing shared work on purpose,
// with a record. A small main-line-with-a-branch motif up top, then the three
// questions every team has mapped to the GitHub object that answers each.
// Deck navy blue-yellow palette.
const answers = [
  {
    q: "What's the current version?",
    a: 'A repository',
    detail: 'The one shared copy everyone agrees on. The main version.',
  },
  {
    q: "What's being proposed?",
    a: 'A branch and a pull request',
    detail: 'Your change, off to the side, put up for the team to review.',
  },
  {
    q: 'Who agreed to it?',
    a: 'A merge, kept in history',
    detail: 'Who changed what, when, and why, recorded for good.',
  },
];
---

<figure
  class="wig-fig"
  role="img"
  aria-label="What GitHub actually is: a team changing shared work on purpose, with a record. A diagram shows a main line with one change branching off and merging back. Three questions every team has, each mapped to the GitHub object that answers it. What is the current version? A repository, the one shared copy everyone agrees on. What is being proposed? A branch and a pull request, your change put up for review. Who agreed to it? A merge kept in history, who changed what, when, and why."
>
  <div class="wig-head">
    <span class="wig-eyebrow">Before any buttons</span>
    <h3 class="wig-title">What GitHub actually is</h3>
    <p class="wig-sub">A team changing shared work on purpose, and keeping a record of every change.</p>
  </div>

  <svg class="wig-diagram" viewBox="0 0 320 92" role="presentation" aria-hidden="true">
    <line x1="18" y1="66" x2="302" y2="66" class="wig-main" />
    <path d="M92 66 C112 66 112 32 142 32 L178 32 C208 32 208 66 228 66" class="wig-branch" />
    <circle cx="92" cy="66" r="4.5" class="wig-node" />
    <circle cx="228" cy="66" r="4.5" class="wig-node" />
    <circle cx="160" cy="32" r="5" class="wig-commit" />
    <text x="20" y="83" class="wig-label wig-label--main">main</text>
    <text x="160" y="20" class="wig-label wig-label--branch" text-anchor="middle">your change</text>
    <text x="248" y="83" class="wig-label wig-label--merge">merged in</text>
  </svg>

  <div class="wig-cards">
    {answers.map((item, i) => (
      <div class="wig-card" style={`--i:${i}`}>
        <span class="wig-q">{item.q}</span>
        <span class="wig-a">{item.a}</span>
        <span class="wig-detail">{item.detail}</span>
      </div>
    ))}
  </div>

  <figcaption class="wig-caption">Three questions every team has. GitHub is just the place they get answered.</figcaption>
</figure>

<style>
  .wig-fig {
    container-type: inline-size;
    margin: 0;
    box-sizing: border-box;
    width: 100%;
    padding: clamp(1.2rem, 0.7rem + 2.4cqw, 2.4rem);
    border-radius: 18px;
    background:
      radial-gradient(130% 95% at 12% -10%, rgba(89, 159, 253, 0.3), transparent 58%),
      radial-gradient(120% 95% at 92% 115%, rgba(250, 220, 20, 0.16), transparent 55%),
      linear-gradient(150deg, #0e2a52 0%, #0b2344 55%, #081a36 100%);
    color: #eaf1fb;
    box-shadow: 0 24px 60px rgba(8, 20, 40, 0.32);
  }

  .wig-head { margin-bottom: clamp(0.9rem, 0.6rem + 1.4cqw, 1.6rem); }
  .wig-eyebrow {
    display: block;
    font-size: clamp(0.62rem, 0.55rem + 0.3cqw, 0.74rem);
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #599ffd;
  }
  .wig-title {
    margin: 0.3rem 0 0;
    font-size: clamp(1.1rem, 0.85rem + 1.4cqw, 1.7rem);
    font-weight: 800;
    line-height: 1.12;
    color: #fff;
  }
  .wig-sub {
    margin: 0.5rem 0 0;
    font-size: clamp(0.78rem, 0.7rem + 0.3cqw, 0.95rem);
    color: #a5b8ee;
    max-width: 48ch;
  }

  .wig-diagram {
    display: block;
    width: 100%;
    max-width: 460px;
    height: auto;
    margin: clamp(0.6rem, 0.3rem + 1cqw, 1.2rem) auto;
  }
  .wig-main {
    stroke: #599ffd;
    stroke-width: 3;
    stroke-linecap: round;
  }
  .wig-branch {
    fill: none;
    stroke: #fadc14;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: wig-draw 2.4s ease forwards 0.2s;
  }
  .wig-node { fill: #599ffd; }
  .wig-commit {
    fill: #fadc14;
    transform-origin: 160px 32px;
    animation: wig-pulse 2.8s ease-in-out infinite 2.4s;
  }
  .wig-label {
    font-family: ui-monospace, "SF Mono", "Cascadia Code", monospace;
    font-size: 9px;
    font-weight: 600;
  }
  .wig-label--main { fill: #9fc2ff; }
  .wig-label--branch { fill: #fbe98a; }
  .wig-label--merge { fill: #9fc2ff; }

  .wig-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.5rem, 0.3rem + 0.8cqw, 0.9rem);
  }
  .wig-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: clamp(0.7rem, 0.5rem + 0.7cqw, 1rem);
    border-radius: 13px;
    background: rgba(89, 159, 253, 0.1);
    border: 1px solid rgba(89, 159, 253, 0.32);
    animation: wig-fade 0.5s ease both;
    animation-delay: calc(var(--i) * 0.1s + 0.3s);
  }
  .wig-q {
    font-size: clamp(0.74rem, 0.66rem + 0.34cqw, 0.9rem);
    font-weight: 800;
    color: #fadc14;
    line-height: 1.15;
  }
  .wig-a {
    font-size: clamp(0.78rem, 0.7rem + 0.36cqw, 0.96rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
  }
  .wig-detail {
    font-size: clamp(0.7rem, 0.64rem + 0.26cqw, 0.84rem);
    line-height: 1.3;
    color: #cfe0ff;
  }

  .wig-caption {
    margin: clamp(0.9rem, 0.6rem + 1.2cqw, 1.5rem) 0 0;
    font-size: clamp(0.78rem, 0.7rem + 0.3cqw, 0.95rem);
    font-weight: 700;
    color: #e2f9d9;
  }

  @keyframes wig-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes wig-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.35); opacity: 0.75; }
  }
  @keyframes wig-fade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @container (max-width: 540px) {
    .wig-cards { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wig-branch { animation: none; stroke-dashoffset: 0; }
    .wig-commit { animation: none; }
    .wig-card { animation: none; }
  }
</style>
