---
// In-article infographic for "GitHub Without the Tour".
// Left: the agentic loop the learner stays inside — state intent, the agent
// plans, acts, and shows its work, the human reviews and approves. A glow
// cycles the five stages on a loop. Right: narrow example prompts, each with
// one predictable outcome, so a fast literal system does what was meant.
const stages = [
  { k: 'You', label: 'State the intent', detail: 'Plain language. What you want, not which command.' },
  { k: 'Agent', label: 'Plans the steps', detail: 'Branch, edit, commit, push, open a PR.' },
  { k: 'Agent', label: 'Does the work', detail: 'Runs the mechanics so you do not memorize them.' },
  { k: 'Agent', label: 'Shows its work', detail: 'The diff and each move, labeled as it goes.' },
  { k: 'You', label: 'Review & approve', detail: 'You keep the judgment. Nothing ships unseen.' },
];

const prompts = [
  {
    say: 'In the practice repo, add my name, Thor Draper, to Contributors.md in alphabetical order on a new branch called add-thor-draper, commit it with a clear message, and open a pull request.',
    get: 'A branch, one edited line, a labeled commit, and an open PR.',
  },
  {
    say: 'Show me the diff of what you just changed before we push anything.',
    get: 'The exact before-and-after, so nothing ships unseen.',
  },
  {
    say: 'Explain in plain language what a branch is and why we made one before editing.',
    get: 'The concept, tied to the action you just watched.',
  },
];
---

<figure
  class="agl-fig"
  role="img"
  aria-label="The agentic loop. You state the intent in plain language. The agent plans the steps, does the work, and shows its work as a labeled diff. You review and approve. Alongside it, three narrow example prompts, each with one predictable outcome."
>
  <div class="agl-head">
    <span class="agl-eyebrow">Intent in, work out</span>
    <h3 class="agl-title">You keep the intent. The agent runs the mechanics.</h3>
  </div>

  <div class="agl-body">
    <ol class="agl-loop">
      {stages.map((s, i) => (
        <li class={`agl-stage agl-stage--${s.k === 'You' ? 'you' : 'agent'}`} style={`--i:${i}`}>
          <span class="agl-who">{s.k}</span>
          <span class="agl-stage-label">{s.label}</span>
          <span class="agl-stage-detail">{s.detail}</span>
        </li>
      ))}
    </ol>

    <div class="agl-prompts">
      <span class="agl-prompts-head">Narrow prompts, predictable outcomes</span>
      {prompts.map((p) => (
        <div class="agl-prompt">
          <p class="agl-say"><span class="agl-tag">Say</span>{p.say}</p>
          <p class="agl-get"><span class="agl-tag agl-tag--get">Get</span>{p.get}</p>
        </div>
      ))}
    </div>
  </div>

  <figcaption class="agl-caption">The skill is expressing intent precisely enough that a fast, literal system does what you meant.</figcaption>
</figure>

