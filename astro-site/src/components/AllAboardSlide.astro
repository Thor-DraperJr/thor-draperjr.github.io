---
// A single All Aboard slide figure, placed inline between prose in the article.
// The spoken narration lives in the markdown; this renders only the visual.
import AllAboardRichSlide from './AllAboardRichSlide.astro';

const slideNumbers = new Set(['03', '04', '05', '06', '07', '08', '09', '10', '11', '12', '13', '14']);

interface Props {
  n: string;
}

const { n } = Astro.props;
const hasSlide = slideNumbers.has(n);
---

{hasSlide && (
  <figure class="aa-slide">
    <AllAboardRichSlide n={n} />
  </figure>
)}

<style>
  .aa-slide {
    width: min(100%, 1280px);
    margin: 0 auto;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 18px 50px -24px rgba(8, 22, 48, 0.55), 0 0 0 1px rgba(15, 36, 72, 0.12);
    background: #0a1b34;
  }

</style>
