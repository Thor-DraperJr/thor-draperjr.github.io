---
// In-article visual for "GitHub Without the Tour".
// The two tools the session leans on, each in a sentence, for people who have
// never opened either. VS Code (where you work) and GitHub Copilot (who does
// the typing), plus a one-line note on how they fit. Deck blue-yellow palette.
const tools = [
  {
    role: 'Where you work',
    name: 'Visual Studio Code',
    detail: 'A free code editor that runs on any machine, and one of the most common ones in the field. Today it is just where you read files, see changes, and talk to the agent.',
  },
  {
    role: 'Who does the work',
    name: 'GitHub Copilot',
    detail: 'The AI built into that editor. You describe what you want in plain language, it makes the change and runs the Git steps, then shows you what it did so you can approve.',
  },
];
---

<figure
  class="wtl-fig"
  role="img"
  aria-label="Your two tools for the session. Visual Studio Code is where you work: a free code editor that runs anywhere and is where you read files, see changes, and talk to the agent. GitHub Copilot is who does the work: the AI built into the editor that turns your plain-language request into changes and Git steps, then shows you what it did so you can approve. You talk to Copilot inside VS Code, and it does the work on GitHub."
>
  <div class="wtl-head">
    <span class="wtl-eyebrow">Your two tools</span>
    <h3 class="wtl-title">Where you work, and who does the typing</h3>
    <p class="wtl-sub">Two things make this possible. You don't have to be an expert in either one.</p>
  </div>

  <div class="wtl-cards">
    {tools.map((t, i) => (
      <div class="wtl-card" style={`--i:${i}`}>
        <span class="wtl-role">{t.role}</span>
        <span class="wtl-name">{t.name}</span>
        <span class="wtl-detail">{t.detail}</span>
      </div>
    ))}
  </div>

  <p class="wtl-flow">
    <span class="wtl-chip">You</span>
    <span class="wtl-arrow" aria-hidden="true">&rarr;</span>
    <span class="wtl-chip">Copilot, inside VS Code</span>
    <span class="wtl-arrow" aria-hidden="true">&rarr;</span>
    <span class="wtl-chip wtl-chip--accent">the work, on GitHub</span>
  </p>

  <figcaption class="wtl-caption">Your job is to say what you want and check the result. The tools handle the rest.</figcaption>
</figure>

<style>
  .wtl-fig {
    container-type: inline-size;
    margin: 0;
    box-sizing: border-box;
    width: 100%;
    padding: clamp(1.2rem, 0.7rem + 2.4cqw, 2.4rem);
    border-radius: 18px;
    background:
      radial-gradient(130% 95% at 12% -10%, rgba(89, 159, 253, 0.3), transparent 58%),
      radial-gradient(120% 95% at 92% 115%, rgba(250, 220, 20, 0.16), transparent 55%),
      linear-gradient(150deg, #0e2a52 0%, #0b2344 55%, #081a36 100%);
    color: #eaf1fb;
    box-shadow: 0 24px 60px rgba(8, 20, 40, 0.32);
  }

  .wtl-head { margin-bottom: clamp(0.9rem, 0.6rem + 1.4cqw, 1.6rem); }
  .wtl-eyebrow {
    display: block;
    font-size: clamp(0.62rem, 0.55rem + 0.3cqw, 0.74rem);
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #599ffd;
  }
  .wtl-title {
    margin: 0.3rem 0 0;
    font-size: clamp(1.1rem, 0.85rem + 1.4cqw, 1.7rem);
    font-weight: 800;
    line-height: 1.12;
    color: #fff;
  }
  .wtl-sub {
    margin: 0.5rem 0 0;
    font-size: clamp(0.78rem, 0.7rem + 0.3cqw, 0.95rem);
    color: #a5b8ee;
    max-width: 50ch;
  }

  .wtl-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.6rem, 0.35rem + 0.9cqw, 1rem);
  }
  .wtl-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: clamp(0.8rem, 0.55rem + 0.8cqw, 1.2rem);
    border-radius: 14px;
    background: rgba(89, 159, 253, 0.1);
    border: 1px solid rgba(89, 159, 253, 0.32);
    animation: wtl-fade 0.5s ease both;
    animation-delay: calc(var(--i) * 0.1s);
  }
  .wtl-card:nth-child(2) {
    background: rgba(250, 220, 20, 0.08);
    border-color: rgba(250, 220, 20, 0.4);
  }
  .wtl-role {
    font-size: clamp(0.62rem, 0.56rem + 0.26cqw, 0.74rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a5b8ee;
  }
  .wtl-card:nth-child(2) .wtl-role { color: #fadc14; }
  .wtl-name {
    font-size: clamp(0.96rem, 0.82rem + 0.5cqw, 1.2rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.12;
  }
  .wtl-detail {
    font-size: clamp(0.74rem, 0.66rem + 0.3cqw, 0.9rem);
    line-height: 1.34;
    color: #cfe0ff;
  }

  .wtl-flow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem 0.5rem;
    margin: clamp(0.9rem, 0.6rem + 1.2cqw, 1.4rem) 0 0;
  }
  .wtl-chip {
    font-size: clamp(0.7rem, 0.62rem + 0.3cqw, 0.84rem);
    font-weight: 700;
    padding: 0.28rem 0.6rem;
    border-radius: 8px;
    color: #dfeaff;
    background: rgba(89, 159, 253, 0.16);
    border: 1px solid rgba(89, 159, 253, 0.34);
  }
  .wtl-chip--accent {
    color: #081a36;
    background: #fadc14;
    border-color: #fadc14;
  }
  .wtl-arrow {
    color: #7aa6e8;
    font-weight: 800;
  }

  .wtl-caption {
    margin: clamp(0.9rem, 0.6rem + 1.2cqw, 1.5rem) 0 0;
    font-size: clamp(0.78rem, 0.7rem + 0.3cqw, 0.95rem);
    font-weight: 700;
    color: #e2f9d9;
  }

  @keyframes wtl-fade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @container (max-width: 520px) {
    .wtl-cards { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wtl-card { animation: none; }
  }
</style>
