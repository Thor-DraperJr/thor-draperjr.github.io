---
import openaiSvg from './logos/openai.svg?raw';
import anthropicSvg from './logos/anthropic.svg?raw';
import googlecloudSvg from './logos/googlecloud.svg?raw';
import awsSvg from './logos/amazonwebservices.svg?raw';
import langchainSvg from './logos/langchain.svg?raw';
import oktaSvg from './logos/okta.svg?raw';
import auth0Svg from './logos/auth0.svg?raw';
import salesforceSvg from './logos/salesforce.svg?raw';
import datadogSvg from './logos/datadog.svg?raw';
import splunkSvg from './logos/splunk.svg?raw';

import foundrySvg from './logos/microsoft/foundry.svg?raw';
import entraGovernanceSvg from './logos/microsoft/entra-governance.svg?raw';
import conditionalAccessSvg from './logos/microsoft/conditional-access.svg?raw';
import defenderSvg from './logos/microsoft/defender.svg?raw';

const msLogos: Record<string, string> = {
  foundry: foundrySvg,
  'entra-governance': entraGovernanceSvg,
  'conditional-access': conditionalAccessSvg,
  defender: defenderSvg,
};

const logos: Record<string, string> = {
  openai: openaiSvg,
  anthropic: anthropicSvg,
  gcp: googlecloudSvg,
  aws: awsSvg,
  langchain: langchainSvg,
  okta: oktaSvg,
  auth0: auth0Svg,
  salesforce: salesforceSvg,
  datadog: datadogSvg,
  splunk: splunkSvg,
};

interface Vendor {
  name: string;
  logo?: string;
  brand?: string;
}

interface MsProduct {
  name: string;
  brand: string;
  mono: string;
  logo?: string;
}

interface Station {
  id: string;
  label: string;
  accent: string;
  vendors: Vendor[];
  msft: MsProduct[];
}

const stations: Station[] = [
  {
    id: 'build',
    label: 'Build',
    accent: '#5c6b7d',
    vendors: [
      { name: 'OpenAI', logo: 'openai', brand: '#0f0f0f' },
      { name: 'Anthropic', logo: 'anthropic', brand: '#d97757' },
      { name: 'Vertex AI', logo: 'gcp', brand: '#4285f4' },
      { name: 'Bedrock', logo: 'aws', brand: '#ff9900' },
      { name: 'LangChain', logo: 'langchain', brand: '#1c3c3c' },
    ],
    msft: [
      { name: 'Microsoft Foundry', brand: '#0078d4', mono: 'MF', logo: 'foundry' },
      { name: 'Copilot Studio', brand: '#7b5cd6', mono: 'CS' },
    ],
  },
  {
    id: 'identify',
    label: 'Identify',
    accent: '#1f5fb8',
    vendors: [
      { name: 'Okta', logo: 'okta', brand: '#007dc1' },
      { name: 'Auth0', logo: 'auth0', brand: '#eb5424' },
      { name: 'Ping', brand: '#c8202f' },
      { name: 'CyberArk', brand: '#ff0000' },
    ],
    msft: [
      { name: 'Entra Agent ID', brand: '#0099bc', mono: 'EA' },
    ],
  },
  {
    id: 'entitle',
    label: 'Entitle',
    accent: '#1f7a47',
    vendors: [
      { name: 'SailPoint', brand: '#0d3b66' },
      { name: 'Saviynt', brand: '#7c3aed' },
      { name: 'ServiceNow', brand: '#62d84e' },
    ],
    msft: [
      { name: 'Entra ID Governance', brand: '#0099bc', mono: 'EG', logo: 'entra-governance' },
      { name: 'Conditional Access', brand: '#0099bc', mono: 'CA', logo: 'conditional-access' },
    ],
  },
  {
    id: 'run',
    label: 'Run',
    accent: '#6a3ba0',
    vendors: [
      { name: 'ServiceNow AICT', brand: '#62d84e' },
      { name: 'Agentforce', logo: 'salesforce', brand: '#00a1e0' },
      { name: 'Custom orchestrators', brand: '#888' },
    ],
    msft: [
      { name: 'Agent 365', brand: '#d83b01', mono: 'A3' },
    ],
  },
  {
    id: 'observe',
    label: 'Observe',
    accent: '#a87a1a',
    vendors: [
      { name: 'Datadog', logo: 'datadog', brand: '#632ca6' },
      { name: 'Splunk', logo: 'splunk', brand: '#65a637' },
      { name: 'Arize', brand: '#1e88e5' },
      { name: 'LangSmith', brand: '#1c3c3c' },
    ],
    msft: [
      { name: 'Agent 365 Observability', brand: '#d83b01', mono: 'A3' },
    ],
  },
  {
    id: 'govern',
    label: 'Govern',
    accent: '#a13b3b',
    vendors: [
      { name: 'OneTrust', brand: '#0066ff' },
      { name: 'BigID', brand: '#00a3e0' },
      { name: 'Credo AI', brand: '#1f8a8a' },
      { name: 'Zenity', brand: '#7c3aed' },
    ],
    msft: [
      { name: 'Defender', brand: '#00b294', mono: 'DF', logo: 'defender' },
      { name: 'Purview', brand: '#7719aa', mono: 'PV' },
    ],
  },
];

interface Phase {
  id: string;
  number: string;
  verb: string;
  body: string;
  good: string;
}

const lifecycle: Phase[] = [
  {
    id: 'build',
    number: '01',
    verb: 'Build',
    body: 'Someone in the business decides they want an agent. They pick a model, drop it into a workflow, and ship it. Usually before security or IT hears about it.',
    good: 'The agent shows up in a registry on day one, not after the incident.',
  },
  {
    id: 'identify',
    number: '02',
    verb: 'Identify',
    body: 'The agent needs a name and a credential. It has to be able to prove it is the agent your IT bought, not a script someone in marketing wrote on a Saturday.',
    good: 'Every agent has its own identity. The same directory humans live in.',
  },
  {
    id: 'entitle',
    number: '03',
    verb: 'Entitle',
    body: 'It gets the keys to do its job. Read this mailbox. Write to that ticket queue. Stay out of these folders. The wrong keys here is the whole story.',
    good: 'Least privilege, scoped to the task. Reviewed on a cadence like any other account.',
  },
  {
    id: 'run',
    number: '04',
    verb: 'Run',
    body: 'It does the work. Calls APIs. Hands off to other agents. Maybe runs for days. Maybe spawns helpers you didn\'t plan for.',
    good: 'Every action is traceable back to one agent, one prompt, one decision.',
  },
  {
    id: 'observe',
    number: '05',
    verb: 'Observe',
    body: 'Someone has to know what it did, what it tried to do, what it cost, and when it started behaving differently than the week before.',
    good: 'One signal graph. Drift, cost, and risk on the same screen.',
  },
  {
    id: 'govern',
    number: '06',
    verb: 'Govern',
    body: 'When the project ends, the team rotates, or the model gets retired, the agent has to be turned off and evidenced. Like any other user. Like any other system.',
    good: 'Leaver process for agents looks like the leaver process for humans. Auditable.',
  },
];

interface Zone {
  id: string;
  navLabel: string;
  kicker: string;
  title: string;
  state: 'local' | 'bullet';
  lede: string;
  caption: string;
  takeaway: string;
}

const zones: Zone[] = [
  {
    id: 'aa-zone-local',
    navLabel: 'The Silos',
    kicker: 'Route 01 · Six pillars, six vendors, no platform',
    state: 'local',
    title: 'Today: same six steps. A different vendor at every one. No control plane underneath.',
    lede: 'The lifecycle does not change. Every agent makes the same six-step trip. What changes is who runs each step. Today it is six different vendors, six different buying cycles, and six different operating pictures that do not connect.',
    caption: 'Six independent buying cycles. Shadow paths everywhere. No single pane of glass.',
    takeaway: 'It is not a missing tool. It is a missing platform. Six siloed vendors cannot produce one operating picture.',
  },
  {
    id: 'aa-zone-bullet',
    navLabel: 'The Express',
    kicker: 'Route 02 · The unified platform',
    state: 'bullet',
    title: 'The Microsoft Foundry route: same six steps, one operator, one control plane underneath.',
    lede: 'The lifecycle still does not change. Build, Identify, Entitle, Run, Observe, Govern is still the trip every agent has to make. The difference is the platform underneath. One operator across all six. One signal graph. One ticket for the whole route.',
    caption: 'Same six decisions every customer is already making. They land on one platform where the signals connect.',
    takeaway: 'You don\'t have to be the IDP to be the control plane. You just have to be the platform that runs underneath all six pillars.',
  },
];

const principles = [
  {
    short: 'Trust before control',
    long: 'Don\'t win the land grab. There\'s nothing to secure if the customer doesn\'t trust you to be in the room.',
  },
  {
    short: 'Control plane, not IDP',
    long: 'You don\'t have to be the IDP to be the control plane. The IDP they picked a decade ago is not moving. The control plane sits in front of it.',
  },
  {
    short: 'Agents are users',
    long: 'Measure twice, cut once. The same joiner/mover/leaver flow you already run for humans is the flow that should cover agents.',
  },
];
---

<section class="all-aboard" data-all-aboard>
  <nav class="deck-rail" aria-label="All Aboard sections">
    <a href="#aa-cover" data-rail-link>Cover</a>
    <a href="#aa-lifecycle" data-rail-link>The Lifecycle</a>
    {zones.map((z) => <a href={`#${z.id}`} data-rail-link>{z.navLabel}</a>)}
    <a href="#aa-close" data-rail-link>Close</a>
    <button type="button" class="present-toggle" data-present-toggle aria-label="Enter presentation mode">&#9654; Present</button>
  </nav>

  <div class="present-hud" data-present-hud aria-hidden="true">
    <span class="present-counter" data-present-counter>Section 01 / 05</span>
    <span class="present-title" data-present-title>Cover</span>
    <div class="present-controls">
      <button type="button" class="present-btn" data-present-prev aria-label="Previous section">&lsaquo;</button>
      <button type="button" class="present-btn" data-present-next aria-label="Next section">&rsaquo;</button>
      <button type="button" class="present-btn present-btn-exit" data-present-exit aria-label="Exit presentation">Exit</button>
    </div>
  </div>

  <section class="aa-cover" id="aa-cover" data-deck-section aria-labelledby="aa-cover-title">
    <div class="cover-grid">
      <div class="cover-copy">
        <span class="deck-kicker">Six pillars · one control plane</span>
        <h2 id="aa-cover-title">All Aboard.</h2>
        <p class="cover-thesis">Every agent you bring into the enterprise makes the same six-step trip — Build, Identify, Entitle, Run, Observe, Govern. End to end. From the idea on a whiteboard to the day it gets turned off. Today most enterprises buy each step from a different vendor and end up with six operating pictures that do not connect. The platform underneath is what changes that.</p>
        <ul class="cover-principles" role="list">
          {principles.map((p) => (
            <li>
              <strong>{p.short}.</strong>
              <span>{p.long}</span>
            </li>
          ))}
        </ul>
      </div>
      <aside class="cover-ticket" aria-label="One ticket, six stops">
        <span class="ticket-label">One ticket · six stops</span>
        <div class="ticket-body">
          {stations.map((s) => <span class="ticket-stub">{s.label}</span>)}
        </div>
        <p class="ticket-note">Every agent makes the same trip across the same six pillars. The question is whether each pillar is a silo or a stop on one platform.</p>
      </aside>
    </div>
  </section>

  <section class="aa-lifecycle" id="aa-lifecycle" data-deck-section aria-labelledby="aa-lifecycle-title">
    <div class="zone-head">
      <span class="deck-kicker">End-to-end &middot; what bringing an agent in actually looks like</span>
      <h2 id="aa-lifecycle-title">Six steps. Every agent. From the whiteboard to the day it gets turned off.</h2>
      <p class="zone-lede">Joiner, mover, leaver. The same flow you already run for humans. The same flow has to cover agents. The six steps below are the trip. Everything after this is who runs each one.</p>
    </div>

    <ol class="pillars pillars-lifecycle" aria-label="Agent lifecycle phases">
      {lifecycle.map((p, i) => {
        const accent = stations[i].accent;
        return (
          <li class={`pillar pillar-phase pillar-${p.id}`} style={`--p-accent: ${accent}`}>
            <div class="pillar-head"><span class="phase-num">{p.number}</span> {p.verb}</div>
            <div class="pillar-body pillar-body-phase">
              <p class="phase-body">{p.body}</p>
              <p class="phase-good"><span class="phase-good-label">What good looks like</span>{p.good}</p>
            </div>
          </li>
        );
      })}
    </ol>

    <div class="zone-foot">
      <p class="zone-caption">Same six steps every time. The differences between vendors and platforms only become visible once you draw the trip end to end.</p>
      <p class="zone-takeaway"><strong>Why this matters.</strong> Most agent conversations skip straight to a tool in one of these steps. Executives need to see the whole trip before they can pick where to spend.</p>
    </div>
  </section>

  {zones.map((zone) => (
    <section class={`aa-zone aa-zone-${zone.state}`} id={zone.id} data-deck-section aria-labelledby={`${zone.id}-title`}>
      <div class="zone-head">
        <span class="deck-kicker">{zone.kicker}</span>
        <h2 id={`${zone.id}-title`}>{zone.title}</h2>
        <p class="zone-lede">{zone.lede}</p>
      </div>

      <div class={`pillars pillars-${zone.state}`} aria-hidden="true">
        {stations.map((s) => (
          <div class={`pillar pillar-${s.id}`} style={`--p-accent: ${s.accent}`}>
            <div class="pillar-head">{s.label}</div>
            <div class="pillar-body">
              {zone.state === 'local' ? (
                s.vendors.map((v) => (
                  <div class="vendor" style={v.brand ? `--brand: ${v.brand}` : ''}>
                    {v.logo ? (
                      <span class="vendor-logo" set:html={logos[v.logo]} />
                    ) : (
                      <span class="vendor-mark" aria-hidden="true">{v.name.charAt(0)}</span>
                    )}
                    <span class="vendor-name">{v.name}</span>
                  </div>
                ))
              ) : (
                s.msft.map((m) => (
                  <div class="msft-component" style={`--brand: ${m.brand}`}>
                    {m.logo && msLogos[m.logo] ? (
                      <span class="msft-logo" aria-hidden="true" set:html={msLogos[m.logo]} />
                    ) : (
                      <span class="msft-tile" aria-hidden="true">{m.mono}</span>
                    )}
                    <span class="msft-name">{m.name}</span>
                  </div>
                ))
              )}
            </div>
          </div>
        ))}
      </div>

      {zone.state === 'local' ? (
        <div class="vehicle vehicle-local" aria-hidden="true">
          <svg viewBox="0 0 720 90" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <g class="rail-bed">
              <line x1="0" y1="66" x2="720" y2="66" />
              {Array.from({ length: 24 }).map((_, i) => (
                <line x1={20 + i * 30} y1="60" x2={20 + i * 30} y2="72" />
              ))}
            </g>
            <g class="local-train" transform="translate(40, 18)">
              <rect x="0" y="6" width="86" height="38" rx="4" fill="#8a4a2a" stroke="#4a2a18" stroke-width="1.5" />
              <path d="M 86 6 L 110 6 L 118 24 L 110 44 L 86 44 Z" fill="#8a4a2a" stroke="#4a2a18" stroke-width="1.5" />
              <rect x="6" y="12" width="16" height="14" fill="#f1e4c5" opacity="0.9" />
              <rect x="26" y="12" width="16" height="14" fill="#f1e4c5" opacity="0.9" />
              <rect x="46" y="12" width="16" height="14" fill="#f1e4c5" opacity="0.9" />
              <rect x="66" y="12" width="16" height="14" fill="#f1e4c5" opacity="0.9" />
              <rect x="92" y="12" width="12" height="10" fill="#f1e4c5" opacity="0.9" />
              <circle cx="18" cy="48" r="6" fill="#1a1208" />
              <circle cx="54" cy="48" r="6" fill="#1a1208" />
              <circle cx="94" cy="48" r="6" fill="#1a1208" />
              <rect x="30" y="0" width="32" height="6" fill="#5a2e16" />
              <text x="58" y="-4" text-anchor="middle" class="vehicle-label vehicle-label-local">LOCAL · stops 1 of 6</text>
            </g>
          </svg>
          <p class="vehicle-caption vehicle-caption-local">Six stops. Six budget owners. Six different operators on one trip.</p>
        </div>
      ) : (
        <div class="vehicle vehicle-bullet" aria-hidden="true">
          <svg viewBox="0 0 720 90" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="bullet-body" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#ffffff" />
                <stop offset="0.45" stop-color="#dfeaff" />
                <stop offset="1" stop-color="#2c6fd8" />
              </linearGradient>
              <linearGradient id="bullet-nose-shine" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#ffffff" stop-opacity="0.9" />
                <stop offset="1" stop-color="#ffffff" stop-opacity="0" />
              </linearGradient>
            </defs>
            <line x1="0" y1="68" x2="720" y2="68" class="rail-glow-line" />
            <line x1="0" y1="68" x2="720" y2="68" class="rail-line-sharp" />
            <g class="bullet-train" transform="translate(110, 22)">
              <g class="motion">
                <line x1="-40" y1="14" x2="-8" y2="14" />
                <line x1="-52" y1="24" x2="-12" y2="24" />
                <line x1="-44" y1="34" x2="-10" y2="34" />
              </g>
              {/* Body shadow under rail */}
              <ellipse cx="240" cy="46" rx="220" ry="3" fill="#000" opacity="0.25" />
              {/* Train silhouette: long tapered nose on the left, sleek body */}
              <path
                d="M 0 24 Q 4 6 100 6 L 470 6 Q 485 6 485 16 L 485 32 Q 485 42 470 42 L 100 42 Q 4 42 0 24 Z"
                fill="url(#bullet-body)"
                stroke="#1f5fb8"
                stroke-width="1.4"
              />
              {/* Gold racing stripe */}
              <rect x="6" y="22.5" width="478" height="3" fill="#f1b75f" />
              {/* Highlight on top of nose */}
              <path d="M 8 18 Q 30 10 120 12 L 120 16 Q 30 14 12 22 Z" fill="url(#bullet-nose-shine)" opacity="0.7" />
              {/* Cockpit window (dark wraparound) */}
              <path d="M 22 16 Q 28 10 80 11 L 80 19 Q 32 18 24 20 Z" fill="#0c1626" opacity="0.92" />
              {/* Headlight */}
              <circle cx="6" cy="24" r="2.4" fill="#ffe9a8" />
              <circle cx="6" cy="24" r="1.2" fill="#fff" />
              {/* Single row of evenly-spaced passenger windows */}
              {Array.from({ length: 9 }).map((_, i) => (
                <rect x={108 + i * 42} y="13" width="28" height="8" rx="1.5" fill="#0c1626" opacity="0.88" />
              ))}
              {/* Door seams */}
              <line x1="280" y1="6" x2="280" y2="42" stroke="#1f5fb8" stroke-width="0.8" opacity="0.5" />
              <line x1="420" y1="6" x2="420" y2="42" stroke="#1f5fb8" stroke-width="0.8" opacity="0.5" />
              <text x="240" y="-8" text-anchor="middle" class="vehicle-label vehicle-label-bullet">ALL-ABOARD EXPRESS · one route · one operator</text>
            </g>
          </svg>
          <p class="vehicle-caption vehicle-caption-bullet">Same six pillars. One platform underneath. One ticket end to end.</p>
        </div>
      )}

      <div class="zone-foot">
        <p class="zone-caption">{zone.caption}</p>
        <p class="zone-takeaway"><strong>What it means.</strong> {zone.takeaway}</p>
      </div>
    </section>
  ))}

  <section class="aa-close" id="aa-close" data-deck-section aria-labelledby="aa-close-title">
    <span class="deck-kicker">The line that closes it</span>
    <h2 id="aa-close-title">Sell the route. The express is what the customer buys. The bundle underneath is what makes the express possible.</h2>
    <ul class="close-list" role="list">
      <li><strong>Agents are users.</strong> Same six stops, two populations.</li>
      <li><strong>Don't win the land grab.</strong> Trust is the foundation. The express only works if the customer trusts the operator.</li>
      <li><strong>You don't have to be the IDP to be the control plane.</strong> Federate at the first station. Run the rest of the line.</li>
    </ul>
    <p class="close-line">Measure twice. Cut once. All aboard the express.</p>
  </section>
</section>

<script>
  (() => {
    const deck = document.querySelector('[data-all-aboard]');
    if (!deck) return;

    const rail = deck.querySelector('.deck-rail');
    const updateRailHeight = () => {
      if (!rail) return;
      const h = rail.getBoundingClientRect().height;
      deck.style.setProperty('--rail-height', `${Math.round(h)}px`);
    };
    updateRailHeight();
    if ('ResizeObserver' in window && rail) {
      const ro = new ResizeObserver(updateRailHeight);
      ro.observe(rail);
    } else {
      window.addEventListener('resize', updateRailHeight);
    }

    const railLinks = Array.from(deck.querySelectorAll('[data-rail-link]'));
    const sections = Array.from(deck.querySelectorAll('[data-deck-section]'));

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((l, r) => r.intersectionRatio - l.intersectionRatio)[0];
        if (!visible) return;
        railLinks.forEach((link) => {
          link.classList.toggle('is-active', link.getAttribute('href') === `#${visible.target.id}`);
        });
      }, { threshold: [0.24, 0.45, 0.65], rootMargin: '-15% 0px -55% 0px' });
      sections.forEach((s) => observer.observe(s));
    }

    const presentToggle = deck.querySelector('[data-present-toggle]');
    const presentHud = deck.querySelector('[data-present-hud]');
    const presentCounter = deck.querySelector('[data-present-counter]');
    const presentTitle = deck.querySelector('[data-present-title]');
    const presentPrev = deck.querySelector('[data-present-prev]');
    const presentNext = deck.querySelector('[data-present-next]');
    const presentExit = deck.querySelector('[data-present-exit]');

    if (!presentToggle || !sections.length) return;

    const total = sections.length;
    const totalLabel = String(total).padStart(2, '0');
    const sectionLabels = sections.map((s) => {
      const link = railLinks.find((l) => l.getAttribute('href') === `#${s.id}`);
      return link ? link.textContent.trim() : (s.id || '');
    });

    let currentIdx = 0;
    let isPresenting = false;
    let leaveTimer = 0;

    const setSlide = (idx) => {
      if (idx < 0) idx = 0;
      if (idx >= total) idx = total - 1;
      if (idx === currentIdx && sections[idx].classList.contains('is-current')) return;
      const previous = sections[currentIdx];
      const next = sections[idx];
      const direction = idx >= currentIdx ? 1 : -1;
      deck.dataset.presentDir = direction > 0 ? 'forward' : 'back';
      if (previous && previous !== next) {
        previous.classList.remove('is-current');
        previous.classList.add('is-leaving');
        window.clearTimeout(leaveTimer);
        leaveTimer = window.setTimeout(() => previous.classList.remove('is-leaving'), 460);
      }
      next.classList.add('is-current');
      next.classList.remove('is-leaving');
      next.scrollTop = 0;
      currentIdx = idx;
      if (presentCounter) presentCounter.textContent = `Section ${String(idx + 1).padStart(2, '0')} / ${totalLabel}`;
      if (presentTitle) presentTitle.textContent = sectionLabels[idx] || '';
    };

    const enterPresent = () => {
      if (isPresenting) return;
      isPresenting = true;
      deck.dataset.present = 'true';
      if (presentHud) presentHud.removeAttribute('aria-hidden');
      document.documentElement.classList.add('deck-presenting');
      document.body.classList.add('deck-presenting');
      currentIdx = 0;
      sections.forEach((s) => s.classList.remove('is-current', 'is-leaving'));
      setSlide(0);
      window.setTimeout(() => presentNext && presentNext.focus(), 60);
    };

    const exitPresent = () => {
      if (!isPresenting) return;
      isPresenting = false;
      delete deck.dataset.present;
      delete deck.dataset.presentDir;
      if (presentHud) presentHud.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('deck-presenting');
      document.body.classList.remove('deck-presenting');
      sections.forEach((s) => s.classList.remove('is-current', 'is-leaving'));
      presentToggle.focus();
    };

    presentToggle.addEventListener('click', enterPresent);
    presentExit && presentExit.addEventListener('click', exitPresent);
    presentPrev && presentPrev.addEventListener('click', () => setSlide(currentIdx - 1));
    presentNext && presentNext.addEventListener('click', () => setSlide(currentIdx + 1));

    document.addEventListener('keydown', (event) => {
      if (!isPresenting) return;
      if (event.key === 'Escape') { event.preventDefault(); exitPresent(); }
      else if (event.key === 'ArrowRight' || event.key === 'PageDown' || event.key === ' ') { event.preventDefault(); setSlide(currentIdx + 1); }
      else if (event.key === 'ArrowLeft' || event.key === 'PageUp') { event.preventDefault(); setSlide(currentIdx - 1); }
      else if (event.key === 'Home') { event.preventDefault(); setSlide(0); }
      else if (event.key === 'End') { event.preventDefault(); setSlide(total - 1); }
    });
  })();
</script>

