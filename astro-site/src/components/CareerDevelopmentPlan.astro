---
import { cdp } from '../lib/careerPlan';
---

<div class="cdp" data-cdp>
  <div class="cdp-edition">
    <span class="cdp-edition-label">Career Development Plan</span>
    <span class="cdp-edition-date">Edition: {cdp.edition} &middot; {cdp.editionDate}</span>
  </div>

  <header class="cdp-header">
    <div class="cdp-header-text">
      <h2 class="cdp-name">{cdp.name}</h2>
      <p class="cdp-title">{cdp.title}</p>
      <p class="cdp-org">{cdp.org}</p>
    </div>
    <div class="cdp-header-meta">
      {cdp.meta.map((m) => (
        <div class="cdp-meta-pill">
          <span class="cdp-meta-key">{m.label}</span>
          <span class="cdp-meta-val" data-count-to={/^\d+$/.test(m.value) ? m.value : undefined}>{m.value}</span>
        </div>
      ))}
    </div>
  </header>

  <div class="cdp-body">
    <!-- Column 1: About Leader -->
    <div class="cdp-col cdp-col-about">
      <div class="cdp-col-header cdp-col-header-teal">About Leader</div>
      <div class="cdp-col-content">
        <dl class="cdp-facts">
          {cdp.facts.map((f) => (
            <div class="cdp-fact"><dt>{f.label}</dt><dd>{f.value}</dd></div>
          ))}
        </dl>

        <p class="cdp-impact-summary">{cdp.impact.summary}</p>

        <h5 class="cdp-subsection-title">Summary of Impact</h5>
        {cdp.impact.what.map((w) => (
          <div class="cdp-impact-what">
            <span class="cdp-impact-goal">{w.goal}</span>
            <p class="cdp-impact-result">{w.result}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Column 2: Core Strengths -->
    <div class="cdp-col cdp-col-strengths">
      <div class="cdp-col-header cdp-col-header-purple">Core Strengths</div>
      <div class="cdp-col-content">
        {cdp.coreStrengths.map((s, i) => (
          <div class={`cdp-strength-block${i > 0 ? ' cdp-subsection' : ''}`}>
            <h5 class="cdp-strength-heading">{s.title}</h5>
            <p class="cdp-strength-narrative">{s.narrative}</p>
          </div>
        ))}

        <div class="cdp-sme-grid">
          {cdp.sme.map((tag) => <span class="cdp-sme-tag">{tag}</span>)}
        </div>
      </div>
    </div>

    <!-- Column 3: Development Areas & Actions -->
    <div class="cdp-col cdp-col-dev">
      <div class="cdp-col-header cdp-col-header-navy">Development Areas &amp; Actions</div>
      <div class="cdp-col-content">
        <h5 class="cdp-subsection-title">Areas of Development</h5>
        <ul class="cdp-dev-list">
          {cdp.developmentAreas.map((item) => <li>{item}</li>)}
        </ul>

        <h5 class="cdp-subsection-title" style="margin-top: 1rem;">Development Actions</h5>
        <ul class="cdp-dev-list cdp-dev-actions">
          {cdp.developmentActions.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>

    <!-- Column 4: Career History -->
    <div class="cdp-col cdp-col-history">
      <div class="cdp-col-header cdp-col-header-steel">Career History</div>
      <div class="cdp-col-content">
        <div class="cdp-timeline">
          {cdp.workHistory.map((w) => (
            <div class={`cdp-timeline-item${w.current ? ' cdp-timeline-current' : ''}`}>
              <span class="cdp-timeline-dates">{w.dates}</span>
              <span class="cdp-timeline-company">{w.company}</span>
              <span class="cdp-timeline-role">{w.role}</span>
            </div>
          ))}
        </div>
        <p class="cdp-prior-experience">Prior: {cdp.priorExperience}</p>

        <div class="cdp-subsection">
          <h5 class="cdp-subsection-title">Education</h5>
          <ul class="cdp-edu-list">
            {cdp.education.map((e) => (
              <li><strong>{e.degree}</strong><span>{e.school}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <section class="cdp-progress-section">
    <div class="cdp-progress-header">
      <h3 class="cdp-progress-title">Actions Since Last Review</h3>
      <span class="cdp-progress-period">{cdp.edition}</span>
    </div>
    <ul class="cdp-progress-list">
      {cdp.progress.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</div>

<script>
  function initCDP() {
    const root = document.querySelector('[data-cdp]');
    if (!root || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Animated count-up for numeric values
    const counters = root.querySelectorAll('[data-count-to]');
    const counted = new WeakSet();
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting || counted.has(entry.target)) return;
        counted.add(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countTo!, 10);
        el.textContent = '0';
        const duration = 900;
        const start = performance.now();
        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = String(Math.round(eased * target));
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.3 });
    counters.forEach((el) => counterObserver.observe(el));
  }

  // Run on initial load and after Astro view transitions
  initCDP();
  document.addEventListener('astro:page-load', initCDP);
</script>

<style>
  .cdp {
    margin: 2.5rem 0;
    display: grid;
    gap: 0;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  /* ---- Edition banner ---- */
  .cdp-edition {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.35rem 1rem;
    background: linear-gradient(90deg, #0e6a61 0%, #195ca6 50%, #0e6a61 100%);
    background-size: 200% 100%;
    animation: cdpShimmer 6s ease-in-out infinite;
    border-radius: 14px 14px 0 0;
    color: white;
  }

  .cdp-edition-label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cdp-edition-date {
    font-size: 0.64rem;
    font-weight: 600;
    opacity: 0.8;
  }

  /* ---- Header ---- */
  .cdp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 1.25rem;
    background: linear-gradient(135deg, #132235 0%, #1e3a5f 100%);
    border-left: 1px solid rgba(19, 34, 53, 0.1);
    border-right: 1px solid rgba(19, 34, 53, 0.1);
    color: white;
  }

  .cdp-name {
    margin: 0;
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    color: white;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .cdp-title {
    margin: 0.15rem 0 0;
    font-size: 0.85rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
  }

  .cdp-org {
    margin: 0.1rem 0 0;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 600;
  }

  .cdp-header-meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .cdp-meta-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.3rem 0.5rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    min-width: 4.5rem;
    text-align: center;
  }

  .cdp-meta-key {
    font-size: 0.58rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cdp-meta-val {
    font-family: 'Fraunces', serif;
    font-size: 0.95rem;
    color: white;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  /* ---- Four-column body ---- */
  .cdp-body {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1fr 0.9fr;
    flex: 1;
    border-left: 1px solid rgba(19, 34, 53, 0.1);
    border-right: 1px solid rgba(19, 34, 53, 0.1);
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(18px);
    overflow: hidden;
  }

  .cdp-col {
    border-right: 1px solid rgba(19, 34, 53, 0.06);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .cdp-col:last-child {
    border-right: 0;
  }

  .cdp-col-header {
    padding: 0.35rem 0.75rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: white;
    flex-shrink: 0;
  }

  .cdp-col-header-teal {
    background: linear-gradient(90deg, #0e6a61 0%, #0d8075 100%);
  }

  .cdp-col-header-purple {
    background: linear-gradient(90deg, #5b3a8c 0%, #7b52ab 100%);
  }

  .cdp-col-header-navy {
    background: linear-gradient(90deg, #132235 0%, #1e3a5f 100%);
  }

  .cdp-col-header-steel {
    background: linear-gradient(90deg, #475b6f 0%, #5e7589 100%);
  }

  .cdp-col-content {
    padding: 0.55rem 0.7rem;
    flex: 1;
    overflow: hidden;
  }

  /* ---- Facts ---- */
  .cdp-facts {
    margin: 0;
    display: grid;
    gap: 0.3rem;
  }

  .cdp-fact {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.3rem;
  }

  .cdp-fact dt {
    font-size: 0.65rem;
    font-weight: 800;
    color: #0e6a61;
    white-space: nowrap;
  }

  .cdp-fact dt::after {
    content: ':';
  }

  .cdp-fact dd {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    color: #132235;
    line-height: 1.35;
  }

  /* ---- Subsections ---- */
  .cdp-subsection {
    margin-top: 0.5rem;
    padding-top: 0.4rem;
    border-top: 1px solid rgba(19, 34, 53, 0.08);
  }

  .cdp-subsection-title {
    margin: 0 0 0.3rem;
    font-size: 0.62rem;
    font-weight: 800;
    color: #728193;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ---- Impact section ---- */
  .cdp-impact-summary {
    margin: 0.45rem 0 0.35rem;
    padding-top: 0.4rem;
    border-top: 1px solid rgba(19, 34, 53, 0.08);
    font-size: 0.7rem;
    color: #4f6070;
    line-height: 1.45;
    font-style: italic;
  }

  .cdp-impact-what {
    margin-bottom: 0.35rem;
  }

  .cdp-impact-what:last-child {
    margin-bottom: 0;
  }

  .cdp-impact-goal {
    display: inline-block;
    padding: 0.08rem 0.35rem;
    border-radius: 3px;
    background: rgba(14, 106, 97, 0.1);
    font-size: 0.58rem;
    font-weight: 800;
    color: #0e6a61;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cdp-impact-result {
    margin: 0.15rem 0 0;
    font-size: 0.68rem;
    color: #132235;
    line-height: 1.4;
  }

  /* ---- Progress section (full-width footer) ---- */
  .cdp-progress-section {
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #132235 0%, #1e3a5f 100%);
    border-radius: 0 0 14px 14px;
    color: white;
    flex-shrink: 0;
  }

  .cdp-progress-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.35rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .cdp-progress-title {
    margin: 0;
    font-family: 'Fraunces', serif;
    font-size: 0.85rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .cdp-progress-period {
    font-size: 0.64rem;
    font-weight: 700;
    opacity: 0.6;
    white-space: nowrap;
  }

  .cdp-progress-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.2rem 1rem;
  }

  .cdp-progress-list li {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: 0.66rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.85);
  }

  .cdp-progress-list li::before {
    content: '';
    flex-shrink: 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #0e6a61;
    box-shadow: 0 0 0 2px rgba(14, 106, 97, 0.3);
    position: relative;
    top: -0.1em;
  }

  /* ---- Education list ---- */
  .cdp-edu-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cdp-edu-list li {
    margin-bottom: 0.3rem;
  }

  .cdp-edu-list strong {
    display: block;
    font-size: 0.72rem;
    color: #132235;
  }

  .cdp-edu-list span {
    font-size: 0.64rem;
    color: #728193;
    font-style: italic;
  }

  /* ---- Timeline ---- */
  .cdp-timeline {
    display: grid;
    gap: 0;
  }

  .cdp-timeline-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding: 0.25rem 0 0.25rem 0.7rem;
    border-left: 2px solid rgba(19, 34, 53, 0.12);
    position: relative;
    transition: background 0.25s ease, padding-left 0.25s ease;
    border-radius: 6px;
  }

  .cdp-timeline-item::before {
    content: '';
    position: absolute;
    left: -4px;
    top: 0.5rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #728193;
    border: 1.5px solid rgba(255, 255, 255, 0.9);
  }

  .cdp-timeline-current {
    border-left-color: #0e6a61;
  }

  .cdp-timeline-current::before {
    background: #0e6a61;
    box-shadow: 0 0 0 2px rgba(14, 106, 97, 0.2);
  }

  .cdp-timeline-current:hover {
    background: rgba(14, 106, 97, 0.06);
    padding-left: 0.85rem;
  }

  .cdp-timeline-dates {
    font-size: 0.6rem;
    font-weight: 800;
    color: #728193;
    letter-spacing: 0.04em;
  }

  .cdp-timeline-company {
    font-size: 0.68rem;
    font-weight: 700;
    color: #132235;
  }

  .cdp-timeline-role {
    font-size: 0.62rem;
    color: #4f6070;
  }

  .cdp-prior-experience {
    margin: 0.4rem 0 0;
    padding: 0.3rem 0.5rem;
    font-size: 0.6rem;
    font-weight: 700;
    color: #728193;
    font-style: italic;
    border-top: 1px dashed rgba(19, 34, 53, 0.12);
  }

  /* ---- Strength narratives ---- */
  .cdp-strength-block {
    margin-bottom: 0.15rem;
  }

  .cdp-strength-heading {
    margin: 0 0 0.2rem;
    font-family: 'Fraunces', serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #132235;
    letter-spacing: -0.01em;
  }

  .cdp-strength-narrative {
    margin: 0;
    font-size: 0.68rem;
    color: #4f6070;
    line-height: 1.45;
  }

  /* ---- SME tags ---- */
  .cdp-sme-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.4rem;
  }

  .cdp-sme-tag {
    display: inline-block;
    padding: 0.12rem 0.35rem;
    border-radius: 999px;
    background: #f3f0f8;
    border: 1px solid #e0d6ed;
    font-size: 0.54rem;
    font-weight: 700;
    color: #5b3a8c;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cdp-sme-tag:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(91, 58, 140, 0.15);
  }

  /* ---- Development list ---- */
  .cdp-dev-list {
    margin: 0;
    padding: 0 0 0 0.8rem;
    font-size: 0.75rem;
    color: #132235;
    line-height: 1.5;
  }

  .cdp-dev-list li {
    margin-bottom: 0.3rem;
  }

  .cdp-dev-list li::marker {
    color: #1e3a5f;
  }

  .cdp-dev-actions li {
    color: #4f6070;
  }

  /* ---- Shimmer keyframe ---- */
  @keyframes cdpShimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* ---- Scroll-driven entrance animations removed ----
     The 16:9 aspect-ratio container with overflow:hidden prevents
     animation-timeline: view() from triggering reliably.
     Count-up animation on meta pills is kept via the script. ---- */

  /* ---- Responsive: 2x2 grid ---- */
  @media (max-width: 1100px) {
    .cdp {
      aspect-ratio: unset;
      overflow: visible;
    }

    .cdp-body {
      grid-template-columns: 1fr 1fr;
      overflow: visible;
    }

    .cdp-col {
      overflow: visible;
    }

    .cdp-col:nth-child(2) {
      border-right: 0;
    }

    .cdp-col:nth-child(1),
    .cdp-col:nth-child(2) {
      border-bottom: 1px solid rgba(19, 34, 53, 0.06);
    }

    .cdp-progress-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ---- Responsive: single column ---- */
  @media (max-width: 720px) {
    .cdp-body {
      grid-template-columns: 1fr;
    }

    .cdp-col {
      border-right: 0;
      border-bottom: 1px solid rgba(19, 34, 53, 0.06);
    }

    .cdp-col:last-child {
      border-bottom: 0;
    }

    .cdp-edition {
      flex-direction: column;
      gap: 0.2rem;
      align-items: flex-start;
      border-radius: 12px 12px 0 0;
    }

    .cdp-header {
      flex-direction: column;
      align-items: flex-start;
      padding: 0.75rem 1rem;
    }

    .cdp-header-meta {
      justify-content: flex-start;
    }

    .cdp-name {
      font-size: 1.3rem;
    }

    .cdp-col-content {
      padding: 0.75rem;
    }

    .cdp-progress-section {
      padding: 0.75rem;
      border-radius: 0 0 12px 12px;
    }

    .cdp-progress-list {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cdp-edition {
      animation: none;
      background-size: 100% 100%;
    }
  }
</style>
