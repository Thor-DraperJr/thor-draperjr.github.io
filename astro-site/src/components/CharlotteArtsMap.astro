---
import {
  artsMapCenter,
  artsMapFilters,
  artsRailStations,
  artsVenues,
} from '../lib/charlotteArtsMap';

const mapCanvasId = 'charlotte-arts-map-canvas';
---

<section class="arts-map-shell" data-charlotte-arts-map data-reveal>
  <div class="arts-map-header">
    <span class="arts-map-kicker">Venue Map</span>
    <h2>Where These Spots Actually Are</h2>
    <p>
      The list in this post is organization-based. This map is venue-based because that is a lot more useful when I am
      actually trying to leave the house. Click a card or marker and the map will show the closest Blue or Gold stop I
      could pin down for that venue.
    </p>
  </div>

  <div class="arts-map-toolbar" role="toolbar" aria-label="Map filters">
    {artsMapFilters.map((filter, index) => (
      <button
        class="arts-map-filter"
        type="button"
        data-map-filter={filter.id}
        aria-pressed={index === 0 ? 'true' : 'false'}
      >
        {filter.label}
      </button>
    ))}
  </div>

  <div class="arts-map-grid">
    <div class="arts-map-stage">
      <div class="arts-map-legend" aria-label="Map legend">
        <span><i class="arts-map-legend-dot arts-map-legend-dot-performance"></i>Performance</span>
        <span><i class="arts-map-legend-dot arts-map-legend-dot-museum"></i>Museum</span>
        <span><i class="arts-map-legend-dot arts-map-legend-dot-studio"></i>Studio</span>
        <span><i class="arts-map-legend-dot arts-map-legend-dot-rail"></i>Blue / Gold anchor</span>
      </div>

      <div id={mapCanvasId} class="arts-map-canvas" data-map-canvas>
        <p class="arts-map-fallback">
          The map loads with JavaScript enabled. If it does not, the venue cards still have the useful part: the actual
          addresses and the rail links.
        </p>
      </div>

      <div class="arts-map-notes">
        <p>
          Rail notes are based on the closest Blue or Gold stop I could pin down from the venue addresses and central
          CATS stations. Since I am starting from Uptown, that is the only part I really care about.
        </p>
      </div>
    </div>

    <aside class="arts-map-sidebar" aria-label="Venue list">
      <div class="arts-map-sidebar-copy">
        <h3>Rail-First Planning</h3>
        <p>
          The cards below are the practical version. Click one to focus the map. The first link is the closest Blue or
          Gold stop I found for that spot.
        </p>
      </div>

      <ul class="arts-map-card-list">
        {artsVenues.map((venue) => (
          <li
            class="arts-map-card"
            data-venue-card
            data-venue-id={venue.id}
            data-filter-group={venue.filterGroup}
          >
            <button class="arts-map-card-hit" type="button" data-focus-venue={venue.id}>
              <span class="arts-map-card-topline">
                <span class="arts-map-card-title">{venue.name}</span>
                <span class="arts-map-card-area">{venue.areaLabel}</span>
              </span>
              <span class="arts-map-card-address">{venue.address}</span>
              <span class="arts-map-card-orgs">Best for {venue.organizations.join(', ')}</span>
            </button>

            <p class="arts-map-card-note">{venue.note}</p>

            <div class="arts-map-card-actions">
              {venue.primaryRailGuide ? (
                <a href={venue.primaryRailGuide.directionsUrl} target="_blank" rel="noreferrer">
                  From {venue.primaryRailGuide.station.name} · about {venue.primaryRailGuide.estimatedWalkMinutes} min
                </a>
              ) : (
                <span class="arts-map-card-static">No clean Blue/Gold drop-off for this one.</span>
              )}
              <a href={venue.siteUrl} target="_blank" rel="noreferrer">Official site</a>
            </div>
          </li>
        ))}
      </ul>
    </aside>
  </div>

  <div class="arts-map-station-strip" aria-label="Rail anchors">
    {artsRailStations.map((station) => (
      <div class="arts-map-station-pill">
        <span class="arts-map-station-name">{station.name}</span>
        <span class="arts-map-station-lines">{station.lines.join(' + ')}</span>
      </div>
    ))}
  </div>
</section>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script define:vars={{ venues: artsVenues, stations: artsRailStations, mapCenter: artsMapCenter }}>
  function initCharlotteArtsMaps() {
    const roots = Array.from(document.querySelectorAll('[data-charlotte-arts-map]'));
    if (!roots.length || !window.L) return;

    roots.forEach((root) => {
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const L = window.L;
      const mapCanvas = root.querySelector('[data-map-canvas]');
      const filterButtons = Array.from(root.querySelectorAll('[data-map-filter]'));
      const venueCards = Array.from(root.querySelectorAll('[data-venue-card]'));
      const focusButtons = Array.from(root.querySelectorAll('[data-focus-venue]'));

      if (!mapCanvas) return;

      const stationLookup = new Map(stations.map((station) => [station.id, station]));
      const venueLookup = new Map(venues.map((venue) => [venue.id, venue]));

      const map = L.map(mapCanvas, {
        zoomControl: true,
        scrollWheelZoom: false,
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        subdomains: 'abcd',
        maxZoom: 20,
        attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
      }).addTo(map);

      map.attributionControl.setPrefix(false);

      const stationMarkers = new Map();
      const venueMarkers = new Map();
      let activeRouteLine = null;
      let activeVenueId = null;
      let activeFilter = 'all';

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function createVenueIcon(category) {
        return L.divIcon({
          className: '',
          iconSize: [20, 20],
          iconAnchor: [10, 10],
          popupAnchor: [0, -10],
          html: `<span class="arts-map-marker-shell arts-map-marker-shell-${category}"><span class="arts-map-marker-core"></span></span>`,
        });
      }

      function createStationIcon(lines) {
        const dualLine = lines.length > 1 ? ' arts-map-rail-shell-dual' : '';
        return L.divIcon({
          className: '',
          iconSize: [20, 20],
          iconAnchor: [10, 10],
          popupAnchor: [0, -10],
          html: `<span class="arts-map-rail-shell${dualLine}"><span class="arts-map-rail-core"></span></span>`,
        });
      }

      function renderStationPopup(station) {
        return `
          <div class="arts-map-popup">
            <strong>${escapeHtml(station.name)}</strong>
            <p>${escapeHtml(station.lines.join(' + '))}</p>
            <p>${escapeHtml(station.note)}</p>
          </div>
        `;
      }

      function renderVenuePopup(venue) {
        const railBlock = venue.primaryRailGuide
          ? `<p><strong>From rail:</strong> <a href="${venue.primaryRailGuide.directionsUrl}" target="_blank" rel="noreferrer">${escapeHtml(venue.primaryRailGuide.station.name)} · about ${venue.primaryRailGuide.estimatedWalkMinutes} min</a></p>`
          : '<p><strong>From rail:</strong> better as a dedicated drive or rideshare stop.</p>';

        return `
          <div class="arts-map-popup">
            <strong>${escapeHtml(venue.name)}</strong>
            <p>${escapeHtml(venue.address)}</p>
            <p><strong>Best for:</strong> ${escapeHtml(venue.organizations.join(', '))}</p>
            <p>${escapeHtml(venue.note)}</p>
            ${railBlock}
            <p><a href="${venue.siteUrl}" target="_blank" rel="noreferrer">Official site</a></p>
          </div>
        `;
      }

      stations.forEach((station) => {
        const marker = L.marker([station.lat, station.lng], {
          icon: createStationIcon(station.lines),
        }).addTo(map);

        marker.bindPopup(renderStationPopup(station));
        stationMarkers.set(station.id, marker);
      });

      venues.forEach((venue) => {
        const marker = L.marker([venue.lat, venue.lng], {
          icon: createVenueIcon(venue.category),
        }).addTo(map);

        marker.bindPopup(renderVenuePopup(venue));
        marker.on('click', () => {
          setActiveVenue(venue.id, true);
        });

        venueMarkers.set(venue.id, marker);
      });

      function visibleVenuesForFilter(filterId) {
        if (filterId === 'all') return venues;
        return venues.filter((venue) => venue.filterGroup === filterId);
      }

      function updateCardState() {
        venueCards.forEach((card) => {
          const isActive = card.dataset.venueId === activeVenueId;
          card.classList.toggle('is-active', isActive);
        });

        venueMarkers.forEach((marker, venueId) => {
          const markerElement = marker.getElement();
          if (!markerElement) return;
          markerElement.classList.toggle('is-active', venueId === activeVenueId);
        });
      }

      function clearRouteLine() {
        if (!activeRouteLine) return;
        map.removeLayer(activeRouteLine);
        activeRouteLine = null;
      }

      function drawRouteLine(venue) {
        clearRouteLine();
        if (!venue || !venue.primaryRailGuide) return;

        const station = stationLookup.get(venue.primaryRailGuide.stationId);
        if (!station) return;

        activeRouteLine = L.polyline(
          [
            [station.lat, station.lng],
            [venue.lat, venue.lng],
          ],
          {
            color: '#c49c33',
            weight: 3,
            opacity: 0.95,
            dashArray: '8 8',
            lineCap: 'round',
          },
        ).addTo(map);
      }

      function fitMapToVenues(currentVenues) {
        const coordinates = [];
        const stationIds = new Set();

        currentVenues.forEach((venue) => {
          coordinates.push([venue.lat, venue.lng]);
          venue.railGuides.forEach((guide) => stationIds.add(guide.stationId));
        });

        stationIds.forEach((stationId) => {
          const station = stationLookup.get(stationId);
          if (station) {
            coordinates.push([station.lat, station.lng]);
          }
        });

        if (!coordinates.length) {
          map.setView([mapCenter.lat, mapCenter.lng], 13);
          return;
        }

        if (coordinates.length === 1) {
          map.setView(coordinates[0], 15);
          return;
        }

        map.fitBounds(coordinates, {
          padding: [32, 32],
          maxZoom: 15,
        });
      }

      function applyFilter(filterId) {
        activeFilter = filterId;
        const currentVenues = visibleVenuesForFilter(filterId);
        const visibleVenueIds = new Set(currentVenues.map((venue) => venue.id));
        const visibleStationIds = new Set();

        currentVenues.forEach((venue) => {
          venue.railGuides.forEach((guide) => visibleStationIds.add(guide.stationId));
        });

        venueCards.forEach((card) => {
          card.hidden = !visibleVenueIds.has(card.dataset.venueId);
        });

        venueMarkers.forEach((marker, venueId) => {
          if (visibleVenueIds.has(venueId)) {
            if (!map.hasLayer(marker)) marker.addTo(map);
          } else if (map.hasLayer(marker)) {
            map.removeLayer(marker);
          }
        });

        stationMarkers.forEach((marker, stationId) => {
          if (visibleStationIds.has(stationId)) {
            if (!map.hasLayer(marker)) marker.addTo(map);
          } else if (map.hasLayer(marker)) {
            map.removeLayer(marker);
          }
        });

        filterButtons.forEach((button) => {
          button.setAttribute('aria-pressed', String(button.dataset.mapFilter === filterId));
        });

        if (activeVenueId && !visibleVenueIds.has(activeVenueId)) {
          activeVenueId = null;
          clearRouteLine();
          updateCardState();
        }

        fitMapToVenues(currentVenues);
      }

      function setActiveVenue(venueId, flyToMarker) {
        const venue = venueLookup.get(venueId);
        const marker = venueMarkers.get(venueId);

        if (!venue || !marker) return;

        activeVenueId = venueId;
        updateCardState();
        drawRouteLine(venue);
        marker.openPopup();

        if (flyToMarker) {
          map.flyTo([venue.lat, venue.lng], Math.max(map.getZoom(), 14), {
            duration: 0.45,
          });
        }
      }

      focusButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const venueId = button.dataset.focusVenue;
          if (!venueId) return;
          setActiveVenue(venueId, true);
        });
      });

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filterId = button.dataset.mapFilter;
          if (!filterId || filterId === activeFilter) return;
          applyFilter(filterId);
        });
      });

      map.setView([mapCenter.lat, mapCenter.lng], 13);
      applyFilter('all');
      requestAnimationFrame(() => map.invalidateSize());
    });
  }

  initCharlotteArtsMaps();
  document.addEventListener('astro:page-load', initCharlotteArtsMaps);
</script>

<style is:global>
  @import url('https://unpkg.com/leaflet@1.9.4/dist/leaflet.css');

  .arts-map-shell {
    margin: 2.5rem 0;
    padding: 1.4rem;
    border: 1px solid rgba(19, 34, 53, 0.1);
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(201, 163, 72, 0.16), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(248, 245, 238, 0.96) 100%);
    box-shadow: var(--shadow);
  }

  .arts-map-header h2,
  .arts-map-sidebar-copy h3 {
    margin: 0;
    font-family: 'Lora', serif;
    letter-spacing: -0.03em;
  }

  .arts-map-kicker {
    display: inline-block;
    margin-bottom: 0.45rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #7a8b98;
  }

  .arts-map-header p,
  .arts-map-sidebar-copy p,
  .arts-map-notes p {
    margin: 0.65rem 0 0;
    color: var(--ink-soft);
    font-size: 0.96rem;
  }

  .arts-map-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1.25rem 0 1rem;
  }

  .arts-map-filter {
    border: 1px solid rgba(19, 34, 53, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--ink-soft);
    cursor: pointer;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 800;
    padding: 0.65rem 0.95rem;
    transition: transform 140ms ease, background 140ms ease, color 140ms ease, border-color 140ms ease;
  }

  .arts-map-filter[aria-pressed='true'] {
    background: linear-gradient(135deg, #123253 0%, #184c78 100%);
    border-color: transparent;
    color: white;
  }

  .arts-map-filter:hover {
    transform: translateY(-1px);
  }

  .arts-map-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(19rem, 0.95fr);
  }

  .arts-map-stage,
  .arts-map-sidebar {
    min-width: 0;
  }

  .arts-map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 0.85rem;
    color: var(--ink-soft);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .arts-map-legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .arts-map-legend-dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    display: inline-block;
  }

  .arts-map-legend-dot-performance {
    background: #0e6a61;
  }

  .arts-map-legend-dot-museum {
    background: #c49c33;
  }

  .arts-map-legend-dot-studio {
    background: #5b6676;
  }

  .arts-map-legend-dot-rail {
    background: linear-gradient(135deg, #2f73bd 0%, #d1a646 100%);
  }

  .arts-map-canvas {
    min-height: clamp(20rem, 48vw, 35rem);
    border: 1px solid rgba(19, 34, 53, 0.1);
    border-radius: 24px;
    overflow: hidden;
    background: linear-gradient(180deg, #e8efe9 0%, #dfe7e2 100%);
  }

  .arts-map-canvas .leaflet-control-attribution {
    font-size: 0.68rem;
  }

  .arts-map-fallback {
    margin: 0;
    padding: 1rem;
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .arts-map-notes {
    margin-top: 0.85rem;
    padding: 0.85rem 1rem;
    border-radius: 18px;
    background: rgba(19, 34, 53, 0.05);
  }

  .arts-map-sidebar {
    padding: 1rem;
    border: 1px solid rgba(19, 34, 53, 0.08);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.78);
  }

  .arts-map-card-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0.8rem;
    max-height: 41rem;
    overflow: auto;
  }

  .arts-map-card {
    padding: 0.95rem;
    border: 1px solid rgba(19, 34, 53, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.88);
    transition: border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
  }

  .arts-map-card.is-active {
    border-color: rgba(14, 106, 97, 0.4);
    box-shadow: 0 16px 38px rgba(12, 24, 38, 0.08);
    transform: translateY(-1px);
  }

  .arts-map-card-hit {
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    color: inherit;
    cursor: pointer;
    text-align: left;
  }

  .arts-map-card-topline {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .arts-map-card-title {
    display: block;
    font-weight: 800;
    color: var(--ink);
  }

  .arts-map-card-area {
    flex: none;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: rgba(19, 34, 53, 0.06);
    color: var(--ink-soft);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .arts-map-card-address,
  .arts-map-card-orgs,
  .arts-map-card-note,
  .arts-map-card-static {
    display: block;
    color: var(--ink-soft);
    font-size: 0.85rem;
    line-height: 1.45;
  }

  .arts-map-card-orgs {
    margin-top: 0.25rem;
    font-weight: 700;
  }

  .arts-map-card-note {
    margin: 0.65rem 0 0;
  }

  .arts-map-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.8rem;
  }

  .arts-map-card-actions a,
  .arts-map-card-static {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.72rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .arts-map-card-actions a {
    background: rgba(14, 106, 97, 0.1);
    color: #0e5a53;
  }

  .arts-map-card-actions a:last-child {
    background: rgba(19, 34, 53, 0.07);
    color: var(--ink);
  }

  .arts-map-card-static {
    background: rgba(19, 34, 53, 0.07);
  }

  .arts-map-station-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1rem;
  }

  .arts-map-station-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.8rem;
    border-radius: 999px;
    background: rgba(19, 34, 53, 0.06);
  }

  .arts-map-station-name {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--ink);
  }

  .arts-map-station-lines {
    font-size: 0.74rem;
    color: var(--ink-soft);
    font-weight: 700;
  }

  .arts-map-popup {
    min-width: 14rem;
  }

  .arts-map-popup strong {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--ink);
  }

  .arts-map-popup p {
    margin: 0.35rem 0;
    color: var(--ink-soft);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .arts-map-popup a {
    color: #0d625a;
    font-weight: 700;
  }

  .arts-map-marker-shell,
  .arts-map-rail-shell {
    position: relative;
    display: block;
    width: 20px;
    height: 20px;
    box-shadow: 0 10px 24px rgba(12, 24, 38, 0.24);
  }

  .arts-map-marker-shell {
    border: 2px solid white;
    border-radius: 999px;
    transition: transform 140ms ease, box-shadow 140ms ease;
  }

  .arts-map-marker-shell-performance {
    background: linear-gradient(180deg, #0e6a61 0%, #084c45 100%);
  }

  .arts-map-marker-shell-museum {
    background: linear-gradient(180deg, #d4a63c 0%, #a77a1e 100%);
  }

  .arts-map-marker-shell-studio {
    background: linear-gradient(180deg, #697383 0%, #485060 100%);
  }

  .arts-map-marker-core,
  .arts-map-rail-core {
    position: absolute;
    inset: 4px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
  }

  .arts-map-marker-shell.is-active {
    transform: scale(1.18);
    box-shadow: 0 14px 28px rgba(12, 24, 38, 0.32);
  }

  .arts-map-rail-shell {
    border: 2px solid white;
    transform: rotate(45deg);
    background: linear-gradient(135deg, #2f73bd 0%, #1b5eaa 52%, #d1a646 52%, #d1a646 100%);
  }

  .arts-map-rail-shell-dual {
    background: linear-gradient(135deg, #2f73bd 0%, #1b5eaa 48%, #d1a646 48%, #d1a646 100%);
  }

  .arts-map-rail-core {
    inset: 5px;
    transform: rotate(-45deg);
  }

  @media (max-width: 980px) {
    .arts-map-grid {
      grid-template-columns: 1fr;
    }

    .arts-map-card-list {
      max-height: none;
    }
  }

  @media (max-width: 640px) {
    .arts-map-shell {
      padding: 1rem;
      border-radius: 22px;
    }

    .arts-map-card-topline {
      flex-direction: column;
      gap: 0.45rem;
    }

    .arts-map-canvas {
      min-height: 18rem;
    }
  }
</style>