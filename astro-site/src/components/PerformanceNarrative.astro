---
import { performanceNarrative as data } from '../lib/performanceNarrative';

const pastPanels = data.panels.filter((p) => p.category === 'Reflect on the past');
const futurePanels = data.panels.filter((p) => p.category === 'Plan for the future');
---

<section class="pn" data-pn aria-label="Performance narrative dossier">
  <div class="pn-grid" aria-hidden="true"></div>
  <div class="pn-glow pn-glow-a" aria-hidden="true"></div>
  <div class="pn-glow pn-glow-b" aria-hidden="true"></div>

  <header class="pn-strip">
    <div class="pn-strip-id">
      <span class="pn-eyebrow">Performance Narrative</span>
      <h2 class="pn-name">{data.identity.name}</h2>
      <p class="pn-role">{data.identity.role} &middot; {data.identity.org}</p>
      <div class="pn-id-meta">
        <span class="pn-chip pn-chip-ghost">{data.identity.level}</span>
        <span class="pn-chip pn-chip-ghost">{data.identity.period}</span>
        <span class="pn-chip pn-chip-ghost">{data.identity.periodMonths} months</span>
      </div>
    </div>

    <div class="pn-strip-quota" role="note" aria-label="Quota summary">
      <span class="pn-quota-label">Quota</span>
      <p class="pn-quota-line">{data.identity.quotaSummary}</p>
    </div>
  </header>

  <section class="pn-equation" aria-label="Impact equation">
    <p class="pn-equation-headline">{data.framing.headline}</p>
    <div class="pn-equation-body">
      <div class="pn-axis pn-axis-what">
        <span class="pn-axis-label">What</span>
        <p>{data.framing.what}</p>
      </div>

      <div class="pn-orbit" aria-hidden="true">
        <svg viewBox="0 0 220 220">
          <defs>
            <radialGradient id="pn-core" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#5fb8a6" stop-opacity="0.95" />
              <stop offset="60%" stop-color="#1c4f73" stop-opacity="0.9" />
              <stop offset="100%" stop-color="#0c1c2e" stop-opacity="1" />
            </radialGradient>
          </defs>
          <circle cx="110" cy="110" r="74" fill="url(#pn-core)" />
          <g class="pn-orbit-ring pn-orbit-ring-1">
            <circle cx="110" cy="110" r="86" fill="none" stroke="#5fb8a6" stroke-width="1.6" stroke-dasharray="2 6" opacity="0.65" />
          </g>
          <g class="pn-orbit-ring pn-orbit-ring-2">
            <circle cx="110" cy="110" r="98" fill="none" stroke="#3a7fb8" stroke-width="1.4" stroke-dasharray="3 9" opacity="0.5" />
          </g>
          <text x="109" y="106" text-anchor="middle" fill="#eafff8" font-size="14" font-weight="600" letter-spacing="2" font-family="'Inter', sans-serif">WHAT</text>
          <text x="109" y="126" text-anchor="middle" fill="#eafff8" font-size="14" font-weight="600" letter-spacing="2" font-family="'Inter', sans-serif">HOW</text>
          <line x1="78" y1="114" x2="142" y2="114" stroke="#eafff8" stroke-width="1" opacity="0.4" />
        </svg>
      </div>

      <div class="pn-axis pn-axis-how">
        <span class="pn-axis-label">How</span>
        <p>{data.framing.how}</p>
      </div>
    </div>
  </section>

  <div class="pn-section">
    <header class="pn-section-header">
      <span class="pn-section-rule" aria-hidden="true"></span>
      <h3 class="pn-section-title">Reflect on the past</h3>
      <span class="pn-section-rule" aria-hidden="true"></span>
    </header>

    {pastPanels.map((panel) => (
      <article class="pn-panel" id={panel.id}>
        <header class="pn-panel-header">
          <span class="pn-panel-numeral">{panel.numeral}</span>
          <div class="pn-panel-heading">
            <span class="pn-panel-eyebrow">Prompt {panel.numeral}</span>
            <h4 class="pn-panel-question">{panel.question}</h4>
            {panel.helper && <p class="pn-panel-helper">{panel.helper}</p>}
          </div>
        </header>

        <div class="pn-panel-body">
          {panel.narrative.map((para) => <p class="pn-panel-para">{para}</p>)}
        </div>

        {panel.zones && panel.zones.length > 0 && (
          <details class="pn-evidence" open>
            <summary>
              <span class="pn-evidence-label">Supporting evidence</span>
              <span class="pn-evidence-hint">specific, scrubbed wins</span>
            </summary>

            <div class="pn-zones">
              {panel.zones.map((zone) => (
                <section
                  class={`pn-zone pn-zone-${zone.id}`}
                  style={`--zone-hue:${zone.hue};--zone-hue-soft:${zone.hueSoft};--zone-hue-deep:${zone.hueDeep};`}
                  aria-label={zone.title}
                >
                  <header class="pn-zone-header">
                    <span class="pn-zone-roman">{zone.eyebrow}</span>
                    <div>
                      <h5 class="pn-zone-title">{zone.title}</h5>
                      <p class="pn-zone-framing">{zone.framing}</p>
                    </div>
                  </header>

                  <div class="pn-cards">
                    {zone.cards.map((c) => (
                      <article class="pn-card">
                        <div class="pn-card-metric">
                          <span class="pn-card-metric-num">{c.metric}</span>
                          {c.sub && <span class="pn-card-metric-sub">{c.sub}</span>}
                        </div>
                        <div class="pn-card-body">
                          <p class="pn-card-segment">{c.segment}</p>
                          <p class="pn-card-narrative">{c.narrative}</p>
                          {c.tags && c.tags.length > 0 && (
                            <div class="pn-card-tags">
                              {c.tags.map((t) => <span class="pn-tag">{t}</span>)}
                            </div>
                          )}
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </details>
        )}
      </article>
    ))}
  </div>

  <div class="pn-section">
    <header class="pn-section-header">
      <span class="pn-section-rule" aria-hidden="true"></span>
      <h3 class="pn-section-title">Plan for the future</h3>
      <span class="pn-section-rule" aria-hidden="true"></span>
    </header>

    {futurePanels.map((panel) => (
      <article class="pn-panel" id={panel.id}>
        <header class="pn-panel-header">
          <span class="pn-panel-numeral pn-panel-numeral-future">{panel.numeral}</span>
          <div class="pn-panel-heading">
            <span class="pn-panel-eyebrow pn-panel-eyebrow-future">Prompt {panel.numeral}</span>
            <h4 class="pn-panel-question">{panel.question}</h4>
            {panel.helper && <p class="pn-panel-helper">{panel.helper}</p>}
          </div>
        </header>

        <div class="pn-panel-body">
          {panel.narrative.map((para) => <p class="pn-panel-para">{para}</p>)}
        </div>
      </article>
    ))}
  </div>

  <footer class="pn-footnote">
    Customer-identifiable details are anonymized. Numbers are estimated finishes for the Oct 2025 - Apr 2026 review window.
  </footer>
</section>

<style>
  .pn {
    position: relative;
    isolation: isolate;
    color: #eafff8;
    background: radial-gradient(ellipse at top, #142436 0%, #0a1422 60%, #060d18 100%);
    border-radius: 18px;
    padding: clamp(1.4rem, 3vw, 2.6rem);
    overflow: hidden;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .pn-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(95, 184, 166, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(95, 184, 166, 0.06) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 80%);
    z-index: 0;
    pointer-events: none;
  }

  .pn-glow {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    filter: blur(100px);
    z-index: 0;
    pointer-events: none;
    opacity: 0.55;
  }
  .pn-glow-a { top: -120px; left: -80px; background: #1c4f73; }
  .pn-glow-b { bottom: -160px; right: -100px; background: #3f8a55; }

  /* Flow children sit above the decoration layers */
  .pn-strip,
  .pn-equation,
  .pn-section,
  .pn-footnote { position: relative; z-index: 1; }

  /* ---------- Identity strip ---------- */
  .pn-strip {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(95, 184, 166, 0.18);
  }
  .pn-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #5fb8a6;
    font-weight: 600;
  }
  .pn-name {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.4rem 0 0.2rem;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: #ffffff;
  }
  .pn-role {
    margin: 0;
    color: #b3c5d3;
    font-size: 1rem;
  }
  .pn-id-meta {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pn-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .pn-chip-ghost {
    background: rgba(95, 184, 166, 0.08);
    border: 1px solid rgba(95, 184, 166, 0.22);
    color: #cfeee4;
  }

  .pn-strip-quota {
    max-width: 320px;
    padding: 0.9rem 1.1rem;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(95, 184, 166, 0.18), rgba(28, 79, 115, 0.18));
    border: 1px solid rgba(95, 184, 166, 0.32);
  }
  .pn-quota-label {
    display: block;
    font-size: 0.66rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #5fb8a6;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .pn-quota-line {
    margin: 0;
    font-family: 'Lora', serif;
    font-size: 1.05rem;
    line-height: 1.35;
    color: #ffffff;
    letter-spacing: -0.005em;
  }

  /* ---------- Equation ---------- */
  .pn-equation {
    margin: 1.8rem 0 2.2rem;
    padding: 2rem 1.4rem;
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(28, 79, 115, 0.35), rgba(12, 28, 46, 0.55));
    border: 1px solid rgba(95, 184, 166, 0.22);
    text-align: center;
  }
  .pn-equation-headline {
    margin: 0 auto 1.6rem;
    max-width: 38ch;
    font-family: 'Lora', serif;
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    line-height: 1.3;
    color: #ffffff;
    letter-spacing: -0.01em;
  }
  .pn-equation-body {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.4rem;
    max-width: 880px;
    margin: 0 auto;
  }
  .pn-axis { padding: 0 0.6rem; }
  .pn-axis-what { text-align: right; }
  .pn-axis-how { text-align: left; }
  .pn-axis-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .pn-axis-what .pn-axis-label { color: #5fb8a6; }
  .pn-axis-how .pn-axis-label { color: #f1b75f; }
  .pn-axis p {
    margin: 0;
    color: #d8e6f0;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .pn-orbit { width: 200px; height: 200px; }
  .pn-orbit svg { width: 100%; height: 100%; }
  .pn-orbit-ring-1 {
    transform-origin: 110px 110px;
    animation: pn-spin 28s linear infinite;
  }
  .pn-orbit-ring-2 {
    transform-origin: 110px 110px;
    animation: pn-spin 44s linear infinite reverse;
  }
  @keyframes pn-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ---------- Sections (Reflect on the past / Plan for the future) ---------- */
  .pn-section { margin-top: 2.4rem; }
  .pn-section-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }
  .pn-section-title {
    margin: 0;
    font-family: 'Lora', serif;
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    color: #ffffff;
    letter-spacing: -0.01em;
    text-align: center;
  }
  .pn-section-rule {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(95, 184, 166, 0.38), transparent);
  }

  /* ---------- Prompt panels ---------- */
  .pn-panel {
    position: relative;
    padding: 1.6rem 1.6rem 1.4rem;
    margin-bottom: 1.2rem;
    background: rgba(8, 16, 28, 0.55);
    border: 1px solid rgba(95, 184, 166, 0.22);
    border-radius: 14px;
    backdrop-filter: blur(2px);
  }
  .pn-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(95, 184, 166, 0.06), transparent 40%);
  }

  .pn-panel-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.1rem;
    align-items: start;
    margin-bottom: 1.1rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed rgba(95, 184, 166, 0.22);
  }
  .pn-panel-numeral {
    font-family: 'Lora', serif;
    font-size: 2.2rem;
    line-height: 1;
    color: #5fb8a6;
    font-weight: 700;
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(95, 184, 166, 0.55);
    border-radius: 10px;
    background: rgba(95, 184, 166, 0.08);
    letter-spacing: 0.08em;
    min-width: 3.2rem;
    text-align: center;
  }
  .pn-panel-numeral-future {
    color: #f1b75f;
    border-color: rgba(241, 183, 95, 0.55);
    background: rgba(241, 183, 95, 0.08);
  }
  .pn-panel-eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #5fb8a6;
    font-weight: 700;
    margin-bottom: 0.45rem;
  }
  .pn-panel-eyebrow-future { color: #f1b75f; }
  .pn-panel-question {
    margin: 0;
    font-family: 'Lora', serif;
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    line-height: 1.25;
    color: #ffffff;
    letter-spacing: -0.01em;
  }
  .pn-panel-helper {
    margin: 0.55rem 0 0;
    color: #9bb0c2;
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.4;
  }

  .pn-panel-body { display: grid; gap: 1rem; }
  .pn-panel-para {
    margin: 0;
    color: #e1ecf4;
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .pn-panel-para:first-child::first-letter {
    font-family: 'Lora', serif;
    font-size: 2.6rem;
    font-weight: 700;
    float: left;
    line-height: 1;
    margin: 0.15rem 0.55rem 0 0;
    color: #5fb8a6;
  }

  /* ---------- Evidence (collapsible impact zones) ---------- */
  .pn-evidence {
    margin-top: 1.4rem;
    border-top: 1px solid rgba(95, 184, 166, 0.18);
    padding-top: 1.1rem;
  }
  .pn-evidence > summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 1rem;
    user-select: none;
  }
  .pn-evidence > summary::-webkit-details-marker { display: none; }
  .pn-evidence > summary::before {
    content: '+';
    display: inline-grid;
    place-items: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    border: 1px solid rgba(95, 184, 166, 0.55);
    color: #5fb8a6;
    font-weight: 700;
    line-height: 1;
    transition: transform 0.25s ease;
  }
  .pn-evidence[open] > summary::before { content: '-'; transform: rotate(180deg); }
  .pn-evidence-label {
    font-size: 0.74rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #5fb8a6;
    font-weight: 700;
  }
  .pn-evidence-hint {
    font-size: 0.78rem;
    color: #9bb0c2;
    font-style: italic;
  }

  .pn-zones { display: grid; gap: 1rem; }
  .pn-zone {
    background: linear-gradient(180deg, var(--zone-hue-soft), rgba(8, 16, 28, 0.6));
    border: 1px solid var(--zone-hue);
    border-radius: 12px;
    padding: 1.2rem 1.2rem 1rem;
    box-shadow: 0 24px 60px -40px var(--zone-hue);
  }
  .pn-zone-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: start;
    margin-bottom: 0.9rem;
  }
  .pn-zone-roman {
    font-family: 'Lora', serif;
    font-size: 1.8rem;
    line-height: 1;
    color: var(--zone-hue);
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--zone-hue);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.25);
    letter-spacing: 0.08em;
  }
  .pn-zone-title {
    margin: 0;
    font-family: 'Lora', serif;
    font-size: 1.2rem;
    color: #ffffff;
    letter-spacing: -0.01em;
  }
  .pn-zone-framing {
    margin: 0.2rem 0 0;
    color: #b3c5d3;
    font-size: 0.86rem;
  }

  .pn-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.8rem;
  }
  .pn-card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: rgba(8, 16, 28, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .pn-card:hover {
    transform: translateY(-3px);
    border-color: var(--zone-hue);
    box-shadow: 0 16px 36px -22px var(--zone-hue);
  }
  .pn-card-metric {
    padding: 0.85rem 1rem 0.75rem;
    background: linear-gradient(135deg, var(--zone-hue) 0%, var(--zone-hue-deep) 100%);
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .pn-card-metric-num {
    display: block;
    font-family: 'Lora', serif;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .pn-card-metric-sub {
    display: block;
    margin-top: 0.18rem;
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.04em;
  }
  .pn-card-body { padding: 0.8rem 1rem 0.95rem; }
  .pn-card-segment {
    margin: 0 0 0.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--zone-hue);
    font-weight: 700;
  }
  .pn-card-narrative {
    margin: 0;
    color: #d8e6f0;
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .pn-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.65rem;
  }
  .pn-tag {
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #cfeee4;
  }

  /* ---------- Footnote ---------- */
  .pn-footnote {
    margin-top: 1.8rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(95, 184, 166, 0.18);
    font-size: 0.78rem;
    color: #8aa0b3;
    text-align: center;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 880px) {
    .pn-strip {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .pn-strip-quota { max-width: none; }
    .pn-equation-body {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .pn-axis-what, .pn-axis-how { text-align: center; }
    .pn-orbit { margin: 0 auto; }
    .pn-panel-header { grid-template-columns: 1fr; gap: 0.8rem; }
    .pn-panel-numeral { justify-self: start; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pn-orbit-ring-1, .pn-orbit-ring-2 { animation: none; }
  }
</style>
