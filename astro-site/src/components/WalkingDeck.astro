  .signal-cover,
  .human-section,
  .strengths-section,
  .essence-section,
  .passion-section,
  .recordings-section,
  .ask-section {
    scroll-margin-top: 7rem;
    margin-top: 1rem;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.76);
    box-shadow: 0 18px 46px rgba(12, 24, 38, 0.07);
  }

  .signal-cover {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.82fr);
    gap: 1rem;
    overflow: hidden;
    min-height: 33rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    color: white;
    background:
      linear-gradient(135deg, rgba(19, 34, 53, 0.98), rgba(14, 106, 97, 0.9) 66%, rgba(183, 121, 31, 0.84)),
      #132235;
  }

  .signal-canvas {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    opacity: 0.78;
  }

  .cover-copy {
    display: grid;
    align-content: center;
    gap: 1rem;
