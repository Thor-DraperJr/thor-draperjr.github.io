    text-transform: uppercase;
  }

  .recording-quote {
    margin: 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .recording-cite {
    display: grid;
    gap: 0.1rem;
    padding-top: 0.6rem;
    border-top: 1px dashed rgba(255, 255, 255, 0.18);
    font-style: normal;
  }

  .recording-cite strong {
    color: white;
    font-size: 0.9rem;
    font-weight: 850;
  }

  .recording-cite em {
    color: rgba(255, 255, 255, 0.55);
    font-style: normal;
    font-size: 0.76rem;
    letter-spacing: 0.04em;
  }

  .ask-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    color: white;
    background: linear-gradient(135deg, #132235, #1c4f73 58%, #0e6a61);
  }

  .ask-section .signal-kicker,
  .ask-section p {
    color: rgba(255, 255, 255, 0.82);
  }

  .ask-section h2 {
    color: white;
  }

  .signal-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 8px;
    color: white;
    font-weight: 900;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.11);
  }

  .signal-link:hover {
    background: rgba(255, 255, 255, 0.18);
  }

  @media (max-width: 980px) {
    .signal-cover,
    .ask-section {
      grid-template-columns: 1fr;
    }

    .recordings {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .walking-signal {
      width: min(calc(100vw - 1rem), 76rem);
    }

    .signal-rail {
      top: 4.5rem;
      flex-wrap: nowrap;
      justify-content: flex-start;
      width: 100%;
      padding: 0.3rem 0.4rem;
      border-radius: 8px;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .signal-rail::-webkit-scrollbar {
      display: none;
    }

    .signal-rail [data-rail-link] {
      flex: 0 0 auto;
      font-size: 0.74rem;
      padding: 0.4rem 0.65rem;
    }

    .present-toggle {
      flex: 0 0 auto;
      margin-left: auto;
      padding: 0.45rem 0.75rem;
      font-size: 0.72rem;
    }

    .signal-cover,
    .recordings,
    .ask-section {
      grid-template-columns: 1fr;
    }

    .signal-cover,
    .cover-photo {
      min-height: auto;
    }

    .cover-photo {
      min-height: 18rem;
    }
  }

  /* Pitch module */
  .pitch-module {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto auto;
    align-content: start;
    gap: 0.7rem;
    width: min(100%, 34rem);
    margin-top: 0.25rem;
    min-width: 0;
  }

  .pitch-mode {
    display: inline-flex;
    width: fit-content;
    padding: 0.18rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(8, 18, 30, 0.36);
    backdrop-filter: blur(8px);
  }

  .pitch-mode button {
    min-height: 2rem;
    padding: 0 0.75rem;
    border: 0;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.74);
    background: transparent;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .pitch-mode button:hover,
  .pitch-mode button:focus-visible {
    color: white;
    outline: none;
  }

  .pitch-mode button.is-active {
    color: var(--signal-ink);
    background: var(--signal-gold);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.22);
  }

  .pitch-view[hidden] {
    display: none !important;
  }

  .pitch-executive {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    padding: clamp(1rem, 2.2vw, 1.35rem);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    background:
      radial-gradient(circle at 92% 16%, rgba(241, 183, 95, 0.18), transparent 34%),
      linear-gradient(90deg, rgba(241, 183, 95, 0.12), transparent 18% 82%, rgba(14, 106, 97, 0.12)),
      linear-gradient(135deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.06)),
      rgba(8, 18, 30, 0.44);
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
  }

  .pitch-exec-head {
    display: grid;
    gap: 0.5rem;
  }

  .pitch-eyebrow {
    width: fit-content;
    padding: 0.28rem 0.55rem;
    border: 1px solid rgba(241, 183, 95, 0.36);
    border-radius: 999px;
    color: var(--signal-gold);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pitch-executive h3 {
    max-width: 24ch;
    color: white;
    font-size: clamp(1.35rem, 2.45vw, 2rem);
    line-height: 1.1;
  }

  .pitch-exec-summary {
    max-width: 58ch;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.86rem;
    line-height: 1.42;
  }

  .pitch-story {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding-top: 0.1rem;
  }

  .pitch-story::before {
    content: '';
    position: absolute;
    left: 1.1rem;
    right: 1.1rem;
    top: 1rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(241, 183, 95, 0.7), transparent);
    pointer-events: none;
  }

  .pitch-story-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    align-content: start;
    min-width: 0;
    padding: 0.1rem 0.15rem 0;
  }

  .pitch-story-index {
    display: grid;
    place-items: center;
    width: 1.55rem;
    height: 1.55rem;
    border: 1px solid rgba(241, 183, 95, 0.45);
    border-radius: 50%;
    color: var(--signal-gold);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.58rem;
    font-weight: 900;
    line-height: 1;
    background: rgba(8, 18, 30, 0.85);
  }

  .pitch-story-item div {
    display: grid;
    gap: 0.14rem;
    min-width: 0;
  }

  .pitch-story-label {
    color: rgba(241, 183, 95, 0.82);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .pitch-story-item strong {
    color: white;
    font-size: 0.86rem;
    font-weight: 900;
    line-height: 1.18;
  }

  .pitch-story-item p {
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.75rem;
    line-height: 1.35;
  }

  .pitch-thesis {
    position: relative;
    display: grid;
    gap: 0.3rem;
    margin-top: 0.2rem;
    padding: 0.78rem 0.92rem 0.82rem 1.05rem;
    border: 1px solid rgba(241, 183, 95, 0.46);
    border-left: 4px solid var(--signal-gold);
    border-radius: 8px;
    background:
      linear-gradient(110deg, rgba(241, 183, 95, 0.22), rgba(14, 106, 97, 0.22)),
      rgba(8, 18, 30, 0.58);
    box-shadow:
      inset 0 0 24px rgba(241, 183, 95, 0.08),
      0 14px 30px rgba(0, 0, 0, 0.16);
  }

  .pitch-thesis span {
    color: var(--signal-gold);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pitch-thesis p {
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.82rem;
    line-height: 1.42;
  }

  .pitch-thesis strong {
    color: white;
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .pitch-terminal {
    width: 100%;
    margin-top: 0;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    background: rgba(8, 18, 30, 0.72);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .pitch-terminal:not([hidden]) {
    display: flex;
    flex-direction: column;
  }

  .pitch-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .pitch-dots {
    display: inline-flex;
    gap: 0.3rem;
  }

  .pitch-dots i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.28);
  }

  .pitch-dots i:first-child { background: #ff6b6b; }
  .pitch-dots i:nth-child(2) { background: #f1b75f; }
  .pitch-dots i:last-child { background: #58d39c; }

  .pitch-title {
    flex: 1;
    color: rgba(255, 255, 255, 0.62);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }

  .pitch-skip {
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    color: rgba(255, 255, 255, 0.78);
    background: transparent;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .pitch-skip:hover {
    color: white;
    background: rgba(255, 255, 255, 0.12);
  }

  .pitch-stream {
    margin: 0;
    padding: 0.85rem 0.95rem 1rem;
    max-height: 14rem;
    overflow-y: auto;
    color: rgba(232, 240, 248, 0.94);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.84rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .pitch-stream code {
    background: transparent;
    color: inherit;
    font: inherit;
  }

  .pitch-cursor {
    display: inline-block;
    color: #f1b75f;
    font-weight: 900;
    animation: pitch-blink 1s steps(2) infinite;
  }

  @keyframes pitch-blink {
    50% { opacity: 0; }
  }

  /* Sphere grid (slide 5: Experience with Impact, FFX-style career sphere) */
  .sphere-section {
    margin-top: 1rem;
    padding: clamp(1rem, 3vw, 1.75rem);
    scroll-margin-top: 7rem;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 46px rgba(12, 24, 38, 0.07);
  }

  .sphere-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .sphere-stage {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1000 / 380;
    background:
      radial-gradient(circle at 18% 22%, rgba(241, 183, 95, 0.22), transparent 38%),
      radial-gradient(circle at 82% 78%, rgba(28, 79, 115, 0.36), transparent 50%),
      linear-gradient(135deg, #060e1c 0%, #0e1d31 50%, #0c1d2e 100%);
    isolation: isolate;
    box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.55);
  }

  .sphere-starfield {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 12% 22%, rgba(255,255,255,0.7), transparent 60%),
      radial-gradient(1.4px 1.4px at 28% 64%, rgba(180,210,255,0.55), transparent 60%),
      radial-gradient(1px 1px at 44% 18%, rgba(255,255,255,0.5), transparent 60%),
      radial-gradient(1.6px 1.6px at 58% 82%, rgba(241,183,95,0.55), transparent 60%),
      radial-gradient(1px 1px at 70% 36%, rgba(255,255,255,0.55), transparent 60%),
      radial-gradient(1.2px 1.2px at 82% 70%, rgba(255,255,255,0.45), transparent 60%),
      radial-gradient(1px 1px at 92% 14%, rgba(180,210,255,0.6), transparent 60%);
    animation: sphere-twinkle 6s ease-in-out infinite alternate;
  }

  @keyframes sphere-twinkle {
    0% { opacity: 0.55; }
    100% { opacity: 1; }
  }

  .sphere-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .sphere-bg-lines line {
    stroke: rgba(255, 255, 255, 0.07);
    stroke-width: 1;
    stroke-dasharray: 2 8;
  }

  .sphere-link {
    fill: none;
    stroke: rgba(255, 255, 255, 0.18);
    stroke-width: 2.4;
    stroke-dasharray: 6 8;
    transition: stroke 760ms ease, stroke-width 760ms ease, filter 760ms ease;
  }

  .sphere-link.is-lit {
    stroke: var(--signal-gold);
    stroke-width: 3;
    filter: drop-shadow(0 0 6px rgba(241, 183, 95, 0.85));
    animation: sphere-flow 2.2s linear infinite;
  }

  @keyframes sphere-flow {
    to { stroke-dashoffset: -28; }
  }

  /* Branch links on the stage (career/education/service threads) */
  .branch-link {
    fill: none;
    stroke: rgba(255, 255, 255, 0.0);
    stroke-width: 1.6;
    stroke-dasharray: 3 5;
    transition: stroke 360ms ease, filter 360ms ease;
  }

  .branch-link.is-lit.is-career { stroke: rgba(241, 183, 95, 0.85); filter: drop-shadow(0 0 4px rgba(241,183,95,0.7)); }
  .branch-link.is-lit.is-education { stroke: rgba(95, 184, 166, 0.85); filter: drop-shadow(0 0 4px rgba(95,184,166,0.7)); }
  .branch-link.is-lit.is-service { stroke: rgba(217, 122, 90, 0.85); filter: drop-shadow(0 0 4px rgba(217,122,90,0.7)); }

  /* Branch satellite nodes */
  .sphere-branch-nodes {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .sphere-branch {
    position: absolute;
    left: calc(var(--cx, 0) * 100% / 1000);
    top: calc(var(--cy, 0) * 100% / 420);
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    opacity: 0.35;
    filter: saturate(0.5) brightness(0.7);
    transition: opacity 360ms ease, filter 360ms ease;
  }

  .sphere-branch.is-lit { opacity: 1; filter: none; }

  .branch-dot {
    width: clamp(0.85rem, 1.3vw, 1.05rem);
    height: clamp(0.85rem, 1.3vw, 1.05rem);
    border-radius: 50%;
    background: radial-gradient(circle, white 0%, rgba(255,255,255,0.9) 30%, transparent 75%);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.4);
  }

  .sphere-branch.is-career .branch-dot { background: radial-gradient(circle, #fff7e2 0%, rgba(241,183,95,0.95) 35%, rgba(183,121,31,0.6) 70%, transparent 90%); box-shadow: 0 0 0 1px rgba(241,183,95,0.55), 0 0 12px rgba(241,183,95,0.45); }
  .sphere-branch.is-education .branch-dot { background: radial-gradient(circle, #e6fbf5 0%, rgba(95,184,166,0.95) 35%, rgba(20,90,80,0.6) 70%, transparent 90%); box-shadow: 0 0 0 1px rgba(95,184,166,0.55), 0 0 12px rgba(95,184,166,0.45); }
  .sphere-branch.is-service .branch-dot { background: radial-gradient(circle, #ffe6dc 0%, rgba(217,122,90,0.95) 35%, rgba(120,55,40,0.6) 70%, transparent 90%); box-shadow: 0 0 0 1px rgba(217,122,90,0.55), 0 0 12px rgba(217,122,90,0.45); }

  .branch-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: grid;
    text-align: center;
    white-space: nowrap;
    font-family: 'Manrope', sans-serif;
    pointer-events: none;
  }

  /* If branch sits in lower half, label below; if upper half, label above */
  .sphere-branch[style*="--cy:360"] .branch-label,
  .sphere-branch[style*="--cy:340"] .branch-label,
  .sphere-branch[style*="--cy:300"] .branch-label { top: 100%; transform: translate(-50%, 0.35rem); }
  .sphere-branch[style*="--cy:60"] .branch-label,
  .sphere-branch[style*="--cy:80"] .branch-label,
  .sphere-branch[style*="--cy:130"] .branch-label { bottom: 100%; transform: translate(-50%, -0.35rem); }

  .branch-label strong {
    max-width: 8rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: normal;
    line-height: 1.15;
  }

  .branch-label em { display: none; }

  .sphere-nodes {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sphere-node {
    position: absolute;
    left: calc(var(--cx, 0) * 100% / 1000);
    top: calc(var(--cy, 0) * 100% / 420);
    transform: translate(-50%, -50%);
  }

  .node-button {
    position: relative;
    width: clamp(3.2rem, 5.5vw, 4.4rem);
    height: clamp(3.2rem, 5.5vw, 4.4rem);
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: white;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 240ms ease;
  }

  .node-button:hover { transform: scale(1.06); }

  .node-button:focus-visible {
    outline: 2px solid var(--signal-gold);
    outline-offset: 6px;
  }

  .node-core {
    position: relative;
    width: 64%;
    height: 64%;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(241,183,95,0.85) 35%, rgba(183,121,31,0.7) 70%, rgba(19,34,53,0.9) 100%);
    box-shadow:
      0 0 0 2px rgba(241, 183, 95, 0.45),
      0 0 16px rgba(241, 183, 95, 0.4),
      inset 0 0 14px rgba(255, 255, 255, 0.5);
    color: rgba(19, 34, 53, 0.92);
    font-family: 'Lora', serif;
    font-size: clamp(0.75rem, 1.1vw, 0.95rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    filter: saturate(0.45) brightness(0.65);
    transition: filter 360ms ease, transform 360ms ease, box-shadow 360ms ease;
  }

  .node-button.is-lit .node-core {
    filter: saturate(1) brightness(1);
    box-shadow:
      0 0 0 2px rgba(241, 183, 95, 0.85),
      0 0 28px rgba(241, 183, 95, 0.7),
      inset 0 0 16px rgba(255, 255, 255, 0.6);
  }

  .node-button.is-active .node-core {
    transform: scale(1.12);
    box-shadow:
      0 0 0 2px rgba(255, 255, 255, 0.95),
      0 0 36px rgba(241, 183, 95, 1),
      0 0 64px rgba(241, 183, 95, 0.6),
      inset 0 0 18px rgba(255, 255, 255, 0.75);
    animation: sphere-pulse 2.4s ease-in-out infinite;
  }

  @keyframes sphere-pulse {
    0%, 100% { transform: scale(1.12); }
    50% { transform: scale(1.2); }
  }

  .node-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    pointer-events: none;
  }

  .node-button.is-lit .node-ring {
    border-color: rgba(241, 183, 95, 0.45);
  }

  .node-button.is-active .node-ring {
    border-color: rgba(241, 183, 95, 0.7);
    animation: sphere-ring-spin 6s linear infinite;
  }

  @keyframes sphere-ring-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .node-orbit {
    position: absolute;
    inset: -28%;
    border-radius: 50%;
    border: 1px dashed rgba(241, 183, 95, 0);
    pointer-events: none;
    transition: border-color 360ms ease;
  }

  .node-button.is-active .node-orbit {
    border-color: rgba(241, 183, 95, 0.45);
    animation: sphere-orbit 7s linear infinite reverse;
  }

  @keyframes sphere-orbit {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .node-label {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translate(-50%, 0.45rem);
    display: grid;
    text-align: center;
    white-space: nowrap;
    font-family: 'Manrope', sans-serif;
  }

  .node-label strong {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .node-label em {
    color: rgba(241, 183, 95, 0.78);
    font-style: normal;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .node-button.is-active .node-label strong { color: white; }
  .node-button.is-active .node-label em { color: var(--signal-gold); }

  /* Readout panel - wide HUD beneath the stage */
  .sphere-readout {
    position: relative;
    display: grid;
    grid-template-columns: minmax(11rem, 14rem) minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 1.1rem 1.4rem;
    padding: 1.15rem 1.25rem 1.25rem;
    border: 1px solid rgba(241, 183, 95, 0.4);
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(19, 34, 53, 0.96), rgba(8, 18, 30, 0.92));
    color: white;
    box-shadow: 0 16px 40px rgba(12, 24, 38, 0.18);
    overflow: hidden;
  }

  .sphere-readout::before {
    content: '';
    position: absolute;
    inset: 0;
