  .walking-signal[data-present='true'] .strengths-section h2,
  .walking-signal[data-present='true'] .passion-section h2,
  .walking-signal[data-present='true'] .recordings-section h2,
  .walking-signal[data-present='true'] .human-section h2,
  .walking-signal[data-present='true'] .sphere-section h2 {
