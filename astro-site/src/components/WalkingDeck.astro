---
import { branchLinks, chapters, imageSlots, linkPaths, slotExists } from '../lib/walkingDeck';

interface Props {
  startInPresent?: boolean;
}

const { startInPresent = false } = Astro.props;

const pitchTerminalLines = [
  { prompt: '$', text: 'whoami --short' },
  { out: 'Senior Security Solution Engineer at Microsoft. Career seller before that.' },
  { prompt: '$', text: 'cat origin.story | head' },
  { out: 'Prior to my career in tech, I started in sales, military service and entrepreneurship.' },
  { out: 'Branch Manager at Enterprise, leading a 40-plus team at the largest non-airport location.' },
  { out: 'Paychex sales, then bought a hometown gym. Studied IT certs while running the business.' },
  { out: 'Sold the gym just before the pandemic. MSP by day, cyber bootcamp instructor by night.' },
  { out: 'Microsoft contractor in April 2021. FTE that October. SANS B.P.S in Applied Cybersecurity in 2024 and moved to the Security STU shortly after that.' },
  { prompt: '$', text: 'echo $THESIS' },
  { out: 'I did not leave sales because I was burnt out. I loved it.' },
  { out: 'I rebuilt on technical depth so the next sales seat compounds everything.' },
  { prompt: '$', text: 'echo $NEXT' },
  { out: 'Account Executive in the AI era, then sales leadership.' },
  { prompt: '$', text: '_' },
];

const pitchStory = [
  {
    label: 'Sales operator',
    title: 'Sales, service, and ownership.',
    detail: 'Enterprise Branch Manager leading 40-plus people; Paychex seller; hometown gym owner.',
  },
  {
    label: 'Technical rebuild',
    title: 'MSP by day, cyber instructor by night.',
    detail: 'Sold the business and rebuilt deliberately around security depth.',
  },
  {
    label: 'Microsoft execution',
    title: 'Contractor to FTE to Security STU.',
    detail: 'H2 FY26: exceeded quota across all four buckets. 8-figure TCV E5, 7-figure Entra ID Governance, mid-6-figure DEX.',
  },
];
---

<section class="walking-signal" data-walking-signal data-present={startInPresent ? 'true' : undefined}>
  <nav class="signal-rail" aria-label="Walking deck sections">
    <a href="#signal-cover" data-rail-link>Cover</a>
    <a href="#signal-human" data-rail-link>Human</a>
    <a href="#signal-strengths" data-rail-link>Strengths</a>
    <a href="#signal-essence" data-rail-link>Essence</a>
    <a href="#signal-impact" data-rail-link>Impact</a>
    <a href="#signal-voices" data-rail-link>Voices</a>
    <a href="#signal-passion" data-rail-link>Passion</a>
    <a href="#signal-ask" data-rail-link>Ask</a>
    <button type="button" class="present-toggle" data-present-toggle aria-label="Enter presentation mode">&#9654; Present</button>
  </nav>

  <div class="present-hud" data-present-hud aria-hidden={startInPresent ? 'false' : 'true'}>
    <span class="present-counter" data-present-counter>Section 01 / 08</span>
    <span class="present-title" data-present-title>Cover</span>
    <div class="present-controls">
      <button type="button" class="present-btn" data-present-prev aria-label="Previous section">&lsaquo;</button>
      <button type="button" class="present-btn" data-present-next aria-label="Next section">&rsaquo;</button>
      <button type="button" class="present-btn present-btn-exit" data-present-exit aria-label="Exit presentation">Exit</button>
    </div>
  </div>

  <section class:list={[ 'signal-cover', startInPresent && 'is-current' ]} id="signal-cover" data-signal-section aria-labelledby="signal-cover-title">
    <canvas class="signal-canvas" data-signal-canvas aria-hidden="true"></canvas>
    <div class="cover-copy">
      <span class="signal-kicker">Thor Draper Jr &middot; Walking Deck</span>
      <h2 id="signal-cover-title" data-pretext-fit data-pretext-lines="3" data-pretext-min-ratio="0.55" data-pretext-width-ratio="0.62">A seller's instinct, rebuilt on technical depth.</h2>
      <p class="cover-role" aria-label="Senior Security Solution Engineer, Microsoft, Charlotte, NC"><span>Senior Security Solution Engineer, Microsoft</span><span>Charlotte, NC</span></p>

      <div class="pitch-module" data-pitch-shell data-pitch-mode="executive">
        <div class="pitch-mode" role="group" aria-label="Pitch display mode">
          <button type="button" class="is-active" data-pitch-mode-button="executive" aria-pressed="true" aria-controls="pitch-executive-view">Executive</button>
          <button type="button" data-pitch-mode-button="backend" aria-pressed="false" aria-controls="pitch-backend-view">Backend</button>
        </div>

        <div class="pitch-executive pitch-view" id="pitch-executive-view" data-pitch-executive>
          <div class="pitch-exec-head">
            <span class="pitch-eyebrow">Career signal</span>
            <h3 data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.78" data-pretext-width-ratio="0.68">I loved sales enough to rebuild the technical depth around it.</h3>
            <p class="pitch-exec-summary" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.86" data-pretext-width-ratio="0.72">Sales instinct, operator accountability, cybersecurity instruction, and Microsoft Security credibility in one motion.</p>
          </div>
          <div class="pitch-story" role="list">
            {pitchStory.map((item, index) => (
              <article class="pitch-story-item" role="listitem">
                <span class="pitch-story-index">{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <span class="pitch-story-label">{item.label}</span>
                  <strong>{item.title}</strong>
                  <p>{item.detail}</p>
                </div>
              </article>
            ))}
          </div>
          <div class="pitch-thesis">
            <span>Thesis</span>
            <p data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.84" data-pretext-width-ratio="0.72">I did not leave sales because I was burnt out. I rebuilt on technical depth so the next sales seat compounds.</p>
            <strong data-pretext-fit data-pretext-lines="1" data-pretext-min-ratio="0.82" data-pretext-width-ratio="0.72">Next: AE in the AI era, then sales leadership.</strong>
          </div>
        </div>

        <div class="pitch-terminal pitch-view" id="pitch-backend-view" data-pitch role="region" aria-label="Elevator pitch backend terminal" hidden>
          <header class="pitch-bar">
            <span class="pitch-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="pitch-title">~/career/elevator-pitch.sh</span>
            <button type="button" class="pitch-skip" data-pitch-skip aria-label="Skip typing animation">skip</button>
          </header>
          <pre class="pitch-stream" data-pitch-stream aria-live="polite"><code data-pitch-output></code><span class="pitch-cursor" aria-hidden="true">_</span></pre>
          <script type="application/json" data-pitch-script set:html={JSON.stringify({ lines: pitchTerminalLines })}></script>
        </div>
      </div>
    </div>

    <figure class:list={[ 'cover-photo', slotExists(imageSlots[0]) && 'has-image' ]}>
      {slotExists(imageSlots[0]) ? (
        <>
          <img src={imageSlots[0].src} alt={imageSlots[0].alt} loading="eager" />
          <figcaption class="cover-photo-caption">
            <strong>Thor Draper Jr</strong>
            <span>Senior Security Solution Engineer &middot; Microsoft</span>
          </figcaption>
        </>
      ) : (
        <div class="slot-placeholder">
          <span>{imageSlots[0].role}</span>
          <strong>{imageSlots[0].label}</strong>
          <code>{imageSlots[0].src}</code>
          <p>{imageSlots[0].note}</p>
        </div>
      )}
    </figure>
  </section>

  <section class="human-section" id="signal-human" data-signal-section aria-labelledby="signal-human-title">
    <div class="section-copy">
      <span class="signal-kicker">Section 02 &middot; The Human Behind the Headline</span>
      <h2 id="signal-human-title" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.62" data-pretext-width-ratio="1">The person behind the resume.</h2>
      <p data-pretext-fit data-pretext-lines="4" data-pretext-min-ratio="0.78" data-pretext-width-ratio="1">Charlotte native, back in uptown two blocks from the Belk Theater. Sports junkie: Panthers, Hornets, Yankees. Married my wife in Banff on 7/11 (her birthday plus mine). Our adopted mutt Lloyd handles the household charisma.</p>
    </div>

    <div class="photo-collage" aria-label="Photo collage">
      {imageSlots.slice(1).map((slot, index) => (
        <figure
          class:list={[ 'collage-card', slot.id, slotExists(slot) && 'has-image' ]}
          style={`--tilt: ${slot.tilt ?? 0}deg; --i: ${index};`}
        >
          {slotExists(slot) ? (
            <>
              <img src={slot.src} alt={slot.alt} loading="lazy" />
              {slot.caption && <figcaption>{slot.caption}</figcaption>}
            </>
          ) : (
            <div class="slot-placeholder">
              <span>{slot.role}</span>
              <strong>{slot.label}</strong>
              <code>{slot.src}</code>
              <p>{slot.note}</p>
            </div>
          )}
        </figure>
      ))}
    </div>
  </section>

  <section class="strengths-section" id="signal-strengths" data-signal-section aria-labelledby="signal-strengths-title">
    <div class="section-copy compact">
      <span class="signal-kicker">Section 03 &middot; Superpowers</span>
      <h2 id="signal-strengths-title" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.62" data-pretext-width-ratio="1">In plain English.</h2>
    </div>
    <ul class="strengths-list" role="list">
      <li><strong>I earn trust fast.</strong><span>Eight-figure TCV E5 platform displacement at a regional health system, won on operational efficiency and security outcomes.</span></li>
      <li><strong>I simplify the complex.</strong><span>Authored the AI Red Teaming workshop two regional user groups picked up and ran with their own communities.</span></li>
      <li><strong>I run things end to end.</strong><span>40-plus person Enterprise branch and a hometown gym P&amp;L sold before the pandemic.</span></li>
      <li><strong>I lift the team around the deal.</strong><span>Covered 60 accounts on a 24-account quota &mdash; load-bearing teammate on the largest closes of the year.</span></li>
      <li><strong>I keep showing up.</strong><span>Exceeded quota across all four revenue buckets this H2, with deals advanced as an overlay.</span></li>
    </ul>
  </section>

  <section class="essence-section" id="signal-essence" data-signal-section aria-labelledby="signal-essence-title">
    <span class="signal-kicker">Section 04 &middot; Brand Essence</span>
    <h2 id="signal-essence-title" data-pretext-fit data-pretext-lines="4" data-pretext-min-ratio="0.55" data-pretext-width-ratio="1">I'm a seller who learned the technology, so customers get the version of Microsoft that actually solves the problem.</h2>
  </section>

  <section class="sphere-section" id="signal-impact" data-signal-section aria-labelledby="signal-impact-title">
    <div class="section-copy compact">
      <span class="signal-kicker">Section 05 &middot; Experience with Impact</span>
      <h2 id="signal-impact-title" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.62" data-pretext-width-ratio="1">Three chapters. Each one carried its abilities forward.</h2>
      <p class="sphere-instruction" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.78" data-pretext-width-ratio="1">A career sphere grid. Click a node to load that chapter. Smaller satellites are the career, education, and service threads that branched off it.</p>
    </div>

    <div class="sphere-grid" data-sphere data-sphere-payload={JSON.stringify(chapters)}>
      <div class="sphere-stage">
        <div class="sphere-starfield" aria-hidden="true"></div>
        <svg class="sphere-svg" viewBox="0 0 1000 420" preserveAspectRatio="none" aria-hidden="true">
          <g class="sphere-bg-lines">
            <line x1="0" y1="105" x2="1000" y2="105"></line>
            <line x1="0" y1="210" x2="1000" y2="210"></line>
            <line x1="0" y1="315" x2="1000" y2="315"></line>
          </g>
          <g class="sphere-branch-links">
            {branchLinks.map((bl) => (
              <path class={`branch-link is-${bl.kind}`} data-branch-parent={bl.parent} d={bl.d}></path>
            ))}
          </g>
          <g class="sphere-links">
            {linkPaths.map((d, i) => (
              <path class="sphere-link" data-link={i} d={d}></path>
            ))}
          </g>
        </svg>
        <ul class="sphere-branch-nodes" role="list" aria-hidden="true">
          {chapters.flatMap((ch, i) =>
            ch.branches.map((b) => (
              <li class={`sphere-branch is-${b.kind}`} data-branch-parent={i} style={`--cx:${b.cx};--cy:${b.cy}`}>
                <span class="branch-dot"></span>
                <span class="branch-label"><strong>{b.label}</strong><em>{b.detail}</em></span>
              </li>
            ))
          )}
        </ul>
        <ol class="sphere-nodes" role="list">
          {chapters.map((ch, i) => (
            <li class="sphere-node" style={`--cx:${ch.cx};--cy:${ch.cy}`}>
              <button
                type="button"
                class:list={['node-button', i === 0 && 'is-active is-lit']}
                data-node-button={i}
                aria-label={`Chapter ${i + 1}: ${ch.tag}, ${ch.era}`}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <span class="node-orbit" aria-hidden="true"></span>
                <span class="node-ring" aria-hidden="true"></span>
                <span class="node-core" aria-hidden="true"><span>{ch.glyph}</span></span>
                <span class="node-label"><strong>{ch.tag}</strong><em>{ch.era}</em></span>
              </button>
            </li>
          ))}
        </ol>
      </div>

      <aside class:list={['sphere-readout', !chapters[0].image && 'no-portrait']} data-sphere-readout aria-live="polite">
        <div class="readout-col readout-col-portrait">
          <header class="readout-head">
            <span class="readout-counter"><strong data-readout-num>01</strong><em>/ 03</em></span>
            <div class="readout-titles">
              <span class="readout-tag" data-readout-tag>{chapters[0].tag}</span>
              <span class="readout-year" data-readout-year>{chapters[0].era}</span>
            </div>
          </header>
          <figure
            class="readout-portrait"
            data-readout-portrait
            hidden={!chapters[0].image}
            style={`--portrait-focus: ${chapters[0].imageFocus || 'center top'}`}
          >
            {chapters[0].image && <img src={chapters[0].image} alt="" loading="lazy" />}
          </figure>
        </div>

        <div class="readout-col readout-col-thesis">
          <h3 class="readout-question" data-readout-question data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.8" data-pretext-width-ratio="0.92">{chapters[0].headline}</h3>
          <div class="ability-banner" data-ability-banner>
            <span class="ability-flash">&#9650; Ability Unlocked</span>
            <strong class="ability-name" data-readout-ability data-pretext-fit data-pretext-lines="1" data-pretext-min-ratio="0.82" data-pretext-width-ratio="0.9">{chapters[0].ability}</strong>
            <span class="ability-detail" data-readout-ability-detail data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.84" data-pretext-width-ratio="0.94">{chapters[0].abilityDetail}</span>
          </div>
          <p class="readout-thesis" data-readout-thesis data-pretext-fit data-pretext-lines="4" data-pretext-min-ratio="0.82" data-pretext-width-ratio="0.96">{chapters[0].thesis}</p>
          <div class="readout-milestones" data-readout-milestones>
            {chapters[0].milestones.map((milestone) => <span>{milestone}</span>)}
          </div>
        </div>

        <div class="readout-col readout-col-meta">
          <ul class="readout-highlights" data-readout-highlights role="list">
            {chapters[0].highlights.map((h) => <li>{h}</li>)}
          </ul>
          <div class="readout-branches" data-readout-branches>
            {chapters[0].branches.map((b) => (
              <span class={`branch-chip is-${b.kind}`}>
                <em>{b.kind}</em>
                <strong>{b.label}</strong>
                <span>{b.detail}</span>
              </span>
            ))}
          </div>
        </div>

        <p class="sphere-pattern">Sales taught trust. Ownership taught risk. Teaching taught clarity. Microsoft is where they compound.</p>
      </aside>

      <ol class="sphere-mobile" role="list" aria-label="Career chapters (mobile view)">
        {chapters.map((ch, i) => (
          <li class={`mchapter is-${ch.id}`}>
            <header class="mchapter-head">
              <span class="mchapter-num">{String(i + 1).padStart(2, '0')}<em>/ 03</em></span>
              <span class="mchapter-glyph" aria-hidden="true">{ch.glyph}</span>
              <div class="mchapter-titles">
                <span class="mchapter-tag">{ch.tag}</span>
                <span class="mchapter-era">{ch.era}</span>
              </div>
            </header>
            <h3 class="mchapter-headline" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.82" data-pretext-width-ratio="1">{ch.headline}</h3>
            <div class="mchapter-ability">
              <span class="mchapter-ability-flash">&#9650; Ability Unlocked</span>
              <strong class="mchapter-ability-name" data-pretext-fit data-pretext-lines="1" data-pretext-min-ratio="0.84" data-pretext-width-ratio="0.94">{ch.ability}</strong>
              <span class="mchapter-ability-detail" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.84" data-pretext-width-ratio="0.96">{ch.abilityDetail}</span>
            </div>
            <div class="mchapter-milestones">
              {ch.milestones.map((milestone) => <span>{milestone}</span>)}
            </div>
            <p class="mchapter-thesis">{ch.thesis}</p>
            <ul class="mchapter-highlights" role="list">
              {ch.highlights.map((h) => <li>{h}</li>)}
            </ul>
            {ch.branches.length > 0 && (
              <div class="mchapter-branches">
                {ch.branches.map((b) => (
                  <span class={`mchapter-branch is-${b.kind}`}>
                    <em>{b.kind}</em>
                    <strong>{b.label}</strong>
                    <span>{b.detail}</span>
                  </span>
                ))}
              </div>
            )}
          </li>
        ))}
        <p class="mchapter-pattern">Sales taught trust. Ownership taught risk. Teaching taught clarity. Microsoft is where they compound.</p>
      </ol>
    </div>
  </section>

  <section class="recordings-section" id="signal-voices" data-signal-section aria-labelledby="signal-voices-title">
    <div class="section-copy">
      <span class="signal-kicker">Section 06 &middot; Voices Around the Work</span>
      <h2 id="signal-voices-title" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.6" data-pretext-width-ratio="1">Credibility compounds when other people say it for you.</h2>
      <p class="recordings-lede" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.78" data-pretext-width-ratio="1">Sphere recordings. Captured from Microsoft leadership, sales peers, and cross-org partners.</p>
    </div>

    <div class="recordings" role="list">
      <article class="recording" role="listitem" style="--rec-hue: 38;">
        <div class="recording-orb" aria-hidden="true">
          <span class="orb-glow"></span>
          <span class="orb-ring"></span>
          <span class="orb-initials">ES</span>
        </div>
        <div class="recording-body">
          <header class="recording-head">
            <span class="recording-role">Microsoft leader</span>
          </header>
          <p class="recording-quote">Thor consistently operates at the next level, demonstrating strong judgment and independence in complex, ambiguous environments. He translates emerging requirements into scalable, repeatable mechanisms that drive measurable impact across teams. His cross-functional influence and ability to create clarity where none exists elevate both execution and strategy.</p>
          <cite class="recording-cite"><strong>Erfan Setork</strong><em>Sr Solution Engineer Mgmt</em></cite>
        </div>
      </article>

      <article class="recording" role="listitem" style="--rec-hue: 168;">
        <div class="recording-orb" aria-hidden="true">
          <span class="orb-glow"></span>
          <span class="orb-ring"></span>
          <span class="orb-initials">CK</span>
        </div>
        <div class="recording-body">
          <header class="recording-head">
            <span class="recording-role">Sales security peer</span>
          </header>
          <p class="recording-quote">It is a privilege to work with Thor Draper as my Sr. Solution Engineer. Thor has excelled in his role as a Senior Solution Engineer specializing in security. Thor consistently demonstrates a deep understanding of complex security challenges and offers innovative solutions that deliver measurable results. His technical expertise is complemented by exceptional communication skills, allowing him to effectively translate technical concepts to stakeholders at all levels.</p>
          <cite class="recording-cite"><strong>Chad Krantz</strong><em>Sr. Security Specialist</em></cite>
        </div>
      </article>

      <article class="recording" role="listitem" style="--rec-hue: 200;">
        <div class="recording-orb" aria-hidden="true">
          <span class="orb-glow"></span>
          <span class="orb-ring"></span>
          <span class="orb-initials">KU</span>
        </div>
        <div class="recording-body">
          <header class="recording-head">
            <span class="recording-role">Cross-org technical teammate</span>
          </header>
          <p class="recording-quote">Your technical knowledge, easy-going personality and dependability &mdash; I know that if I reach out to for help with a customer of mine, you'll make yourself available to engage as needed. And likewise, I know that you have no hesitation in reaching out to me when you're seeking my input or opinion on a customer matter.</p>
          <cite class="recording-cite"><strong>Kevin Uy</strong><em>Principal Cloud Solution Architect</em></cite>
        </div>
      </article>
    </div>
  </section>

  <section class="passion-section" id="signal-passion" data-signal-section aria-labelledby="signal-passion-title">
    <div class="section-copy compact">
      <span class="signal-kicker">Section 07 &middot; Proof of Passion</span>
      <h2 id="signal-passion-title" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.62" data-pretext-width-ratio="1">Where the work shows up off-hours.</h2>
    </div>
    <div class="passion-grid">
      <article style="--passion-hue: 38;">
        <span class="passion-glyph" aria-hidden="true">&#9650;</span>
        <span class="passion-tag">Shipping</span>
        <h3>Built, not bought.</h3>
        <p>This blog and walking deck &mdash; Astro, custom interactions, no template. Proof I ship, not just pitch.</p>
        <span class="passion-stat">main &middot; deployed continuously</span>
      </article>
      <article style="--passion-hue: 168;">
        <span class="passion-glyph" aria-hidden="true">&#9670;</span>
        <span class="passion-tag">Speaking</span>
        <h3>Mic on, when it sharpens.</h3>
        <p>Community talks, internal Microsoft sessions, and panels. I take the mic when it sharpens the message or the audience.</p>
        <span class="passion-stat">internal &middot; external &middot; on demand</span>
      </article>
      <article style="--passion-hue: 200;">
        <span class="passion-glyph" aria-hidden="true">&#9679;</span>
        <span class="passion-tag">Writing</span>
        <h3>Public thinking.</h3>
        <p>Operator notes on security, AI, leadership, and career &mdash; published here on a steady cadence so the thinking stays public.</p>
        <span class="passion-stat">cadence &middot; steady</span>
      </article>
    </div>
  </section>

  <section class="ask-section" id="signal-ask" data-signal-section aria-labelledby="signal-ask-title">
    <div>
      <span class="signal-kicker">Section 08 &middot; The Ask</span>
      <h2 id="signal-ask-title" data-pretext-fit data-pretext-lines="2" data-pretext-min-ratio="0.6" data-pretext-width-ratio="1">An Account Executive seat, then sales leadership.</h2>
      <p data-pretext-fit data-pretext-lines="4" data-pretext-min-ratio="0.78" data-pretext-width-ratio="1">Near term: AE at Microsoft, where sales judgment, customer trust, and security and AI fluency compound. Mid term: sales leadership. Long term: GM and CVP-shaped seats.</p>
    </div>
    <a class="signal-link" href="/career/career-development-plan/">Open the career development plan</a>
  </section>
</section>

<script>
  import { initWalkingDeck } from '../scripts/walkingDeck.client';

  initWalkingDeck();
</script>

<style>
  .walking-signal {
    --signal-ink: #132235;
    --signal-muted: #526273;
    --signal-line: rgba(19, 34, 53, 0.13);
    --signal-accent: #0e6a61;
    --signal-gold: #b7791f;
    --signal-blue: #1c4f73;
    width: min(calc(100vw - 2rem), 76rem);
    margin: 2rem 0 2.5rem 50%;
    transform: translateX(-50%);
    color: var(--signal-ink);
    font-size: 0.98rem;
  }

  .walking-signal h2,
  .walking-signal h3,
  .walking-signal p {
    margin: 0;
    letter-spacing: 0;
  }

  .walking-signal h2,
  .walking-signal h3 {
    line-height: 1.08;
  }

  .walking-signal h2 {
    font-size: clamp(2rem, 4vw, 4rem);
  }

  .walking-signal h3 {
    font-size: clamp(1.5rem, 2.4vw, 2.15rem);
  }

  .walking-signal p {
    color: var(--signal-muted);
    line-height: 1.72;
  }

  .signal-kicker,
  .slot-placeholder span {
    display: block;
    color: var(--signal-accent);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .signal-rail {
    position: sticky;
    top: 5.25rem;
    z-index: 8;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    width: fit-content;
    max-width: 100%;
    margin: 0 auto 1rem;
    padding: 0.35rem;
    border: 1px solid var(--signal-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(16px);
    box-shadow: 0 14px 30px rgba(12, 24, 38, 0.08);
  }

  .signal-rail a {
    padding: 0.48rem 0.72rem;
    border-radius: 999px;
    color: var(--signal-muted);
    font-size: 0.82rem;
    font-weight: 850;
    text-decoration: none;
  }

  .signal-rail a:hover,
  .signal-rail a.is-active {
    color: white;
    background: var(--signal-ink);
  }

  .present-toggle {
    margin-left: 0.4rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--signal-gold);
    border-radius: 999px;
    background: var(--signal-gold);
    color: var(--signal-ink);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 200ms ease, color 200ms ease;
  }

  .present-toggle:hover,
  .present-toggle:focus-visible {
    background: var(--signal-ink);
    color: var(--signal-gold);
    outline: none;
  }

  /* Presentation HUD - hidden until present mode is active */
  .present-hud {
    --hud-counter-width: 10.75rem;
    --hud-title-width: 6.25rem;
    --hud-controls-width: 9.25rem;
    display: none;
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10001;
    align-items: center;
    grid-template-columns: var(--hud-counter-width) var(--hud-title-width) var(--hud-controls-width);
    gap: 0.65rem;
    max-width: calc(100vw - 1rem);
    box-sizing: border-box;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(241, 183, 95, 0.45);
    border-radius: 999px;
    background: rgba(8, 18, 30, 0.92);
    color: white;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .present-counter {
    color: var(--signal-gold);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    white-space: nowrap;
  }

  .present-title {
    min-width: 0;
    padding-left: 0.85rem;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .present-controls {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.35rem;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding-left: 0.6rem;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
  }

  .present-btn {
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    color: white;
    font: inherit;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .present-btn:hover,
  .present-btn:focus-visible {
    background: var(--signal-gold);
    color: var(--signal-ink);
    border-color: var(--signal-gold);
    outline: none;
  }

  .present-btn-exit {
    width: 4rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* Full-screen present mode */
  .walking-signal[data-present='true'] {
    position: fixed;
    inset: 0;
    z-index: 9000;
    width: 100vw;
    max-width: 100vw;
    height: 100vh;
    height: 100dvh;
    margin: 0;
    transform: none;
    padding: 4.75rem 4vw 1.5rem;
    box-sizing: border-box;
    background:
      radial-gradient(circle at 18% 22%, rgba(241, 183, 95, 0.18), transparent 38%),
      radial-gradient(circle at 82% 78%, rgba(28, 79, 115, 0.32), transparent 50%),
      linear-gradient(135deg, #060e1c 0%, #0e1d31 50%, #0c1d2e 100%);
    overflow: hidden;
  }

  .walking-signal[data-present='true'] .signal-rail {
    display: none;
  }

  .walking-signal[data-present='true'] .present-hud {
    display: grid;
  }

  .walking-signal[data-present='true'] [data-signal-section] {
    position: absolute;
    inset: 4.75rem 4vw 1.5rem;
    margin: 0;
    width: auto;
    max-width: none;
    box-sizing: border-box;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateX(60px);
    transition: opacity 320ms ease, transform 460ms cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }

  .walking-signal[data-present='true'][data-present-dir='back'] [data-signal-section] {
    transform: translateX(-60px);
  }

  /* When View Transitions take over, suppress our manual opacity/transform fallback
     (the browser captures snapshots and cross-fades them itself). */
  .walking-signal.using-view-transitions[data-present='true'] [data-signal-section] {
    transition: none !important;
    transform: none !important;
  }
  .walking-signal.using-view-transitions[data-present='true'] [data-signal-section]:not(.is-current) {
    opacity: 0;
  }
  .walking-signal.using-view-transitions[data-present='true'] [data-signal-section].is-current {
    opacity: 1;
  }

  /* Name persistent HUD elements so the browser morphs them between slides
     instead of cross-fading them. (The ::view-transition-* keyframes themselves
     live in the global style block at the bottom of this file.) */
  .walking-signal[data-present='true'] [data-present-title] {
    view-transition-name: deck-title;
  }
  .walking-signal[data-present='true'] [data-present-counter] {
    view-transition-name: deck-counter;
  }
  .walking-signal[data-present='true'] .present-controls {
    view-transition-name: deck-controls;
  }

  /* Kill all transitions/animations during viewport reflow so orientation changes
     don't leave fading ghosts of prior layout. */
  .walking-signal.is-resizing,
  .walking-signal.is-resizing *,
  .walking-signal.is-resizing *::before,
  .walking-signal.is-resizing *::after {
    transition: none !important;
    animation: none !important;
  }

  .walking-signal[data-present='true'] [data-signal-section].is-current {
    opacity: 1;
    pointer-events: auto;
    transform: none;
  }

  .walking-signal[data-present='true'] [data-signal-section].is-leaving {
    opacity: 0;
    transform: translateX(-60px);
  }

  .walking-signal[data-present='true'][data-present-dir='back'] [data-signal-section].is-leaving {
    transform: translateX(60px);
  }

  /* Make every section breathe inside the full-screen stage. */
  .walking-signal[data-present='true'] [data-signal-section] {
    padding: clamp(1.25rem, 3vw, 2.5rem);
  }

  /* Cover: oversize the terminal, right-size the portrait, fill the stage. */
  .walking-signal[data-present='true'] .signal-cover {
    grid-template-columns: minmax(0, 1.28fr) minmax(20rem, 0.95fr);
    gap: clamp(1.5rem, 3.2vw, 3rem);
    align-items: center;
    min-height: 0;
    padding: clamp(2.1rem, 3.7vw, 3.35rem) clamp(1.55rem, 3vw, 2.7rem) clamp(1.35rem, 2.4vw, 2.1rem);
  }

  .walking-signal[data-present='true'] .signal-cover .cover-copy {
    display: flex;
    flex-direction: column;
    gap: 0.72rem;
    justify-content: flex-start;
    min-height: 0;
  }

  .walking-signal[data-present='true'] .signal-cover .signal-kicker {
    color: rgba(241, 183, 95, 0.9);
  }

  .walking-signal[data-present='true'] .signal-cover h2 {
    position: relative;
    max-width: min(20ch, 100%);
    padding-bottom: 0.28rem;
    font-size: clamp(2.25rem, 4vw, 4.5rem);
    line-height: 1.04;
  }

  .walking-signal[data-present='true'] .signal-kicker {
    font-size: clamp(0.95rem, 1vw, 1.25rem);
  }

  .walking-signal[data-present='true'] .signal-cover h2::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: min(8rem, 42%);
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--signal-gold), rgba(241, 183, 95, 0));
  }

  .walking-signal[data-present='true'] .cover-role {
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(1.4rem, 1.6vw, 2rem);
    font-weight: 900;
  }

  .walking-signal[data-present='true'] .pitch-module {
    width: 100%;
    max-width: none;
    flex: 0 1 auto;
    min-height: 0;
  }

  .walking-signal[data-present='true'] .pitch-module[data-pitch-mode='backend'] {
    flex: 1;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .walking-signal[data-present='true'] .pitch-executive,
  .walking-signal[data-present='true'] .pitch-terminal:not([hidden]) {
    min-height: 0;
  }

  .walking-signal[data-present='true'] .pitch-stream {
    max-height: none;
    height: auto;
    flex: 1;
    font-size: clamp(1.1rem, 1.4vw, 1.65rem);
    line-height: 1.6;
    overflow: hidden;
  }

  .walking-signal[data-present='true'] .cover-photo {
    align-self: center;
    width: 100%;
    max-width: 38rem;
    max-height: min(86vh, 56rem);
    margin-left: auto;
    aspect-ratio: 4 / 5;
    min-height: 0;
    border-color: rgba(241, 183, 95, 0.48);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 32px 76px rgba(0, 0, 0, 0.48),
      0 0 62px rgba(241, 183, 95, 0.2);
  }

  .walking-signal[data-present='true'] .cover-photo img {
    object-position: center 20%;
  }

  .walking-signal[data-present='true'] .cover-photo::before {
    content: '';
    position: absolute;
    inset: 0.7rem;
    z-index: 1;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 6px;
    pointer-events: none;
  }

  .walking-signal[data-present='true'] [data-pretext-fit] {
    display: block;
    max-width: 100%;
    overflow-wrap: break-word;
  }

  @media (min-width: 761px) and (max-height: 820px) {
    .walking-signal[data-present='true'] .signal-cover {
      padding: clamp(1.55rem, 3vw, 2.15rem) clamp(1.35rem, 2.6vw, 2.2rem) clamp(1rem, 2vw, 1.45rem);
      gap: clamp(1rem, 2.4vw, 1.75rem);
    }

    .walking-signal[data-present='true'] .signal-cover .cover-copy {
      gap: 0.55rem;
    }

    .walking-signal[data-present='true'] .signal-cover h2 {
