  .collage-card.has-image {
    padding-bottom: 2.2rem;
  }

  /* Layout each card on the 12-col grid for an editorial collage feel */
  .collage-card.charlotte {
    grid-column: 1 / span 6;
    grid-row: span 4;
    --photo-pos: center 18%;
  }
  .collage-card.banff {
    grid-column: 7 / span 6;
    grid-row: span 5;
    --photo-pos: center 22%;
  }
  .collage-card.lloyd {
    grid-column: 1 / span 5;
    grid-row: span 4;
    --photo-pos: center 22%;
  }
  .collage-card.teacher {
    grid-column: 6 / span 7;
    grid-row: span 5;
    --photo-pos: center 55%;
  }

