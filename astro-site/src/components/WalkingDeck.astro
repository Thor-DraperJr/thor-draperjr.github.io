  .human-section,
  .strengths-section,
  .essence-section,
  .passion-section,
  .recordings-section,
  .ask-section {
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .section-copy {
    display: grid;
    gap: 0.75rem;
  }

  .section-copy.compact {
    max-width: 48rem;
  }

  .photo-collage {
    --collage-pad: clamp(0.5rem, 1.5vw, 1rem);
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 4.6rem;
    gap: var(--collage-pad);
    margin-top: 1.25rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    border-radius: 12px;
    background:
      radial-gradient(circle at 20% 15%, rgba(241, 183, 95, 0.14), transparent 45%),
      radial-gradient(circle at 80% 80%, rgba(28, 79, 115, 0.12), transparent 50%),
      linear-gradient(140deg, rgba(244, 238, 226, 0.92), rgba(255, 255, 255, 0.86));
    overflow: hidden;
  }

  .photo-collage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, rgba(19, 34, 53, 0.04) 0 1px, transparent 1px 24px),
      repeating-linear-gradient(90deg, rgba(19, 34, 53, 0.04) 0 1px, transparent 1px 24px);
    pointer-events: none;
    opacity: 0.55;
  }

  .collage-card {
    margin: 0;
    position: relative;
    padding: 0.6rem 0.6rem 0.7rem;
    background: white;
    border-radius: 4px;
    box-shadow:
      0 1px 0 rgba(19, 34, 53, 0.06),
      0 14px 28px -14px rgba(12, 24, 38, 0.45),
      0 28px 50px -28px rgba(12, 24, 38, 0.35);
    transform: rotate(var(--tilt, 0deg));
    transition: transform 240ms ease, box-shadow 240ms ease, z-index 0s 240ms;
    z-index: 1;
    overflow: hidden;
  }

  .collage-card:hover,
  .collage-card:focus-within {
    transform: rotate(0deg) translateY(-4px) scale(1.03);
    box-shadow:
      0 1px 0 rgba(19, 34, 53, 0.08),
      0 24px 38px -16px rgba(12, 24, 38, 0.5),
      0 40px 70px -28px rgba(12, 24, 38, 0.4);
    z-index: 4;
    transition: transform 240ms ease, box-shadow 240ms ease, z-index 0s;
  }

  .collage-card::before {
    content: '';
    position: absolute;
    top: 0.35rem;
    left: 50%;
    width: 3.4rem;
    height: 0.85rem;
    background: rgba(241, 183, 95, 0.55);
    border-radius: 2px;
    transform: translateX(-50%) rotate(-1deg);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
    z-index: 2;
    pointer-events: none;
  }

  .collage-card img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: var(--photo-pos, center 25%);
    border-radius: 2px;
    background: rgba(19, 34, 53, 0.04);
  }

  .collage-card figcaption {
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.65rem;
    padding-top: 0.55rem;
    color: var(--signal-ink);
    font-family: 'Caveat', 'Segoe Script', cursive;
    font-size: clamp(0.95rem, 1.1vw, 1.1rem);
    line-height: 1.15;
    text-align: center;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.92) 35%);
  }

  .collage-card.has-image {
    padding-bottom: 2.2rem;
  }

  /* Layout each card on the 12-col grid for an editorial collage feel */
  .collage-card.charlotte {
    grid-column: 1 / span 6;
    grid-row: span 4;
    --photo-pos: center 18%;
  }
  .collage-card.banff {
    grid-column: 7 / span 6;
    grid-row: span 5;
    --photo-pos: center 22%;
  }
  .collage-card.lloyd {
    grid-column: 1 / span 5;
    grid-row: span 4;
    --photo-pos: center 22%;
  }
  .collage-card.teacher {
    grid-column: 6 / span 7;
    grid-row: span 5;
    --photo-pos: center 55%;
  }

  .collage-card .slot-placeholder {
    min-height: 12rem;
    height: 100%;
    border-radius: 2px;
  }

  @media (max-width: 880px) {
    .photo-collage {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 4rem;
    }
    .collage-card.charlotte,
    .collage-card.banff,
    .collage-card.lloyd,
    .collage-card.teacher {
      grid-column: span 6;
      grid-row: span 4;
    }
  }

  /* Sphere recordings (slide 6: voices around the work) */
  .recordings-lede {
    color: var(--signal-muted);
    max-width: 52ch;
  }

  .recordings {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .recording {
    --rec-color: hsl(var(--rec-hue, 38) 70% 60%);
    --rec-color-soft: hsl(var(--rec-hue, 38) 70% 60% / 0.18);
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.85rem;
    padding: 1.1rem 1.1rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    background:
      radial-gradient(circle at 0% 0%, var(--rec-color-soft), transparent 55%),
      linear-gradient(180deg, rgba(19, 34, 53, 0.96), rgba(8, 18, 30, 0.94));
    color: white;
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 14px 36px rgba(8, 18, 30, 0.22);
    transition: transform 240ms ease, box-shadow 240ms ease;
  }

  .recording::before {
    content: '\201C';
    position: absolute;
    top: -1.4rem;
    right: 0.4rem;
    font-family: 'Lora', serif;
    font-size: 9rem;
    line-height: 1;
    color: var(--rec-color);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }

  .recording::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid var(--rec-color);
    opacity: 0.28;
    pointer-events: none;
    box-shadow: inset 0 0 24px var(--rec-color-soft);
  }

  .recording:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 44px rgba(8, 18, 30, 0.32);
  }

  .recording-orb {
    position: relative;
    width: 3.2rem;
    height: 3.2rem;
    display: grid;
    place-items: center;
    z-index: 1;
  }

  .recording-orb .orb-glow {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, white 0%, var(--rec-color) 35%, transparent 75%);
    filter: blur(2px);
    opacity: 0.85;
  }

  .recording-orb .orb-ring {
    position: absolute;
    inset: -0.35rem;
    border-radius: 50%;
    border: 1px dashed var(--rec-color);
    opacity: 0.55;
    animation: orb-spin 12s linear infinite;
  }

  @keyframes orb-spin {
    to { transform: rotate(360deg); }
  }

  .recording-orb .orb-initials {
    position: relative;
    color: rgba(19, 34, 53, 0.92);
    font-family: 'Lora', serif;
    font-size: 0.95rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    z-index: 1;
  }

  .recording-body {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.65rem;
    align-content: start;
  }

  .recording-head {
    display: grid;
    gap: 0.15rem;
  }

  .recording-tag {
    color: var(--rec-color);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .recording-role {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .recording-quote {
    margin: 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .recording-cite {
    display: grid;
    gap: 0.1rem;
    padding-top: 0.6rem;
    border-top: 1px dashed rgba(255, 255, 255, 0.18);
    font-style: normal;
  }

  .recording-cite strong {
    color: white;
    font-size: 0.9rem;
    font-weight: 850;
  }

  .recording-cite em {
    color: rgba(255, 255, 255, 0.55);
    font-style: normal;
    font-size: 0.76rem;
    letter-spacing: 0.04em;
  }

  .ask-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    color: white;
    background: linear-gradient(135deg, #132235, #1c4f73 58%, #0e6a61);
  }

  .ask-section .signal-kicker,
  .ask-section p {
    color: rgba(255, 255, 255, 0.82);
  }

  .ask-section h2 {
    color: white;
  }

  .signal-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 8px;
    color: white;
    font-weight: 900;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.11);
  }

  .signal-link:hover {
    background: rgba(255, 255, 255, 0.18);
  }

  @media (max-width: 980px) {
    .signal-cover,
    .ask-section {
      grid-template-columns: 1fr;
    }

    .recordings {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .walking-signal {
      width: min(calc(100vw - 1rem), 76rem);
    }

    .signal-rail {
      top: 4.5rem;
      flex-wrap: nowrap;
      justify-content: flex-start;
      width: 100%;
      padding: 0.3rem 0.4rem;
      border-radius: 8px;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .signal-rail::-webkit-scrollbar {
      display: none;
    }

    .signal-rail [data-rail-link] {
      flex: 0 0 auto;
      font-size: 0.74rem;
      padding: 0.4rem 0.65rem;
    }

    .present-toggle {
      flex: 0 0 auto;
      margin-left: auto;
      padding: 0.45rem 0.75rem;
      font-size: 0.72rem;
    }

    .signal-cover,
    .recordings,
    .ask-section {
      grid-template-columns: 1fr;
    }

    .signal-cover,
    .cover-photo {
      min-height: auto;
    }

    .cover-photo {
      min-height: 18rem;
    }
  }

  /* Pitch terminal */
  .pitch-terminal {
    width: min(100%, 34rem);
    margin-top: 0.25rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    background: rgba(8, 18, 30, 0.72);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .pitch-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .pitch-dots {
    display: inline-flex;
    gap: 0.3rem;
  }

  .pitch-dots i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.28);
  }

  .pitch-dots i:first-child { background: #ff6b6b; }
  .pitch-dots i:nth-child(2) { background: #f1b75f; }
  .pitch-dots i:last-child { background: #58d39c; }

  .pitch-title {
    flex: 1;
    color: rgba(255, 255, 255, 0.62);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }

  .pitch-skip {
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    color: rgba(255, 255, 255, 0.78);
    background: transparent;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .pitch-skip:hover {
    color: white;
    background: rgba(255, 255, 255, 0.12);
  }

  .pitch-stream {
    margin: 0;
    padding: 0.85rem 0.95rem 1rem;
    max-height: 14rem;
    overflow-y: auto;
    color: rgba(232, 240, 248, 0.94);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.84rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .pitch-stream code {
    background: transparent;
    color: inherit;
    font: inherit;
  }

  .pitch-cursor {
    display: inline-block;
    color: #f1b75f;
    font-weight: 900;
    animation: pitch-blink 1s steps(2) infinite;
  }

  @keyframes pitch-blink {
    50% { opacity: 0; }
  }

  /* Sphere grid (slide 5: Experience with Impact, FFX-style career sphere) */
  .sphere-section {
    margin-top: 1rem;
    padding: clamp(1rem, 3vw, 1.75rem);
    scroll-margin-top: 7rem;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 46px rgba(12, 24, 38, 0.07);
  }

  .sphere-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .sphere-stage {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1000 / 380;
    background:
      radial-gradient(circle at 18% 22%, rgba(241, 183, 95, 0.22), transparent 38%),
      radial-gradient(circle at 82% 78%, rgba(28, 79, 115, 0.36), transparent 50%),
      linear-gradient(135deg, #060e1c 0%, #0e1d31 50%, #0c1d2e 100%);
    isolation: isolate;
    box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.55);
  }

  .sphere-starfield {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 12% 22%, rgba(255,255,255,0.7), transparent 60%),
      radial-gradient(1.4px 1.4px at 28% 64%, rgba(180,210,255,0.55), transparent 60%),
      radial-gradient(1px 1px at 44% 18%, rgba(255,255,255,0.5), transparent 60%),
      radial-gradient(1.6px 1.6px at 58% 82%, rgba(241,183,95,0.55), transparent 60%),
      radial-gradient(1px 1px at 70% 36%, rgba(255,255,255,0.55), transparent 60%),
      radial-gradient(1.2px 1.2px at 82% 70%, rgba(255,255,255,0.45), transparent 60%),
      radial-gradient(1px 1px at 92% 14%, rgba(180,210,255,0.6), transparent 60%);
    animation: sphere-twinkle 6s ease-in-out infinite alternate;
  }

  @keyframes sphere-twinkle {
    0% { opacity: 0.55; }
    100% { opacity: 1; }
  }

  .sphere-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .sphere-bg-lines line {
    stroke: rgba(255, 255, 255, 0.07);
    stroke-width: 1;
    stroke-dasharray: 2 8;
  }

  .sphere-link {
    fill: none;
    stroke: rgba(255, 255, 255, 0.18);
    stroke-width: 2.4;
    stroke-dasharray: 6 8;
    transition: stroke 360ms ease, stroke-width 360ms ease, filter 360ms ease;
  }

  .sphere-link.is-lit {
    stroke: var(--signal-gold);
    stroke-width: 3;
    filter: drop-shadow(0 0 6px rgba(241, 183, 95, 0.85));
    animation: sphere-flow 1.6s linear infinite;
  }

  @keyframes sphere-flow {
    to { stroke-dashoffset: -28; }
  }

  /* Branch links on the stage (career/education/service threads) */
  .branch-link {
    fill: none;
    stroke: rgba(255, 255, 255, 0.0);
    stroke-width: 1.6;
    stroke-dasharray: 3 5;
    transition: stroke 360ms ease, filter 360ms ease;
  }

  .branch-link.is-lit.is-career { stroke: rgba(241, 183, 95, 0.85); filter: drop-shadow(0 0 4px rgba(241,183,95,0.7)); }
  .branch-link.is-lit.is-education { stroke: rgba(95, 184, 166, 0.85); filter: drop-shadow(0 0 4px rgba(95,184,166,0.7)); }
  .branch-link.is-lit.is-service { stroke: rgba(217, 122, 90, 0.85); filter: drop-shadow(0 0 4px rgba(217,122,90,0.7)); }

  /* Branch satellite nodes */
  .sphere-branch-nodes {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .sphere-branch {
    position: absolute;
    left: calc(var(--cx, 0) * 100% / 1000);
    top: calc(var(--cy, 0) * 100% / 420);
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    opacity: 0.35;
    filter: saturate(0.5) brightness(0.7);
    transition: opacity 360ms ease, filter 360ms ease;
  }

  .sphere-branch.is-lit { opacity: 1; filter: none; }

  .branch-dot {
    width: clamp(0.85rem, 1.3vw, 1.05rem);
    height: clamp(0.85rem, 1.3vw, 1.05rem);
    border-radius: 50%;
    background: radial-gradient(circle, white 0%, rgba(255,255,255,0.9) 30%, transparent 75%);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.4);
  }

  .sphere-branch.is-career .branch-dot { background: radial-gradient(circle, #fff7e2 0%, rgba(241,183,95,0.95) 35%, rgba(183,121,31,0.6) 70%, transparent 90%); box-shadow: 0 0 0 1px rgba(241,183,95,0.55), 0 0 12px rgba(241,183,95,0.45); }
  .sphere-branch.is-education .branch-dot { background: radial-gradient(circle, #e6fbf5 0%, rgba(95,184,166,0.95) 35%, rgba(20,90,80,0.6) 70%, transparent 90%); box-shadow: 0 0 0 1px rgba(95,184,166,0.55), 0 0 12px rgba(95,184,166,0.45); }
  .sphere-branch.is-service .branch-dot { background: radial-gradient(circle, #ffe6dc 0%, rgba(217,122,90,0.95) 35%, rgba(120,55,40,0.6) 70%, transparent 90%); box-shadow: 0 0 0 1px rgba(217,122,90,0.55), 0 0 12px rgba(217,122,90,0.45); }

  .branch-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: grid;
    text-align: center;
    white-space: nowrap;
    font-family: 'Manrope', sans-serif;
    pointer-events: none;
  }

  /* If branch sits in lower half, label below; if upper half, label above */
  .sphere-branch[style*="--cy:360"] .branch-label,
  .sphere-branch[style*="--cy:340"] .branch-label,
  .sphere-branch[style*="--cy:300"] .branch-label { top: 100%; transform: translate(-50%, 0.35rem); }
  .sphere-branch[style*="--cy:60"] .branch-label,
  .sphere-branch[style*="--cy:80"] .branch-label,
  .sphere-branch[style*="--cy:130"] .branch-label { bottom: 100%; transform: translate(-50%, -0.35rem); }

  .branch-label strong {
    max-width: 8rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: normal;
    line-height: 1.15;
  }

  .branch-label em { display: none; }

  .sphere-nodes {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sphere-node {
    position: absolute;
    left: calc(var(--cx, 0) * 100% / 1000);
    top: calc(var(--cy, 0) * 100% / 420);
    transform: translate(-50%, -50%);
  }

  .node-button {
    position: relative;
    width: clamp(3.2rem, 5.5vw, 4.4rem);
    height: clamp(3.2rem, 5.5vw, 4.4rem);
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: white;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 240ms ease;
  }

  .node-button:hover { transform: scale(1.06); }

  .node-button:focus-visible {
    outline: 2px solid var(--signal-gold);
    outline-offset: 6px;
  }

  .node-core {
    position: relative;
    width: 64%;
    height: 64%;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(241,183,95,0.85) 35%, rgba(183,121,31,0.7) 70%, rgba(19,34,53,0.9) 100%);
    box-shadow:
      0 0 0 2px rgba(241, 183, 95, 0.45),
      0 0 16px rgba(241, 183, 95, 0.4),
      inset 0 0 14px rgba(255, 255, 255, 0.5);
    color: rgba(19, 34, 53, 0.92);
    font-family: 'Lora', serif;
    font-size: clamp(0.75rem, 1.1vw, 0.95rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    filter: saturate(0.45) brightness(0.65);
    transition: filter 360ms ease, transform 360ms ease, box-shadow 360ms ease;
  }

  .node-button.is-lit .node-core {
    filter: saturate(1) brightness(1);
    box-shadow:
      0 0 0 2px rgba(241, 183, 95, 0.85),
      0 0 28px rgba(241, 183, 95, 0.7),
      inset 0 0 16px rgba(255, 255, 255, 0.6);
  }

  .node-button.is-active .node-core {
    transform: scale(1.12);
    box-shadow:
      0 0 0 2px rgba(255, 255, 255, 0.95),
      0 0 36px rgba(241, 183, 95, 1),
      0 0 64px rgba(241, 183, 95, 0.6),
      inset 0 0 18px rgba(255, 255, 255, 0.75);
    animation: sphere-pulse 2.4s ease-in-out infinite;
  }

  @keyframes sphere-pulse {
    0%, 100% { transform: scale(1.12); }
    50% { transform: scale(1.2); }
  }

  .node-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    pointer-events: none;
  }

  .node-button.is-lit .node-ring {
    border-color: rgba(241, 183, 95, 0.45);
  }

  .node-button.is-active .node-ring {
    border-color: rgba(241, 183, 95, 0.7);
    animation: sphere-ring-spin 6s linear infinite;
  }

  @keyframes sphere-ring-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .node-orbit {
    position: absolute;
    inset: -28%;
    border-radius: 50%;
    border: 1px dashed rgba(241, 183, 95, 0);
    pointer-events: none;
    transition: border-color 360ms ease;
  }

  .node-button.is-active .node-orbit {
    border-color: rgba(241, 183, 95, 0.45);
    animation: sphere-orbit 7s linear infinite reverse;
  }

  @keyframes sphere-orbit {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .node-label {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translate(-50%, 0.45rem);
    display: grid;
    text-align: center;
    white-space: nowrap;
    font-family: 'Manrope', sans-serif;
  }

  .node-label strong {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .node-label em {
    color: rgba(241, 183, 95, 0.78);
    font-style: normal;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .node-button.is-active .node-label strong { color: white; }
  .node-button.is-active .node-label em { color: var(--signal-gold); }

  /* Readout panel - wide HUD beneath the stage */
  .sphere-readout {
    position: relative;
    display: grid;
    grid-template-columns: minmax(11rem, 14rem) minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 1.1rem 1.4rem;
    padding: 1.15rem 1.25rem 1.25rem;
    border: 1px solid rgba(241, 183, 95, 0.4);
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(19, 34, 53, 0.96), rgba(8, 18, 30, 0.92));
    color: white;
    box-shadow: 0 16px 40px rgba(12, 24, 38, 0.18);
    overflow: hidden;
  }

  .sphere-readout::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 90% -10%, rgba(241, 183, 95, 0.18), transparent 35%);
    pointer-events: none;
  }

  .readout-col {
    display: grid;
    gap: 0.7rem;
    align-content: start;
    min-width: 0;
  }

  .readout-col-portrait { grid-column: 1; }
  .readout-col-thesis { grid-column: 2; }
  .readout-col-meta { grid-column: 3; }

  .readout-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: center;
  }

  .readout-counter {
    display: grid;
    text-align: center;
    padding: 0.4rem 0.6rem;
    border: 1px solid rgba(241, 183, 95, 0.5);
    border-radius: 6px;
    background: rgba(241, 183, 95, 0.08);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    line-height: 1.05;
  }

  .readout-counter strong {
    color: var(--signal-gold);
    font-size: 1.05rem;
    font-weight: 900;
  }

  .readout-counter em {
    color: rgba(255, 255, 255, 0.5);
    font-style: normal;
    font-size: 0.66rem;
    margin-top: 0.1rem;
  }

  .readout-titles { display: grid; gap: 0.1rem; min-width: 0; }

  .readout-tag {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.95rem;
    font-weight: 850;
    letter-spacing: 0.04em;
  }

  .readout-year {
    color: var(--signal-gold);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .readout-question {
    margin: 0;
    font-family: 'Lora', serif;
    font-size: 1.15rem;
    line-height: 1.3;
    color: white;
  }

  .ability-banner {
    position: relative;
    display: grid;
    gap: 0.2rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid rgba(241, 183, 95, 0.55);
    border-radius: 6px;
    background: linear-gradient(110deg, rgba(241, 183, 95, 0.18), rgba(14, 106, 97, 0.18));
    overflow: hidden;
  }

  .ability-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.55) 50%, transparent 100%);
    transform: translateX(-120%);
    pointer-events: none;
  }

  .ability-banner.is-firing::after { animation: ability-sweep 900ms ease-out; }

  @keyframes ability-sweep {
    to { transform: translateX(120%); }
  }

  .ability-flash {
    color: var(--signal-gold);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .ability-name {
    color: white;
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .ability-banner.is-firing .ability-name {
    animation: ability-pop 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  @keyframes ability-pop {
    0% { transform: scale(0.85); opacity: 0; }
    60% { transform: scale(1.05); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  .ability-detail {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.82rem;
  }

  .readout-portrait {
    margin: 0;
    border: 1px solid rgba(241, 183, 95, 0.3);
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: rgba(0, 0, 0, 0.4);
  }

  .readout-portrait[hidden] { display: none; }

  .readout-portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--portrait-focus, center top);
    opacity: 0.95;
    filter: saturate(0.95) brightness(0.92);
  }

  .readout-thesis {
    margin: 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .readout-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }

  .readout-highlights li {
    position: relative;
    padding-left: 1.2rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.85rem;
    line-height: 1.45;
  }

  .readout-highlights li::before {
    content: '';
    position: absolute;
    left: 0.1rem;
    top: 0.5rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 1px;
    background: var(--signal-gold);
    transform: rotate(45deg);
    box-shadow: 0 0 8px rgba(241, 183, 95, 0.6);
  }

  .readout-branches {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .branch-chip {
    display: grid;
    gap: 0.18rem;
    padding: 0.55rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-left: 3px solid rgba(255, 255, 255, 0.28);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.05);
  }

  .branch-chip em {
    color: rgba(255, 255, 255, 0.55);
    font-style: normal;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

