  .recording {
    --rec-color: hsl(var(--rec-hue, 38) 70% 60%);
    --rec-color-soft: hsl(var(--rec-hue, 38) 70% 60% / 0.18);
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.85rem;
    padding: 1.1rem 1.1rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    background:
      radial-gradient(circle at 0% 0%, var(--rec-color-soft), transparent 55%),
      linear-gradient(180deg, rgba(19, 34, 53, 0.96), rgba(8, 18, 30, 0.94));
    color: white;
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 14px 36px rgba(8, 18, 30, 0.22);
    transition: transform 240ms ease, box-shadow 240ms ease;
  }

  .recording::before {
    content: '\201C';
    position: absolute;
    top: -1.4rem;
    right: 0.4rem;
    font-family: 'Lora', serif;
    font-size: 9rem;
    line-height: 1;
    color: var(--rec-color);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }

  .recording::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid var(--rec-color);
    opacity: 0.28;
    pointer-events: none;
    box-shadow: inset 0 0 24px var(--rec-color-soft);
