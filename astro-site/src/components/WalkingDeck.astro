    }

    .walking-signal[data-present='true'] .pitch-exec-summary {
      font-size: 0.76rem;
      line-height: 1.32;
    }

    .walking-signal[data-present='true'] .pitch-story {
      gap: 0.46rem;
    }

    .walking-signal[data-present='true'] .pitch-story-item {
      gap: 0.36rem;
      padding: 0.55rem;
    }

    .walking-signal[data-present='true'] .pitch-story-index {
