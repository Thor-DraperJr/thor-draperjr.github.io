  .photo-collage {
    --collage-pad: clamp(0.5rem, 1.5vw, 1rem);
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 4.6rem;
    gap: var(--collage-pad);
    margin-top: 1.25rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    border-radius: 12px;
    background:
      radial-gradient(circle at 20% 15%, rgba(241, 183, 95, 0.14), transparent 45%),
      radial-gradient(circle at 80% 80%, rgba(28, 79, 115, 0.12), transparent 50%),
      linear-gradient(140deg, rgba(244, 238, 226, 0.92), rgba(255, 255, 255, 0.86));
    overflow: hidden;
  }

  .photo-collage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, rgba(19, 34, 53, 0.04) 0 1px, transparent 1px 24px),
      repeating-linear-gradient(90deg, rgba(19, 34, 53, 0.04) 0 1px, transparent 1px 24px);
    pointer-events: none;
    opacity: 0.55;
  }

  .collage-card {
    margin: 0;
    position: relative;
    padding: 0.6rem 0.6rem 0.7rem;
    background: white;
    border-radius: 4px;
    box-shadow:
      0 1px 0 rgba(19, 34, 53, 0.06),
      0 14px 28px -14px rgba(12, 24, 38, 0.45),
      0 28px 50px -28px rgba(12, 24, 38, 0.35);
    transform: rotate(var(--tilt, 0deg));
    transition: transform 240ms ease, box-shadow 240ms ease, z-index 0s 240ms;
    z-index: 1;
    overflow: hidden;
  }

  .collage-card:hover,
  .collage-card:focus-within {
    transform: rotate(0deg) translateY(-4px) scale(1.03);
    box-shadow:
      0 1px 0 rgba(19, 34, 53, 0.08),
      0 24px 38px -16px rgba(12, 24, 38, 0.5),
      0 40px 70px -28px rgba(12, 24, 38, 0.4);
    z-index: 4;
    transition: transform 240ms ease, box-shadow 240ms ease, z-index 0s;
  }

  .collage-card::before {
    content: '';
    position: absolute;
    top: 0.35rem;
    left: 50%;
    width: 3.4rem;
    height: 0.85rem;
    background: rgba(241, 183, 95, 0.55);
    border-radius: 2px;
    transform: translateX(-50%) rotate(-1deg);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
    z-index: 2;
    pointer-events: none;
  }

  .collage-card img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: var(--photo-pos, center 25%);
    border-radius: 2px;
    background: rgba(19, 34, 53, 0.04);
