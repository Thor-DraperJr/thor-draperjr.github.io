        animation-range: entry 5% cover 30%;
      }
      @keyframes deck-card-rise {
        from { opacity: 0; transform: translateY(36px) scale(0.98); }
        to   { opacity: 1; transform: none; }
      }
    }
  }

  /* === Typographic polish: balanced wrapping for headlines, pretty for prose. === */
  .walking-signal h1,
  .walking-signal h2,
  .walking-signal h3,
  .walking-signal .mchapter-headline {
    text-wrap: balance;
