<style is:global>
  /* === View Transitions for present mode (must be global; pseudo-elements live
     on the document, not inside scoped components). === */
  ::view-transition-old(root) {
    animation: deck-vt-old 240ms cubic-bezier(0.4, 0, 1, 1) both;
  }
  ::view-transition-new(root) {
    animation: deck-vt-new 420ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  ::view-transition-old(deck-title),
  ::view-transition-new(deck-title),
  ::view-transition-old(deck-counter),
  ::view-transition-new(deck-counter) {
    animation-duration: 360ms;
    animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes deck-vt-old {
    to { opacity: 0; transform: scale(0.985); }
  }
  @keyframes deck-vt-new {
    from { opacity: 0; transform: scale(1.015); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root),
    ::view-transition-old(deck-title),
    ::view-transition-new(deck-title),
    ::view-transition-old(deck-counter),
    ::view-transition-new(deck-counter) {
      animation-duration: 1ms !important;
    }
  }

  /* === Scroll-driven reveals for the article view (not present mode). === */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .walking-signal:not([data-present='true']) [data-signal-section] {
        animation: deck-section-rise linear both;
        animation-timeline: view();
        animation-range: entry 5% cover 25%;
      }
      @keyframes deck-section-rise {
        from {
          opacity: 0;
          transform: translateY(48px);
          filter: blur(6px);
        }
        to {
          opacity: 1;
          transform: none;
          filter: blur(0);
        }
      }

      /* The career sphere gets a slow rotational lean as it crosses the viewport. */
      .walking-signal:not([data-present='true']) .sphere-stage svg {
        animation: deck-sphere-lean linear both;
        animation-timeline: view();
        animation-range: entry cover;
        transform-origin: 50% 50%;
      }
      @keyframes deck-sphere-lean {
        from { transform: rotate(-6deg) scale(0.94); }
        50%  { transform: rotate(0deg)  scale(1); }
        to   { transform: rotate(6deg)  scale(1); }
      }

      /* Headlines fade up as they enter. */
      .walking-signal:not([data-present='true']) [data-signal-section] > h1,
      .walking-signal:not([data-present='true']) [data-signal-section] > h2,
      .walking-signal:not([data-present='true']) [data-signal-section] .cover-copy h1,
      .walking-signal:not([data-present='true']) [data-signal-section] .cover-copy h2 {
        animation: deck-headline-rise linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 20%;
      }
      @keyframes deck-headline-rise {
        from { opacity: 0; transform: translateY(24px); letter-spacing: 0.02em; }
        to   { opacity: 1; transform: none; letter-spacing: normal; }
      }

      /* Mobile chapter cards reveal one by one as you scroll. */
      .walking-signal:not([data-present='true']) .sphere-mobile .mchapter {
        animation: deck-card-rise linear both;
