---
import fs from 'node:fs';
import path from 'node:path';

interface ImageSlot {
  id: string;
  label: string;
  src: string;
  alt: string;
  note: string;
  role: string;
  caption?: string;
  tilt?: number;
}

const publicRoot = path.join(process.cwd(), 'public');

const imageSlots: ImageSlot[] = [
  {
    id: 'portrait',
    label: 'Cover portrait',
    src: '/assets/images/posts/2026-05-01-walking-deck/hero-portrait.jpg',
    alt: 'Thor Draper Jr portrait',
    role: 'First impression',
    note: 'Professional photo or favorite candid that feels like you.',
  },
  {
    id: 'charlotte',
    label: 'Panthers draft day',
    src: '/assets/images/posts/2026-05-01-walking-deck/panthers-draft-day.JPG',
    alt: 'Thor on Panthers draft day in Charlotte',
    role: 'Charlotte',
    note: 'Charlotte moment - draft day, uptown, or Belk Theater.',
    caption: 'Charlotte. Panthers, Hornets, and a Yankees.',
    tilt: -2.4,
  },
  {
    id: 'banff',
    label: 'Banff wedding',
    src: '/assets/images/posts/2026-05-01-walking-deck/banff-wedding.jpg',
    alt: 'Thor and his wife in Banff',
    role: 'Family',
    note: 'The 7/11 story deserves a real visual anchor.',
    caption: 'Banff, 7/11.',
    tilt: 1.8,
  },
  {
    id: 'lloyd',
    label: 'Lloyd',
    src: '/assets/images/posts/2026-05-01-walking-deck/lloyd.jpg',
    alt: 'Lloyd the dog',
    role: 'Home life',
    note: 'The personality photo. Let it be charming.',
    caption: 'Lloyd. Household charisma director.',
    tilt: -3.2,
  },
  {
    id: 'teacher',
    label: 'Teaching and tech',
    src: '/assets/images/posts/2026-05-01-walking-deck/teaching-tech.png',
    alt: 'Teaching, technical work, or Microsoft community moment',
    role: 'Craft',
    note: 'Bootcamp teaching, Microsoft event, or technical community photo.',
    caption: 'Teaching cyber, the night job.',
    tilt: 2.6,
  },
];

function slotExists(slot: ImageSlot) {
  return fs.existsSync(path.join(publicRoot, slot.src.replace(/^\//, '')));
}

type BranchKind = 'career' | 'education' | 'service';

interface Branch {
  kind: BranchKind;
  label: string;
  detail: string;
  cx: number;
  cy: number;
}

interface Chapter {
  id: string;
  era: string;
  tag: string;
  glyph: string;
  headline: string;
  thesis: string;
  ability: string;
  abilityDetail: string;
  highlights: string[];
  branches: Branch[];
  cx: number;
  cy: number;
  image?: string;
  imageFocus?: string;
}

const chapterImage = (file: string): string | undefined => {
  const src = `/assets/images/posts/2026-05-01-walking-deck/${file}`;
  return fs.existsSync(path.join(publicRoot, src.replace(/^\//, ''))) ? src : undefined;
};

const chapters: Chapter[] = [
  {
    id: 'foundation',
    era: '2010 - 2019',
    tag: 'Sales, Ownership, Service',
    glyph: 'I',
    headline: 'A decade of selling, leading, and serving.',
    thesis: 'My previous career was all in sales: B2B, B2C, and a heavy influence of developing the team around me. Methodical, process-driven, and trained on a four-prong approach: take care of customers, take care of employees, growth and profits follow. All of it while serving in the Army National Guard as an E-4 Specialist, 11B Infantryman.',
    ability: 'Trust at Scale',
    abilityDetail: '+ Lead a 40+ team across full-time and part-time',
    highlights: [
      'B2B and B2C across Enterprise, Paychex, and gym ownership',
      'Managed 40+ team members, mix of full-time and part-time',
      'Four-prong approach: customers, employees, growth, profits',
    ],
    branches: [
      { kind: 'service', label: 'Army National Guard', detail: 'E-4 Specialist, 11B Infantryman', cx: 60, cy: 360 },
      { kind: 'education', label: 'Returned to education', detail: 'Re-engaged on degrees and certs', cx: 260, cy: 360 },
    ],
    cx: 160,
    cy: 230,
    image: chapterImage('military-thor.png'),
    imageFocus: 'center 18%',
  },
  {
    id: 'pivot',
    era: '2019 - 2021',
    tag: 'Pivot to Tech',
    glyph: 'II',
    headline: 'Sold the gym, picked up the MSP, and taught the bootcamp by night.',
    thesis: 'Sold the gym just before the pandemic. Took an MSP role and started studying IT certifications at the front desk. Earned an Associate of Science in Cloud and Virtualization from Central Piedmont Community College in July 2021. By night I taught a cybersecurity bootcamp, which forced me to explain the work without jargon.',
    ability: 'Teach to Sell',
    abilityDetail: '+ Explain it without jargon',
    highlights: [
      'MSP by day, cybersecurity bootcamp instructor by night',
      'CPCC A.S. in Cloud and Virtualization, July 2021',
      'Stacked industry certifications between client tickets',
    ],
    branches: [
      { kind: 'education', label: 'CPCC A.S.', detail: 'Cloud and Virtualization, July 2021', cx: 400, cy: 60 },
      { kind: 'career', label: 'Bootcamp instructor', detail: 'Cybersecurity, by night, in front of cohorts', cx: 600, cy: 60 },
    ],
    cx: 500,
    cy: 170,
    image: chapterImage('teaching-tech.png'),
    imageFocus: 'center top',
  },
  {
    id: 'microsoft',
    era: '2021 - now',
    tag: 'Microsoft + Range',
    glyph: 'III',
    headline: 'Built the technical depth on purpose so the next sales seat compounds everything.',
    thesis: 'Started at Microsoft as a contractor in April 2021 - Azure Networking Support Engineer. Converted to FTE in October 2021, supporting Azure Rapid Response in Azure Networking and then moving into Support Escalations Engineer. Now Senior Security Solution Engineer, with a SANS B.S. in cybersecurity earned on Microsoft tuition assistance. Doubled down on technical depth on purpose so the move back to sales lands with credibility, not a learning curve.',
    ability: 'Compounded Range',
    abilityDetail: '+ Sell with deep technical credibility',
    highlights: [
      'Azure Networking Support Engineer (contractor, Apr 2021)',
      'Azure Rapid Response + Support Escalations Engineer (FTE, Oct 2021)',
      'Senior Security Solution Engineer + SANS B.S. (Microsoft tuition assist)',
    ],
    branches: [
      { kind: 'education', label: 'SANS B.S.', detail: 'Cybersecurity, on Microsoft tuition assist', cx: 740, cy: 360 },
      { kind: 'career', label: 'AE-ready', detail: 'Next: Account Executive in the AI era', cx: 940, cy: 360 },
    ],
    cx: 840,
    cy: 230,
  },
];

const linkPaths = [
  'M160,230 Q330,70 500,170',
  'M500,170 Q670,70 840,230',
];

const branchLinks = chapters.flatMap((ch, i) =>
  ch.branches.map((b) => ({
    parent: i,
    kind: b.kind,
    d: `M${ch.cx},${ch.cy} Q${(ch.cx + b.cx) / 2},${(ch.cy + b.cy) / 2 + (b.cy > ch.cy ? -10 : 10)} ${b.cx},${b.cy}`,
  }))
);
---

<section class="walking-signal" data-walking-signal>
  <nav class="signal-rail" aria-label="Walking deck sections">
    <a href="#signal-cover" data-rail-link>Cover</a>
    <a href="#signal-human" data-rail-link>Human</a>
    <a href="#signal-strengths" data-rail-link>Strengths</a>
    <a href="#signal-essence" data-rail-link>Essence</a>
    <a href="#signal-impact" data-rail-link>Impact</a>
    <a href="#signal-voices" data-rail-link>Voices</a>
    <a href="#signal-passion" data-rail-link>Passion</a>
    <a href="#signal-ask" data-rail-link>Ask</a>
  </nav>

  <section class="signal-cover" id="signal-cover" data-signal-section aria-labelledby="signal-cover-title">
    <canvas class="signal-canvas" data-signal-canvas aria-hidden="true"></canvas>
    <div class="cover-copy">
      <span class="signal-kicker">Thor Draper Jr &middot; Walking Deck</span>
      <h2 id="signal-cover-title">A seller's instinct, rebuilt on technical depth.</h2>
      <p class="cover-role">Senior Security Solution Engineer, Microsoft &middot; Charlotte, NC</p>

      <div class="pitch-terminal" data-pitch role="region" aria-label="Elevator pitch terminal">
        <header class="pitch-bar">
          <span class="pitch-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="pitch-title">~/career/elevator-pitch.sh</span>
          <button type="button" class="pitch-skip" data-pitch-skip aria-label="Skip typing animation">skip</button>
        </header>
        <pre class="pitch-stream" data-pitch-stream aria-live="polite"><code data-pitch-output></code><span class="pitch-cursor" aria-hidden="true">_</span></pre>
        <script type="application/json" data-pitch-script>{"lines": [
          {"prompt": "$", "text": "whoami --short"},
          {"out": "Senior Security Solution Engineer at Microsoft. Career seller before that."},
          {"prompt": "$", "text": "cat origin.story | head"},
          {"out": "Prior to my career in tech, I started in sales, military service and entrepreneurship."},
          {"out": "Branch manager at Enterprise, largest non-airport location, 40+ team."},
          {"out": "Paychex sales, then bought a hometown gym. Studied IT certs while running the business."},
          {"out": "Sold the gym just before the pandemic. MSP by day, cyber bootcamp instructor by night."},
          {"out": "Microsoft contractor in April 2021. FTE that October. SANS B.P.S in Applied Cybersecurity in 2024 and moved to the Security STU shortly after that."},
          {"prompt": "$", "text": "echo $THESIS"},
          {"out": "I did not leave sales because I was burnt out. I loved it."},
          {"out": "I rebuilt on technical depth so the next sales seat compounds everything."},
          {"prompt": "$", "text": "echo $NEXT"},
          {"out": "Account Executive in the AI era, then sales leadership."},
          {"prompt": "$", "text": "_"}
        ]}</script>
      </div>
    </div>

    <figure class:list={[ 'cover-photo', slotExists(imageSlots[0]) && 'has-image' ]}>
      {slotExists(imageSlots[0]) ? (
        <img src={imageSlots[0].src} alt={imageSlots[0].alt} loading="eager" />
      ) : (
        <div class="slot-placeholder">
          <span>{imageSlots[0].role}</span>
          <strong>{imageSlots[0].label}</strong>
          <code>{imageSlots[0].src}</code>
          <p>{imageSlots[0].note}</p>
        </div>
      )}
    </figure>
  </section>

  <section class="human-section" id="signal-human" data-signal-section aria-labelledby="signal-human-title">
    <div class="section-copy">
      <span class="signal-kicker">02 &middot; The Human Behind the Headline</span>
      <h2 id="signal-human-title">The person behind the resume.</h2>
      <p>Charlotte native, back in uptown two blocks from the Belk Theater. Sports junkie: Panthers, Hornets, Yankees. Married my wife in Banff on 7/11 (her birthday plus mine). Our adopted mutt Lloyd handles the household charisma.</p>
    </div>

    <div class="photo-collage" aria-label="Photo collage">
      {imageSlots.slice(1).map((slot, index) => (
        <figure
          class:list={[ 'collage-card', slot.id, slotExists(slot) && 'has-image' ]}
          style={`--tilt: ${slot.tilt ?? 0}deg; --i: ${index};`}
        >
          {slotExists(slot) ? (
            <>
              <img src={slot.src} alt={slot.alt} loading="lazy" />
              {slot.caption && <figcaption>{slot.caption}</figcaption>}
            </>
          ) : (
            <div class="slot-placeholder">
              <span>{slot.role}</span>
              <strong>{slot.label}</strong>
              <code>{slot.src}</code>
              <p>{slot.note}</p>
            </div>
          )}
        </figure>
      ))}
    </div>
  </section>

  <section class="strengths-section" id="signal-strengths" data-signal-section aria-labelledby="signal-strengths-title">
    <div class="section-copy compact">
      <span class="signal-kicker">03 &middot; Superpowers</span>
      <h2 id="signal-strengths-title">In plain English.</h2>
    </div>
    <ul class="strengths-list" role="list">
      <li><strong>I earn trust fast.</strong><span>Career sales DNA, used to listen first.</span></li>
      <li><strong>I simplify the complex.</strong><span>Years teaching career changers shaped how I explain technical work.</span></li>
      <li><strong>I run things end to end.</strong><span>40-plus person Enterprise branch and a P&amp;L of my own.</span></li>
      <li><strong>I lift the team around the deal.</strong><span>Specialists, partners, execs &mdash; orchestrated, not herded.</span></li>
      <li><strong>I keep showing up.</strong><span>Five career reinventions. Every one made the next one work.</span></li>
    </ul>
  </section>

  <section class="essence-section" id="signal-essence" data-signal-section aria-labelledby="signal-essence-title">
    <span class="signal-kicker">04 &middot; Brand Essence</span>
    <h2 id="signal-essence-title">I'm a seller who learned the technology, so customers get the version of Microsoft that actually solves the problem.</h2>
  </section>

  <section class="sphere-section" id="signal-impact" data-signal-section aria-labelledby="signal-impact-title">
    <div class="section-copy compact">
      <span class="signal-kicker">05 &middot; Experience with Impact</span>
      <h2 id="signal-impact-title">Three chapters. Each one carried its abilities forward.</h2>
      <p>A career sphere grid. Click a node to load that chapter. Smaller satellites are the career, education, and service threads that branched off it.</p>
    </div>

    <div class="sphere-grid" data-sphere data-sphere-payload={JSON.stringify(chapters)}>
      <div class="sphere-stage">
        <div class="sphere-starfield" aria-hidden="true"></div>
        <svg class="sphere-svg" viewBox="0 0 1000 420" preserveAspectRatio="none" aria-hidden="true">
          <g class="sphere-bg-lines">
            <line x1="0" y1="105" x2="1000" y2="105"></line>
            <line x1="0" y1="210" x2="1000" y2="210"></line>
            <line x1="0" y1="315" x2="1000" y2="315"></line>
          </g>
          <g class="sphere-branch-links">
            {branchLinks.map((bl) => (
              <path class={`branch-link is-${bl.kind}`} data-branch-parent={bl.parent} d={bl.d}></path>
            ))}
          </g>
          <g class="sphere-links">
            {linkPaths.map((d, i) => (
              <path class="sphere-link" data-link={i} d={d}></path>
            ))}
          </g>
        </svg>
        <ul class="sphere-branch-nodes" role="list" aria-hidden="true">
          {chapters.flatMap((ch, i) =>
            ch.branches.map((b) => (
              <li class={`sphere-branch is-${b.kind}`} data-branch-parent={i} style={`--cx:${b.cx};--cy:${b.cy}`}>
                <span class="branch-dot"></span>
                <span class="branch-label"><strong>{b.label}</strong><em>{b.detail}</em></span>
              </li>
            ))
          )}
        </ul>
        <ol class="sphere-nodes" role="list">
          {chapters.map((ch, i) => (
            <li class="sphere-node" style={`--cx:${ch.cx};--cy:${ch.cy}`}>
              <button
                type="button"
                class:list={['node-button', i === 0 && 'is-active is-lit']}
                data-node-button={i}
                aria-label={`Chapter ${i + 1}: ${ch.tag}, ${ch.era}`}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <span class="node-orbit" aria-hidden="true"></span>
                <span class="node-ring" aria-hidden="true"></span>
                <span class="node-core" aria-hidden="true"><span>{ch.glyph}</span></span>
                <span class="node-label"><strong>{ch.tag}</strong><em>{ch.era}</em></span>
              </button>
            </li>
          ))}
        </ol>
      </div>

      <aside class:list={['sphere-readout', !chapters[0].image && 'no-portrait']} data-sphere-readout aria-live="polite">
        <div class="readout-col readout-col-portrait">
          <header class="readout-head">
            <span class="readout-counter"><strong data-readout-num>01</strong><em>/ 03</em></span>
            <div class="readout-titles">
              <span class="readout-tag" data-readout-tag>{chapters[0].tag}</span>
              <span class="readout-year" data-readout-year>{chapters[0].era}</span>
            </div>
          </header>
          <figure
            class="readout-portrait"
            data-readout-portrait
            hidden={!chapters[0].image}
            style={`--portrait-focus: ${chapters[0].imageFocus || 'center top'}`}
          >
            {chapters[0].image && <img src={chapters[0].image} alt="" loading="lazy" />}
          </figure>
        </div>

        <div class="readout-col readout-col-thesis">
          <h3 class="readout-question" data-readout-question>{chapters[0].headline}</h3>
          <div class="ability-banner" data-ability-banner>
            <span class="ability-flash">&#9650; Ability Unlocked</span>
            <strong class="ability-name" data-readout-ability>{chapters[0].ability}</strong>
            <span class="ability-detail" data-readout-ability-detail>{chapters[0].abilityDetail}</span>
          </div>
          <p class="readout-thesis" data-readout-thesis>{chapters[0].thesis}</p>
        </div>

        <div class="readout-col readout-col-meta">
          <ul class="readout-highlights" data-readout-highlights role="list">
            {chapters[0].highlights.map((h) => <li>{h}</li>)}
          </ul>
          <div class="readout-branches" data-readout-branches>
            {chapters[0].branches.map((b) => (
              <span class={`branch-chip is-${b.kind}`}>
                <em>{b.kind}</em>
                <strong>{b.label}</strong>
                <span>{b.detail}</span>
              </span>
            ))}
          </div>
        </div>

        <p class="sphere-pattern">Sales taught trust. Ownership taught risk. Teaching taught clarity. Microsoft is where they compound.</p>
      </aside>
    </div>
  </section>

  <section class="proof-section" id="signal-voices" data-signal-section aria-labelledby="signal-voices-title">
    <div class="section-copy">
      <span class="signal-kicker">06 &middot; Voices Around the Work</span>
      <h2 id="signal-voices-title">Credibility compounds when other people say it for you.</h2>
    </div>

    <div class="proof-grid">
      <blockquote>
        <span>Microsoft leader</span>
        <p>"Thor consistently operates at the next level, demonstrating strong judgment and independence in complex, ambiguous environments. He translates emerging requirements into scalable, repeatable mechanisms that drive measurable impact across teams. His cross-functional influence and ability to create clarity where none exists elevate both execution and strategy."</p>
        <cite>Erfan Setork, Sr Solution Engineer Mgmt</cite>
      </blockquote>
      <blockquote>
        <span>Sales security peer</span>
        <p>"It is a privilege to work with Thor Draper as my Sr. Solution Engineer. Thor has excelled in his role as a Senior Solution Engineer specializing in security. Thor consistently demonstrates a deep understanding of complex security challenges and offers innovative solutions that deliver measurable results. His technical expertise is complemented by exceptional communication skills, allowing him to effectively translate technical concepts to stakeholders at all levels."</p>
        <cite>Chad Krantz, Sr. Security Specialist</cite>
      </blockquote>
      <blockquote>
        <span>Cross Org Technical Teammate</span>
        <p>"Your technical knowledge, easy-going personality and dependability - I know that if I reach out to for help with a customer of mine, you'll make yourself available to engage as needed. And likewise, I know that you have no hesitation in reaching out to me when you're seeking my input or opinion on a customer matter."</p>
        <cite>Kevin Uy, Principal Cloud Solution Architect</cite>
      </blockquote>
    </div>
  </section>

  <section class="passion-section" id="signal-passion" data-signal-section aria-labelledby="signal-passion-title">
    <div class="section-copy compact">
      <span class="signal-kicker">07 &middot; Proof of Passion</span>
      <h2 id="signal-passion-title">Where the work shows up off-hours.</h2>
    </div>
    <div class="passion-grid">
      <article>
        <strong>Shipping</strong>
        <p>This blog and this walking deck are built, designed, and version-controlled by me &mdash; Astro, custom interactions, no template. Proof I ship, not just pitch.</p>
      </article>
      <article>
        <strong>Speaking</strong>
        <p>Community talks, internal Microsoft sessions, and panels. I take the mic when it sharpens the message or the audience.</p>
      </article>
      <article>
        <strong>Writing</strong>
        <p>Operator notes on security, AI, leadership, and career &mdash; published here on a steady cadence so the thinking stays public.</p>
      </article>
    </div>
  </section>

  <section class="ask-section" id="signal-ask" data-signal-section aria-labelledby="signal-ask-title">
    <div>
      <span class="signal-kicker">08 &middot; The Ask</span>
      <h2 id="signal-ask-title">An Account Executive seat, then sales leadership.</h2>
      <p>Near term: AE at Microsoft, where sales judgment, customer trust, and security and AI fluency compound. Mid term: sales leadership. Long term: GM and CVP-shaped seats.</p>
    </div>
    <a class="signal-link" href="/career/career-development-plan/">Open the career development plan</a>
  </section>
</section>

<script>
  (() => {
    const deck = document.querySelector('[data-walking-signal]');
    if (!deck) return;

    const railLinks = Array.from(deck.querySelectorAll('[data-rail-link]'));
    const sections = Array.from(deck.querySelectorAll('[data-signal-section]'));

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((left, right) => right.intersectionRatio - left.intersectionRatio)[0];

        if (!visible) return;

        railLinks.forEach((link) => {
          link.classList.toggle('is-active', link.getAttribute('href') === `#${visible.target.id}`);
        });
      }, { threshold: [0.24, 0.45, 0.65], rootMargin: '-15% 0px -55% 0px' });

      sections.forEach((section) => observer.observe(section));
    }

    const canvas = deck.querySelector('[data-signal-canvas]');
    const context = canvas instanceof HTMLCanvasElement ? canvas.getContext('2d') : null;
    if (!canvas || !context) return;

    const points = [
      { x: 0.12, y: 0.28, r: 2.5 },
      { x: 0.28, y: 0.18, r: 3.2 },
      { x: 0.47, y: 0.35, r: 2.4 },
      { x: 0.69, y: 0.22, r: 3.6 },
      { x: 0.86, y: 0.42, r: 2.8 },
      { x: 0.72, y: 0.7, r: 2.6 },
      { x: 0.4, y: 0.76, r: 3.4 },
      { x: 0.18, y: 0.62, r: 2.2 },
    ];

    let width = 0;
    let height = 0;
    let frame = 0;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const ratio = window.devicePixelRatio || 1;
      width = Math.max(1, rect.width);
      height = Math.max(1, rect.height);
      canvas.width = Math.floor(width * ratio);
      canvas.height = Math.floor(height * ratio);
      context.setTransform(ratio, 0, 0, ratio, 0, 0);
    };

    const draw = (time = 0) => {
      context.clearRect(0, 0, width, height);
      const pulse = prefersReducedMotion ? 0.5 : (Math.sin(time / 900) + 1) / 2;

      context.lineWidth = 1;
      for (let index = 0; index < points.length; index += 1) {
        const current = points[index];
        const next = points[(index + 1) % points.length];
        context.strokeStyle = `rgba(255, 255, 255, ${0.11 + pulse * 0.08})`;
        context.beginPath();
        context.moveTo(current.x * width, current.y * height);
        context.lineTo(next.x * width, next.y * height);
        context.stroke();
      }

      points.forEach((point, index) => {
        const radius = point.r + (index % 2 === 0 ? pulse * 1.8 : (1 - pulse) * 1.4);
        const x = point.x * width;
        const y = point.y * height;
        context.fillStyle = 'rgba(241, 183, 95, 0.9)';
        context.beginPath();
        context.arc(x, y, radius, 0, Math.PI * 2);
        context.fill();

        context.strokeStyle = 'rgba(255, 255, 255, 0.18)';
        context.beginPath();
        context.arc(x, y, radius + 9 + pulse * 7, 0, Math.PI * 2);
        context.stroke();
      });

      if (!prefersReducedMotion) {
        frame = window.requestAnimationFrame(draw);
      }
    };

    resize();
    draw();
    window.addEventListener('resize', () => {
      window.cancelAnimationFrame(frame);
      resize();
      draw();
    });

    // Sphere grid (slide 5): activate nodes in sequence, fire ABILITY UNLOCKED on each.
    const sphere = deck.querySelector('[data-sphere]');
    if (sphere) {
      let chapters = [];
      try { chapters = JSON.parse(sphere.dataset.spherePayload || '[]'); } catch (_e) { chapters = []; }
      const buttons = Array.from(sphere.querySelectorAll('[data-node-button]'));
      const links = Array.from(sphere.querySelectorAll('.sphere-link'));
      const branchNodes = Array.from(sphere.querySelectorAll('.sphere-branch'));
      const branchLinkEls = Array.from(sphere.querySelectorAll('.branch-link'));
      const banner = sphere.querySelector('[data-ability-banner]');
      const get = (sel) => sphere.querySelector(sel);
      const refs = {
        num: get('[data-readout-num]'),
        tag: get('[data-readout-tag]'),
        year: get('[data-readout-year]'),
        question: get('[data-readout-question]'),
        ability: get('[data-readout-ability]'),
        abilityDetail: get('[data-readout-ability-detail]'),
        thesis: get('[data-readout-thesis]'),
        highlights: get('[data-readout-highlights]'),
        branches: get('[data-readout-branches]'),
        portrait: get('[data-readout-portrait]'),
      };

      const setText = (el, text) => { if (el) el.textContent = text; };

      // Astro scopes CSS via a data-astro-cid-* attr; replicate it on JS-created nodes
      const findAstroAttr = (el) => {
        if (!el) return null;
        for (const a of el.attributes) { if (a.name.startsWith('data-astro-cid-')) return a.name; }
        return null;
      };
      const astroAttr = findAstroAttr(sphere);
      const tagAstro = (el) => { if (astroAttr) el.setAttribute(astroAttr, ''); };

      const activate = (idx, opts) => {
        const ch = chapters[idx]; if (!ch) return;
        buttons.forEach((b, i) => {
          b.classList.toggle('is-lit', i <= idx);
          b.classList.toggle('is-active', i === idx);
          b.setAttribute('aria-pressed', i === idx ? 'true' : 'false');
        });
        links.forEach((l, i) => l.classList.toggle('is-lit', i < idx));
        branchNodes.forEach((n) => {
          const isMine = Number(n.dataset.branchParent) === idx;
          n.classList.toggle('is-lit', isMine);
        });
        branchLinkEls.forEach((l) => {
          const isMine = Number(l.dataset.branchParent) === idx;
          l.classList.toggle('is-lit', isMine);
        });
        setText(refs.num, String(idx + 1).padStart(2, '0'));
        setText(refs.tag, ch.tag);
        setText(refs.year, ch.era);
        setText(refs.question, ch.headline);
        setText(refs.ability, ch.ability);
        setText(refs.abilityDetail, ch.abilityDetail);
        setText(refs.thesis, ch.thesis);
        if (refs.highlights) {
          refs.highlights.innerHTML = '';
          (ch.highlights || []).forEach((h) => {
            const li = document.createElement('li');
            tagAstro(li);
            li.textContent = h;
            refs.highlights.appendChild(li);
          });
        }
        if (refs.branches) {
          refs.branches.innerHTML = '';
          (ch.branches || []).forEach((b) => {
            const chip = document.createElement('span');
            chip.className = `branch-chip is-${b.kind}`;
            tagAstro(chip);
            const k = document.createElement('em'); k.textContent = b.kind; tagAstro(k);
            const lab = document.createElement('strong'); lab.textContent = b.label; tagAstro(lab);
            const det = document.createElement('span'); det.textContent = b.detail; tagAstro(det);
            chip.append(k, lab, det);
            refs.branches.appendChild(chip);
          });
        }
        if (refs.portrait) {
          if (ch.image) {
            let img = refs.portrait.querySelector('img');
            if (!img) {
              img = document.createElement('img');
              tagAstro(img);
              img.loading = 'lazy';
              img.alt = '';
              refs.portrait.appendChild(img);
            }
            if (img.getAttribute('src') !== ch.image) img.setAttribute('src', ch.image);
            refs.portrait.style.setProperty('--portrait-focus', ch.imageFocus || 'center top');
            refs.portrait.hidden = false;
            sphere.querySelector('[data-sphere-readout]')?.classList.remove('no-portrait');
          } else {
            refs.portrait.hidden = true;
            sphere.querySelector('[data-sphere-readout]')?.classList.add('no-portrait');
          }
        }
        if (banner && (!opts || opts.fire !== false)) {
          banner.classList.remove('is-firing');
          void banner.offsetWidth;
          banner.classList.add('is-firing');
        }
      };

      buttons.forEach((b, i) => b.addEventListener('click', () => activate(i)));

      let started = false;
      const intro = () => {
        if (started) return;
        started = true;
        if (prefersReducedMotion) { activate(chapters.length - 1, { fire: false }); return; }
        let i = 0;
        const tick = () => {
          activate(i);
          i++;
          if (i < chapters.length) window.setTimeout(tick, 1100);
        };
        tick();
      };
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { intro(); io.disconnect(); } });
        }, { threshold: 0.25 });
        io.observe(sphere);
      } else {
        intro();
      }
    }

    // Pitch terminal: typewriter animation with skip + reduced-motion support.
    const pitch = deck.querySelector('[data-pitch]');
    const output = pitch && pitch.querySelector('[data-pitch-output]');
    const scriptEl = pitch && pitch.querySelector('[data-pitch-script]');
    const stream = pitch && pitch.querySelector('[data-pitch-stream]');
    const skipBtn = pitch && pitch.querySelector('[data-pitch-skip]');

    if (pitch && output && scriptEl && stream) {
      let lines = [];
      try {
        const parsed = JSON.parse(scriptEl.textContent || '{}');
        lines = Array.isArray(parsed.lines) ? parsed.lines : [];
      } catch (_err) {
        lines = [];
      }

      const renderFinal = () => {
        output.textContent = lines.map((line) => {
          if (line.prompt) return `${line.prompt} ${line.text || ''}`;
          return line.out || '';
        }).join('\n');
      };

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let cancelled = false;
      let started = false;

      const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

      const typeLine = async (line) => {
        const text = line.prompt ? `${line.prompt} ${line.text || ''}` : (line.out || '');
        const speed = line.prompt ? 28 : 10;
        for (let i = 0; i < text.length; i += 1) {
          if (cancelled) return;
          output.append(text[i]);
          stream.scrollTop = stream.scrollHeight;
          // eslint-disable-next-line no-await-in-loop
          await sleep(speed);
        }
        if (cancelled) return;
        output.append('\n');
        stream.scrollTop = stream.scrollHeight;
        await sleep(line.prompt ? 220 : 80);
      };

      const run = async () => {
        if (started) return;
        started = true;
        if (reduced) {
          renderFinal();
          return;
        }
        for (const line of lines) {
          if (cancelled) break;
          // eslint-disable-next-line no-await-in-loop
          await typeLine(line);
        }
      };

      skipBtn && skipBtn.addEventListener('click', () => {
        cancelled = true;
        renderFinal();
        stream.scrollTop = stream.scrollHeight;
      });

      if ('IntersectionObserver' in window) {
        const pitchObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              run();
              pitchObserver.disconnect();
            }
          });
        }, { threshold: 0.25 });
        pitchObserver.observe(pitch);
      } else {
        run();
      }
    }
  })();
</script>

