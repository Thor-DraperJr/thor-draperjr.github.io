      height: 1.35rem;
      font-size: 0.52rem;
    }

    .walking-signal[data-present='true'] .pitch-story-label,
    .walking-signal[data-present='true'] .pitch-thesis span {
      font-size: 0.52rem;
    }

    .walking-signal[data-present='true'] .pitch-story-item strong {
