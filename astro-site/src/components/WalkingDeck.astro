    }

    .walking-signal[data-present='true'] .pitch-thesis {
      gap: 0.18rem;
      margin-top: 0.05rem;
      padding: 0.58rem 0.72rem 0.62rem 0.85rem;
    }

    .walking-signal[data-present='true'] .pitch-thesis p,
    .walking-signal[data-present='true'] .pitch-thesis strong {
      font-size: 0.68rem;
      line-height: 1.25;
    }

    .walking-signal[data-present='true'] .cover-photo {
      max-width: 31rem;
      max-height: min(68vh, 32rem);
    }

    .walking-signal[data-present='true'] .cover-photo-caption {
      padding: 1.1rem 0.85rem 0.75rem;
    }
  }

  /* Copy-only sections: distribute content vertically to fill the stage. */
  .walking-signal[data-present='true'] .strengths-section,
  .walking-signal[data-present='true'] .essence-section,
  .walking-signal[data-present='true'] .passion-section,
  .walking-signal[data-present='true'] .ask-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-evenly;
    text-align: center;
    gap: clamp(1.5rem, 3vh, 3rem);
    padding-block: clamp(2.5rem, 7vh, 6rem);
  }

  .walking-signal[data-present='true'] .strengths-section h2,
  .walking-signal[data-present='true'] .passion-section h2,
  .walking-signal[data-present='true'] .ask-section h2 {
    font-size: clamp(2.6rem, 4.2vw, 5.25rem);
    line-height: 1.1;
    max-width: 22ch;
  }

  .walking-signal[data-present='true'] .strengths-section .section-copy,
  .walking-signal[data-present='true'] .passion-section .section-copy {
    text-align: center;
    justify-items: center;
  }

  .walking-signal[data-present='true'] .strengths-list {
    width: min(100%, 72rem);
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
