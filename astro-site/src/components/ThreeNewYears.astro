---
// ThreeNewYears.astro
// FFX-style rotating sigil wheel for the "Three New Years, Three Words" post.
// Three custom glyphs orbit on a tilted ellipse; the front slot is the active mark.
// Drag the stage, use the prev/next runes, or let it auto-rotate. The active glyph
// slowly spins like a summoning sigil, and its word + date + days-away land in the card.

interface NewYearMark {
  id: 'personal' | 'relationship' | 'professional';
  label: string;
  word: string;
  dateLabel: string;
  month: number;
  day: number;
  tone: string;
  deepTone: string;
  glyph: 'knot' | 'star' | 'shard';
}

const marks: NewYearMark[] = [
  {
    id: 'professional',
    label: 'Professional',
    word: 'Uncomfortable',
    dateLabel: 'October 1',
    month: 10,
    day: 1,
    tone: '#5fb8a6',
    deepTone: '#1c4f73',
    glyph: 'shard',
  },
  {
    id: 'relationship',
    label: 'Relationship',
    word: 'Magical',
    dateLabel: 'July 11',
    month: 7,
    day: 11,
    tone: '#e08fb0',
    deepTone: '#a14a6e',
    glyph: 'star',
  },
  {
    id: 'personal',
    label: 'Personal',
    word: 'No loose ends',
    dateLabel: 'April 7',
    month: 4,
    day: 7,
    tone: '#f1b75f',
    deepTone: '#b7791f',
    glyph: 'knot',
  },
];

const markPayload = marks.map((m, i) => ({ ...m, slot: i }));
---

<section class="tny" aria-label="Three personal new years">
  <div class="tny-stage" data-stage>
    <div class="tny-stars" aria-hidden="true"></div>
    <div class="tny-floor" aria-hidden="true"></div>
    <div class="tny-pillar" aria-hidden="true"></div>

    <svg class="tny-defs" aria-hidden="true" focusable="false">
      <defs>
        <!-- Magical: two interlocking wedding bands with sparkles -->
        <g id="tny-glyph-star">
          <g stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" fill="none">
            <circle cx="-13" cy="2" r="15"/>
            <circle cx="13" cy="2" r="15"/>
            <g stroke-width="2.6" opacity="0.95">
              <path d="M -34,-26 L -34,-18 M -38,-22 L -30,-22"/>
              <path d="M 30,-30 L 30,-22 M 26,-26 L 34,-26"/>
              <path d="M 0,-36 L 0,-30 M -3,-33 L 3,-33" opacity="0.75"/>
            </g>
          </g>
        </g>

        <!-- Uncomfortable: arrow piercing the comfort zone -->
        <g id="tny-glyph-shard">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="0" cy="0" r="22" stroke-width="3" stroke-dasharray="3 6" opacity="0.7"/>
            <line x1="-34" y1="26" x2="32" y2="-30" stroke-width="3.6"/>
            <polyline points="14,-30 32,-30 32,-12" stroke-width="3.6"/>
            <path d="M -34,26 L -42,22 M -34,26 L -30,34" stroke-width="3" opacity="0.85"/>
          </g>
        </g>

        <!-- No loose ends: closed loop tied off, nothing dangling -->
        <g id="tny-glyph-knot">
          <g fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M 0,-22 C 18,-22 26,-10 26,4 C 26,16 16,22 0,22 C -16,22 -26,16 -26,4 C -26,-10 -18,-22 0,-22 Z"/>
            <path d="M -10,18 C -6,30 6,30 10,18"/>
            <path d="M -7,22 L 7,22" stroke-width="2.6"/>
            <path d="M -3,26 L 3,26" stroke-width="2.2" opacity="0.8"/>
          </g>
        </g>

        <g id="tny-rune-arrow">
          <path d="M3,-8 L-5,0 L3,8" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </g>
      </defs>
    </svg>

    <div class="tny-wheel" data-wheel>
      {marks.map((m, i) => (
        <button
          class="tny-orb"
          type="button"
          data-orb={m.id}
          data-slot={i}
          style={`--tone:${m.tone};--deep:${m.deepTone};`}
          aria-label={`${m.label} new year, ${m.dateLabel}, word ${m.word}`}
        >
          <span class="tny-orb-glow" aria-hidden="true"></span>
          <span class="tny-orb-disc" aria-hidden="true"></span>
          <svg class="tny-orb-glyph" viewBox="-50 -50 100 100" aria-hidden="true">
            <use href={`#tny-glyph-${m.glyph}`} />
          </svg>
          <span class="tny-orb-tag">{m.label}</span>
        </button>
      ))}
    </div>

    <div class="tny-controls">
      <button class="tny-nav" type="button" data-nav="prev" aria-label="Previous new year">
        <svg viewBox="-12 -12 24 24" aria-hidden="true"><use href="#tny-rune-arrow"/></svg>
      </button>
      <button class="tny-nav" type="button" data-nav="next" aria-label="Next new year">
        <svg viewBox="-12 -12 24 24" style="transform: scaleX(-1);" aria-hidden="true"><use href="#tny-rune-arrow"/></svg>
      </button>
    </div>

    <span class="tny-hint" data-hint>Drag the wheel</span>
  </div>

  <div class="tny-card" data-card>
    <div class="tny-card-meta-row">
      <span class="tny-card-eyebrow" data-card-eyebrow>Relationship · July 11</span>
      <span class="tny-card-status" data-card-status>Up next · 68 days</span>
    </div>
    <h3 class="tny-card-word" data-card-word>Magical</h3>
    <p class="tny-card-line" data-card-line>The word that anchors my relationship year.</p>
  </div>
</section>

<script is:inline define:vars={{ markPayload }}>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root || !root.classList.contains('tny')) return;

    const stage = root.querySelector('[data-stage]');
    const orbs = Array.from(root.querySelectorAll('[data-orb]'));
    const card = root.querySelector('[data-card]');
    const cardEyebrow = root.querySelector('[data-card-eyebrow]');
    const cardWord = root.querySelector('[data-card-word]');
    const cardStatus = root.querySelector('[data-card-status]');
    const cardLine = root.querySelector('[data-card-line]');
    const hint = root.querySelector('[data-hint]');

    const months = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334];
    const dayOfYear = (d) => months[d.getMonth()] + d.getDate();

    const lines = {
      personal: 'My personal year. The word: closing every loop I keep walking past.',
      relationship: 'My relationship year. The word: never coast on what matters most.',
      professional: 'My professional year. The word: stay in the rooms that stretch me.',
    };

    const SLOT_COUNT = markPayload.length;
    const STEP = 360 / SLOT_COUNT;
    const RX = 210;
    const FRONT_SCALE = 1;
    const BACK_SCALE = 0.45;

    let rotation = 0;
    let target = 0;
    let activeId = null;
    let lastInteraction = 0;
    let dragging = false;
    let dragStartX = 0;
    let dragStartTarget = 0;
    let dragMoved = false;
    let raf = null;

    function placeOrbs() {
      orbs.forEach((orb) => {
        const slot = Number(orb.getAttribute('data-slot'));
        const angleDeg = slot * STEP + rotation;
        const angleRad = (angleDeg * Math.PI) / 180;
        const x = Math.sin(angleRad) * RX;
        const depth = Math.cos(angleRad);
        const y = -depth * 14 - 10;
        const t = (depth + 1) / 2;
        const scale = BACK_SCALE + (FRONT_SCALE - BACK_SCALE) * t;
        const opacity = 0.32 + 0.68 * t;
        const z = Math.round(t * 100);
        orb.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
        orb.style.opacity = String(opacity);
        orb.style.zIndex = String(z);
      });
    }

    function activeSlot() {
      const slot = ((-target / STEP) % SLOT_COUNT + SLOT_COUNT) % SLOT_COUNT;
      return Math.round(slot) % SLOT_COUNT;
    }

    function updateCard() {
      const slot = activeSlot();
      const m = markPayload.find((x) => x.slot === slot);
      if (!m || m.id === activeId) return;
      activeId = m.id;

      orbs.forEach((orb) => {
        orb.classList.toggle('is-active', orb.getAttribute('data-orb') === m.id);
      });

      const now = new Date();
      const today = dayOfYear(now);
      const markDay = months[m.month - 1] + m.day;
      const delta = markDay >= today ? markDay - today : 365 - today + markDay;
      const status = delta === 0 ? 'Today' : `${delta} ${delta === 1 ? 'day' : 'days'} away`;

      card.classList.add('is-swapping');
      window.setTimeout(() => {
        cardEyebrow.textContent = `${m.label} new year · ${m.dateLabel}`;
        cardWord.textContent = m.word;
        cardStatus.textContent = status;
        cardLine.textContent = lines[m.id] || '';
        card.style.setProperty('--tone', m.tone);
        card.style.setProperty('--deep', m.deepTone);
        card.classList.remove('is-swapping');
      }, 180);
    }

    function snapTarget() {
      target = Math.round(target / STEP) * STEP;
    }

    function tick() {
      const now = performance.now();
      if (!dragging && now - lastInteraction > 4000) {
        target -= 0.18;
      }
      const delta = target - rotation;
      rotation += delta * 0.12;
      if (Math.abs(delta) < 0.01) rotation = target;
      placeOrbs();
      updateCard();
      raf = requestAnimationFrame(tick);
    }

    function bumpInteraction() {
      lastInteraction = performance.now();
      if (hint) hint.classList.add('is-hidden');
    }

    stage.addEventListener('pointerdown', (e) => {
      if (e.target.closest('.tny-nav')) return;
      dragging = true;
      dragMoved = false;
      dragStartX = e.clientX;
      dragStartTarget = target;
      try { stage.setPointerCapture(e.pointerId); } catch (_) {}
      stage.classList.add('is-dragging');
      bumpInteraction();
    });
    stage.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - dragStartX;
      if (Math.abs(dx) > 3) dragMoved = true;
      target = dragStartTarget + dx * 0.45;
      bumpInteraction();
    });
    stage.addEventListener('pointerup', (e) => {
      if (!dragging) return;
      dragging = false;
      stage.classList.remove('is-dragging');
      try { stage.releasePointerCapture(e.pointerId); } catch (_) {}
      snapTarget();
    });
    stage.addEventListener('pointercancel', () => {
      dragging = false;
      stage.classList.remove('is-dragging');
      snapTarget();
    });

    orbs.forEach((orb) => {
      orb.addEventListener('click', (e) => {
        if (dragMoved) {
          e.preventDefault();
          return;
        }
        const slot = Number(orb.getAttribute('data-slot'));
        target = -slot * STEP;
        bumpInteraction();
      });
    });

    root.querySelectorAll('[data-nav]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = btn.getAttribute('data-nav') === 'next' ? -1 : 1;
        target += dir * STEP;
        snapTarget();
        bumpInteraction();
      });
    });

    stage.setAttribute('tabindex', '0');
    stage.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') {
        target -= STEP;
        snapTarget();
        bumpInteraction();
      } else if (e.key === 'ArrowLeft') {
        target += STEP;
        snapTarget();
        bumpInteraction();
      }
    });

    const now = new Date();
    const today = dayOfYear(now);
    const sorted = markPayload
      .map((m) => ({
        ...m,
        delta: (months[m.month - 1] + m.day) >= today
          ? (months[m.month - 1] + m.day) - today
          : 365 - today + (months[m.month - 1] + m.day),
      }))
      .sort((a, b) => a.delta - b.delta);
    const startSlot = sorted[0].slot;
    target = -startSlot * STEP;
    rotation = target;
    placeOrbs();
    updateCard();

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              root.classList.add('is-ready');
              if (!raf) raf = requestAnimationFrame(tick);
              io.disconnect();
            }
          });
        },
        { threshold: 0.2 },
      );
      io.observe(root);
    } else {
      root.classList.add('is-ready');
      raf = requestAnimationFrame(tick);
    }
  })();
</script>

<style>
  .tny {
    width: min(100%, 64rem);
    margin: 2.5rem auto;
    display: grid;
    gap: 1rem;
  }

  .tny-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 360px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% 110%, rgba(241, 183, 95, 0.18), transparent 60%),
      radial-gradient(ellipse at 50% -20%, rgba(95, 184, 166, 0.18), transparent 55%),
      linear-gradient(180deg, #0a1729, #051023);
    box-shadow:
      inset 0 0 0 1px rgba(241, 183, 95, 0.18),
      inset 0 -60px 100px rgba(0, 0, 0, 0.55),
      0 30px 80px -30px rgba(0, 0, 0, 0.6);
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    outline: none;
  }
  .tny-stage.is-dragging {
    cursor: grabbing;
  }
  .tny-stage:focus-visible {
    box-shadow:
      inset 0 0 0 2px rgba(241, 183, 95, 0.55),
      inset 0 -60px 100px rgba(0, 0, 0, 0.55),
      0 30px 80px -30px rgba(0, 0, 0, 0.6);
  }

  .tny-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 12% 22%, rgba(255, 255, 255, 0.7), transparent 60%),
      radial-gradient(1.4px 1.4px at 28% 64%, rgba(180, 210, 255, 0.55), transparent 60%),
      radial-gradient(1px 1px at 44% 18%, rgba(255, 255, 255, 0.5), transparent 60%),
      radial-gradient(1.6px 1.6px at 58% 82%, rgba(241, 183, 95, 0.55), transparent 60%),
      radial-gradient(1px 1px at 70% 36%, rgba(255, 255, 255, 0.55), transparent 60%),
      radial-gradient(1.2px 1.2px at 82% 70%, rgba(255, 255, 255, 0.45), transparent 60%),
      radial-gradient(1px 1px at 92% 14%, rgba(180, 210, 255, 0.6), transparent 60%);
    opacity: 0.85;
    pointer-events: none;
  }

  .tny-floor {
    position: absolute;
    left: 50%;
    bottom: 6%;
    width: 78%;
    height: 24%;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(241, 183, 95, 0.16) 0%, rgba(241, 183, 95, 0.04) 40%, transparent 70%);
    border: 1px solid rgba(241, 183, 95, 0.22);
    box-shadow:
      0 0 24px rgba(241, 183, 95, 0.12),
      inset 0 0 32px rgba(241, 183, 95, 0.08);
    pointer-events: none;
  }
  .tny-floor::before,
  .tny-floor::after {
    content: '';
    position: absolute;
    inset: 8% 14%;
    border-radius: 50%;
    border: 1px dashed rgba(241, 183, 95, 0.28);
    pointer-events: none;
  }
  .tny-floor::after {
    inset: 22% 30%;
    border-style: solid;
    border-color: rgba(241, 183, 95, 0.18);
  }

  .tny-pillar {
    position: absolute;
    left: 50%;
    bottom: 12%;
    width: 2px;
    height: 70%;
    transform: translateX(-50%);
    background: linear-gradient(180deg, rgba(241, 183, 95, 0) 0%, rgba(241, 183, 95, 0.35) 60%, rgba(241, 183, 95, 0.6) 100%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 800ms var(--motion-ease) 400ms;
  }
  .tny.is-ready .tny-pillar {
    opacity: 1;
  }

  .tny-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  .tny-wheel {
    position: absolute;
    left: 50%;
    top: 56%;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .tny-orb {
    --size: 8.5rem;
    position: absolute;
    left: calc(var(--size) / -2);
    top: calc(var(--size) / -2);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--tone) 60%, transparent);
    background:
      radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--tone) 24%, transparent) 0%, transparent 70%),
      radial-gradient(circle at 50% 50%, rgba(7, 18, 32, 0.92) 60%, rgba(7, 18, 32, 0.7) 100%);
    color: var(--tone);
    cursor: pointer;
    pointer-events: auto;
    transition:
      box-shadow 320ms var(--motion-ease),
      border-color 320ms var(--motion-ease);
    will-change: transform, opacity;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--tone) 18%, transparent),
      0 12px 30px -10px rgba(0, 0, 0, 0.6),
      inset 0 0 18px color-mix(in srgb, var(--tone) 14%, transparent);
  }
  .tny-orb:focus-visible {
    outline: none;
    border-color: var(--tone);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--tone) 35%, transparent);
  }

  .tny-orb-glow {
    position: absolute;
    inset: -25%;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--tone) 60%, transparent) 0%, transparent 65%);
    opacity: 0.55;
    pointer-events: none;
    filter: blur(2px);
  }
  .tny-orb-disc {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--tone) 28%, transparent);
    background: radial-gradient(circle at 50% 30%, color-mix(in srgb, var(--tone) 18%, transparent), transparent 70%);
    pointer-events: none;
  }

  .tny-orb-glyph {
    position: absolute;
    inset: 18%;
    color: var(--tone);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--tone) 70%, transparent));
    pointer-events: none;
    transition: transform 400ms var(--motion-ease);
  }

  .tny-orb-tag {
    position: absolute;
    left: 50%;
    bottom: -1.6rem;
    transform: translateX(-50%);
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tone) 75%, white 25%);
    opacity: 0;
    transition: opacity 320ms var(--motion-ease);
    pointer-events: none;
    white-space: nowrap;
  }

  .tny-orb.is-active {
    border-color: var(--tone);
    box-shadow:
      0 0 0 1px var(--tone),
      0 0 36px color-mix(in srgb, var(--tone) 55%, transparent),
      0 18px 40px -12px rgba(0, 0, 0, 0.7),
      inset 0 0 28px color-mix(in srgb, var(--tone) 22%, transparent);
  }
  .tny-orb.is-active .tny-orb-tag {
    opacity: 1;
  }
  .tny-orb.is-active .tny-orb-glyph {
    animation: tny-glyph-spin 14s linear infinite;
  }
  .tny-orb.is-active .tny-orb-glow {
    animation: tny-glow-pulse 3.6s ease-in-out infinite;
  }

  @keyframes tny-glyph-spin {
    to { transform: rotate(360deg); }
  }
  @keyframes tny-glow-pulse {
    0%, 100% { opacity: 0.45; transform: scale(1); }
    50% { opacity: 0.75; transform: scale(1.08); }
  }

  .tny-controls {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1rem;
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    pointer-events: none;
  }
  .tny-nav {
    pointer-events: auto;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: 1px solid rgba(241, 183, 95, 0.3);
    background: rgba(7, 18, 32, 0.65);
    color: rgba(241, 183, 95, 0.85);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition:
      border-color 200ms var(--motion-ease),
      color 200ms var(--motion-ease),
      transform 200ms var(--motion-ease),
      background 200ms var(--motion-ease);
    backdrop-filter: blur(6px);
  }
  .tny-nav svg {
    width: 1rem;
    height: 1rem;
  }
  .tny-nav:hover,
  .tny-nav:focus-visible {
    border-color: rgba(241, 183, 95, 0.7);
    color: #fff7e2;
    background: rgba(241, 183, 95, 0.18);
    outline: none;
    transform: translateY(-1px);
  }

  .tny-hint {
    position: absolute;
    left: 50%;
    top: 1rem;
    transform: translateX(-50%);
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 247, 226, 0.6);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(241, 183, 95, 0.3);
    background: rgba(7, 18, 32, 0.5);
    backdrop-filter: blur(6px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 600ms var(--motion-ease) 1400ms;
  }
  .tny.is-ready .tny-hint {
    opacity: 1;
  }
  .tny-hint.is-hidden {
    opacity: 0;
    transition-delay: 0ms;
  }

  .tny-card {
    --tone: #e08fb0;
    --deep: #a14a6e;
    position: relative;
    padding: 1.5rem 1.75rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    background: var(--bg-strong);
    overflow: hidden;
    box-shadow: 0 12px 30px -18px color-mix(in srgb, var(--tone) 50%, transparent);
    transition:
      box-shadow 480ms var(--motion-ease),
      border-color 480ms var(--motion-ease);
  }
  .tny-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 5px;
    background: linear-gradient(180deg, var(--tone) 0%, var(--deep) 100%);
    border-radius: 0 4px 4px 0;
  }
  .tny-card-meta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .tny-card-eyebrow {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .tny-card-status {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--deep);
    font-variant-numeric: tabular-nums;
  }
  .tny-card-word {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 600;
