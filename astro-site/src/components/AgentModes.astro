---
// In-article figure for the All Aboard written deep-dive.
// Three operating modes for agents in Agent 365, with availability status.
// Deck blue-yellow palette; yellow marks the preview, green marks GA.
interface Mode {
  title: string;
  sub: string;
  lines: string[];
  status: string;
  state: 'ga' | 'preview';
}

const modes: Mode[] = [
  {
    title: 'On-behalf-of a user',
    sub: 'Delegated access',
    lines: ['Agent acts as the user', "The user's policies apply"],
    status: 'GA',
    state: 'ga',
  },
  {
    title: 'Own access, behind the scenes',
    sub: 'Service-style identity',
    lines: ['Agent has its own scope', 'Agent policies apply'],
    status: 'GA',
    state: 'ga',
  },
  {
    title: 'Own access, in team flow',
    sub: 'First-class teammate',
    lines: ['Joins channels and chats', 'Full agent governance'],
    status: 'Frontier preview',
    state: 'preview',
  },
];
---

<figure
  class="am-fig"
  role="img"
  aria-label="Three operating modes for agents in Agent 365: on-behalf-of a user with delegated access (generally available), own access behind the scenes with a service-style identity (generally available), and own access in a team flow as a first-class teammate (Frontier preview). All three land in one control plane."
>
  <div class="am-head">
    <span class="am-eyebrow">How an agent operates</span>
    <h3 class="am-title">Three modes, one control plane</h3>
  </div>

  <div class="am-grid">
    {modes.map((mode) => (
      <div class={`am-card am-card--${mode.state}`}>
        <span class="am-card-title">{mode.title}</span>
        <span class="am-card-sub">{mode.sub}</span>
        <ul class="am-card-lines">
          {mode.lines.map((line) => <li>{line}</li>)}
        </ul>
        <span class={`am-pill am-pill--${mode.state}`}>{mode.status}</span>
      </div>
    ))}
  </div>

  <figcaption class="am-caption">Three operating modes. One control plane.</figcaption>
</figure>

<style>
  .am-fig {
    container-type: inline-size;
    margin: 0;
    box-sizing: border-box;
    width: 100%;
    padding: clamp(1.2rem, 0.7rem + 2.4cqw, 2.4rem);
    border-radius: 18px;
    background:
      radial-gradient(130% 95% at 12% -10%, rgba(89, 159, 253, 0.3), transparent 58%),
      radial-gradient(120% 95% at 92% 115%, rgba(250, 220, 20, 0.16), transparent 55%),
      linear-gradient(150deg, #0e2a52 0%, #0b2344 55%, #081a36 100%);
    color: #eaf1fb;
    box-shadow: 0 24px 60px rgba(8, 20, 40, 0.32);
  }

  .am-head { margin-bottom: clamp(1rem, 0.6rem + 1.6cqw, 1.8rem); }

  .am-eyebrow {
    display: block;
    font-size: clamp(0.62rem, 0.55rem + 0.3cqw, 0.74rem);
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #599ffd;
  }

  .am-title {
    margin: 0.3rem 0 0;
    font-size: clamp(1.1rem, 0.85rem + 1.4cqw, 1.7rem);
    font-weight: 800;
    line-height: 1.12;
    color: #fff;
  }

  .am-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.5rem, 0.3rem + 0.8cqw, 1rem);
  }

  .am-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: clamp(0.8rem, 0.5rem + 1cqw, 1.3rem);
    border-radius: 13px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(165, 184, 238, 0.32);
  }
  .am-card--preview { border-color: rgba(250, 220, 20, 0.5); }

  .am-card-title {
    font-size: clamp(0.78rem, 0.64rem + 0.55cqw, 1.02rem);
    font-weight: 800;
    line-height: 1.15;
    color: #fff;
  }
  .am-card-sub {
    font-size: clamp(0.64rem, 0.56rem + 0.32cqw, 0.82rem);
    font-weight: 700;
    color: #599ffd;
  }
  .am-card--preview .am-card-sub { color: #fadc14; }

  .am-card-lines {
    margin: 0.25rem 0 0;
    padding-left: 1rem;
    list-style: disc;
  }
  .am-card-lines li {
    font-size: clamp(0.62rem, 0.54rem + 0.32cqw, 0.8rem);
    font-weight: 500;
    line-height: 1.4;
    color: #a5b8ee;
  }

  .am-pill {
    align-self: flex-start;
    margin-top: 0.5rem;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: clamp(0.56rem, 0.5rem + 0.28cqw, 0.72rem);
    font-weight: 800;
    letter-spacing: 0.04em;
  }
  .am-pill--ga {
    background: rgba(89, 159, 253, 0.85);
    color: #06183a;
  }
  .am-pill--preview {
    background: #fadc14;
    color: #2a1f02;
  }

  .am-caption {
    margin: clamp(0.9rem, 0.6rem + 1.2cqw, 1.5rem) 0 0;
    font-size: clamp(0.78rem, 0.7rem + 0.3cqw, 0.95rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #e2f9d9;
  }

  @container (max-width: 520px) {
    .am-grid { grid-template-columns: 1fr; }
  }
</style>
